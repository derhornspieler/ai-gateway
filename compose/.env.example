# Copy to .env — Ansible templates this from group_vars (secrets via Ansible
# Vault / SOPS overlays). Secret values are intentionally blank so Compose's
# `${VAR:?}` guards fail closed until each one is populated with a real random
# value; this file is not a runnable known-credential development profile.
# (Keycloak resolves the OIDC client secrets from these vars at realm import,
# so a missing/placeholder value means broken SSO for that client).
DEPLOYMENT_PROFILE=generic-rocky9
PLATFORM_AUTHORITATIVE_DNS_ENABLED=false
VAULT_UI_ENABLED=false
DOMAIN=aigw.example.internal
ETH1_IP=10.8.10.10      # ADM leg — traefik-adm bind (placeholder)
ETH2_IP=10.20.0.10      # internal leg — traefik-int bind (placeholder)
DOCKER_DATA_ROOT=/var/lib/docker  # must match Docker's configured data-root
# PostgreSQL 18 must use a new volume. Never point this at the old
# ai-gateway_pg_data PostgreSQL 16 volume.
PG_DATA_VOLUME_NAME=ai-gateway_pg18_data
# Resolver addresses are not shared through this runtime file. Ansible renders
# docker-compose.dns.yml from distinct internal_dns_servers/egress_dns_servers:
# routable ADM/internal edges use the former, Envoy alone uses the latter, and
# isolated backends remain Docker-service-discovery-only.
TRAEFIK_INT_CHAT_IP=172.28.3.2
TRAEFIK_INT_PORTAL_IP=172.28.4.2
TRAEFIK_ADM_ADMIN_IP=172.28.5.2
OAUTH2_PROXY_LITELLM_IP=172.28.5.3
TRAEFIK_ADM_GRAFANA_IP=172.28.6.2
OAUTH2_PROXY_GRAFANA_IP=172.28.6.3
PLATFORM_DNS_IP=172.28.18.2
ENVOY_EGRESS_IP=172.28.0.2
# Immutable Envoy build inputs. Generate these with the reviewed provider
# planner or, normally, let scripts/update-images.py prepare set them from
# repeated --provider arguments. Do not enter hostnames or CA paths here.
AIGW_EGRESS_SOURCE_DATE_EPOCH=0
AIGW_EGRESS_PROVIDERS=anthropic
AIGW_EGRESS_POLICY_SHA256=46792952f978335aa2681638f295d2208ab1d9a0154879a0d6dc9ef02d3a7907
ALLOY_INTERNAL_IP=172.28.2.2
ALLOY_TELEMETRY_IP=172.28.13.2
ALLOY_OBSERVABILITY_IP=172.28.15.2
PROMETHEUS_OBSERVABILITY_IP=172.28.15.3
ALERTMANAGER_OBSERVABILITY_IP=172.28.15.4
# Metrics stop at 30 days or this size cap, whichever comes first.
PROMETHEUS_RETENTION_SIZE=5GB

# Ansible writes keyed SHA-256 content markers after all bind sources exist.
# Blank values deliberately keep direct Compose startup fail-closed.
AIGW_BIND_DIGEST_TRAEFIK_INT=
AIGW_BIND_DIGEST_TRAEFIK_ADM=
AIGW_BIND_DIGEST_LITELLM=
AIGW_BIND_DIGEST_OPEN_WEBUI=
AIGW_BIND_DIGEST_KEYCLOAK=
AIGW_BIND_DIGEST_VAULT=
AIGW_BIND_DIGEST_POSTGRES=
AIGW_BIND_DIGEST_REDIS=
AIGW_BIND_DIGEST_ALLOY=
AIGW_BIND_DIGEST_PROMETHEUS=
AIGW_BIND_DIGEST_ALERTMANAGER=
AIGW_BIND_DIGEST_LOKI=
AIGW_BIND_DIGEST_GRAFANA=
AIGW_BIND_DIGEST_CRIBL_MOCK=
AIGW_BIND_DIGEST_KEY_ROTATOR=
AIGW_BIND_DIGEST_PLATFORM_DNS=

# ── Postgres ────────────────────────────────────────────────────────────
PG_SUPER_PASSWORD=
PG_LITELLM_PASSWORD=
PG_KEYCLOAK_PASSWORD=
PG_ROTATOR_PASSWORD=
PG_GRAFANA_RO_PASSWORD=                        # read-only Grafana spend-reporting role

# ── Keycloak ────────────────────────────────────────────────────────────
KC_ADMIN_PASSWORD=
KC_BOOTSTRAP_ADMIN_CLIENT_SECRET=              # 32+ random chars; one-time service bootstrap
# No users are seeded in the imported realms (no credentials in git). To
# bootstrap an admin: log in to https://auth.$DOMAIN with the Keycloak
# bootstrap admin (admin / KC_ADMIN_PASSWORD), create a user in the "aigw"
# realm and assign it the aigw-admins realm role. (Ansible path: see
# aigw_seed_test_users in ansible/group_vars/all.yml — defaults off.)

# ── LiteLLM ─────────────────────────────────────────────────────────────
LITELLM_MASTER_KEY=                            # e.g. sk-<48 random hex chars>
LITELLM_SALT_KEY=                              # encrypts /credentials rows in DB
REDIS_PASSWORD=
WEBUI_LITELLM_KEY=                             # 24+ random candidate; Ansible reconciles the exact scoped virtual key
WEBUI_SECRET_KEY=                              # stable 32+ random chars; never rotate during a normal rollout

# ── OIDC client secrets ─────────────────────────────────────────────────
# Keycloak substitutes these env vars into the realm at --import-realm time
# (the realm JSONs contain ${VAR} placeholders), and the apps receive the
# same values — set once here, both sides stay in sync. Import happens only
# on first boot of an empty Keycloak DB; changing a secret later requires
# updating the client in Keycloak too.
WEBUI_OIDC_CLIENT_SECRET=
PORTAL_OIDC_CLIENT_SECRET=
ADMIN_PORTAL_OIDC_CLIENT_SECRET=
OAUTH2_PROXY_CLIENT_SECRET=
OAUTH2_PROXY_LITELLM_COOKIE_SECRET=            # exactly 32 alphanumeric bytes; stable and unique per relying party
OAUTH2_PROXY_GRAFANA_COOKIE_SECRET=            # exactly 32 alphanumeric bytes; stable and unique per relying party
OAUTH2_PROXY_PROMETHEUS_COOKIE_SECRET=         # exactly 32 alphanumeric bytes; stable and unique per relying party
OAUTH2_PROXY_VAULT_COOKIE_SECRET=              # exactly 32 alphanumeric bytes; stable and unique per relying party
PORTAL_SESSION_SECRET=
ADMIN_PORTAL_SESSION_SECRET=

# ── key-rotator / Vault ────────────────────────────────────────────────
ROTATOR_INTERNAL_TOKEN=
PORTAL_IDENTITY_TOKEN=                          # distinct, portal-only identity-read token
ROTATOR_VAULT_TOKEN=                            # issued during the operator Vault ceremony
IDENTITY_CONTROLLER_KEY_VAULT_PATH=ai-gateway/keycloak/identity-controller-key
IDENTITY_STATE_VAULT_PATH=ai-gateway/keycloak/identity-state
KC_CLIENT_ASSERTION_KEY_VAULT_PATH=ai-gateway/anthropic-wif-client-key

# ── Observability ──────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=
# Plaintext is permitted only for this in-stack development mock. For a real
# Cribl worker set insecure=false, host:port (no URL scheme), its TLS DNS name,
# and mount the issuing CA at CRIBL_OTLP_CA_FILE.
CRIBL_OTLP_ENDPOINT=cribl-mock:4317
CRIBL_OTLP_INSECURE=true
CRIBL_OTLP_CA_FILE=/etc/ssl/certs/aigw-ca.pem
CRIBL_OTLP_SERVER_NAME=cribl-mock

# ── Vendor keys are NOT set here ───────────────────────────────────────
# They live in Vault (seeded by the operator ceremony) and are pushed
# into LiteLLM by key-rotator. See docs/solution-map.md §1.7.
