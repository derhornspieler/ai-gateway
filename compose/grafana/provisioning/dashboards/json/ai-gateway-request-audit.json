          "sort": "desc"
        }
      },
      "pluginVersion": "12.4.5",
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum by (aigw_project_id) (sum_over_time({service_name=\"aigw-requests\"} | logfmt | unwrap gen_ai_cost_total_cost [$__auto]))",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Cost by Project",
      "type": "timeseries"
    },
