      "options": {"legend": {"calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [{"editorMode": "code", "expr": "100 * otelcol_exporter_queue_size{job=\"alloy\"} / clamp_min(otelcol_exporter_queue_capacity{job=\"alloy\"}, 1)", "legendFormat": "{{component_id}} {{data_type}}", "range": true, "refId": "A"}],
      "title": "Alloy Persistent Queue Utilization",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
