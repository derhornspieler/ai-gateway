      "targets": [{"editorMode": "code", "expr": "sum by (job) (process_resident_memory_bytes{job=~\"grafana|loki|alloy|prometheus\"})", "legendFormat": "{{job}}", "range": true, "refId": "A"}],
      "title": "Observability Process Memory",
      "type": "timeseries"
    }
