      "targets": [{"editorMode": "code", "expr": "(sum(rate(otelcol_exporter_send_failed_log_records_total{job=\"alloy\"}[$__rate_interval])) or vector(0)) + (sum(rate(otelcol_exporter_send_failed_spans_total{job=\"alloy\"}[$__rate_interval])) or vector(0))", "instant": true, "legendFormat": "Failed", "range": false, "refId": "A"}],
      "title": "Alloy Export Failures",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "ops"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "id": 5,
      "options": {"legend": {"calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [
        {"editorMode": "code", "expr": "sum(rate(loki_distributor_lines_received_total{job=\"loki\"}[$__rate_interval]))", "legendFormat": "Loki lines", "range": true, "refId": "A"},
        {"editorMode": "code", "expr": "sum(rate(prometheus_tsdb_head_samples_appended_total{job=\"prometheus\"}[$__rate_interval]))", "legendFormat": "Prometheus samples", "range": true, "refId": "C"}
