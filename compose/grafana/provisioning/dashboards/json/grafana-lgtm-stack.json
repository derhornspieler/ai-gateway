        {"editorMode": "code", "expr": "histogram_quantile(0.95, sum by (le) (rate(grafana_datasource_request_duration_seconds_bucket{job=\"grafana\"}[$__rate_interval])))", "legendFormat": "Grafana datasource p95", "range": true, "refId": "C"}
      ],
      "title": "Query and Datasource Latency",
      "type": "timeseries"
