{
  "annotations": {"list": []},
  "description": "Traefik edge, Envoy egress, and Keycloak identity service health from their native metrics.",
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [{"keepTime": true, "tags": [], "targetBlank": false, "title": "AI Gateway Overview", "type": "link", "url": "/d/aigw-overview/ai-gateway-overview"}],
  "liveNow": false,
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"mappings": [{"options": {"0": {"color": "red", "text": "Down"}, "1": {"color": "green", "text": "Up"}}, "type": "value"}], "unit": "short"}, "overrides": []},
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "id": 1,
      "options": {"colorMode": "background", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"},
      "targets": [{"editorMode": "code", "expr": "sum(up{job=~\"traefik|envoy-egress|keycloak\"} == 1) == bool 4", "instant": true, "legendFormat": "Services", "range": false, "refId": "A"}],
      "title": "Edge / Egress / Identity",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []},
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "id": 2,
      "options": {"colorMode": "value", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"},
      "targets": [{"editorMode": "code", "expr": "sum(rate(traefik_service_requests_total{job=\"traefik\"}[$__rate_interval])) or vector(0)", "instant": true, "legendFormat": "Requests", "range": false, "refId": "A"}],
      "title": "Edge Request Rate",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "d"}, "overrides": []},
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "id": 3,
      "options": {"colorMode": "value", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"},
      "targets": [{"editorMode": "code", "expr": "min((traefik_tls_certs_not_after{job=\"traefik\"} - time()) / 86400)", "instant": true, "legendFormat": "Days", "range": false, "refId": "A"}],
      "title": "Edge Certificate Remaining",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "ops"}, "overrides": []},
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "id": 4,
      "options": {"colorMode": "value", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"},
      "targets": [{"editorMode": "code", "expr": "sum(rate(keycloak_credentials_password_hashing_validations_total{job=\"keycloak\"}[$__rate_interval])) or vector(0)", "instant": true, "legendFormat": "Validations", "range": false, "refId": "A"}],
      "title": "Keycloak Password Validations",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "id": 5,
      "options": {"legend": {"calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [{"editorMode": "code", "expr": "sum by (service, code) (rate(traefik_service_requests_total{job=\"traefik\"}[$__rate_interval]))", "legendFormat": "{{service}} {{code}}", "range": true, "refId": "A"}],
      "title": "Traefik Requests by Service and Status",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "id": 6,
      "options": {"legend": {"calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [{"editorMode": "code", "expr": "sum by (envoy_cluster_name, envoy_response_code_class) (rate(envoy_cluster_upstream_rq_xx{job=\"envoy-egress\"}[$__rate_interval]))", "legendFormat": "{{envoy_cluster_name}} {{envoy_response_code_class}}xx", "range": true, "refId": "A"}],
      "title": "Envoy Upstream Responses",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "bytes"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "id": 7,
      "options": {"legend": {"calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [
        {"editorMode": "code", "expr": "sum(jvm_memory_used_bytes{job=\"keycloak\",area=\"heap\"})", "legendFormat": "Used", "range": true, "refId": "A"},
        {"editorMode": "code", "expr": "sum(jvm_memory_max_bytes{job=\"keycloak\",area=\"heap\"} > 0)", "legendFormat": "Maximum", "range": true, "refId": "B"}
      ],
      "title": "Keycloak JVM Heap",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "ops"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "id": 8,
      "options": {"legend": {"calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [{"editorMode": "code", "expr": "sum by (realm, outcome) (rate(keycloak_credentials_password_hashing_validations_total{job=\"keycloak\"}[$__rate_interval]))", "legendFormat": "{{realm}} {{outcome}}", "range": true, "refId": "A"}],
      "title": "Keycloak Password Validation Outcomes",
      "type": "timeseries"
    }
  ],
