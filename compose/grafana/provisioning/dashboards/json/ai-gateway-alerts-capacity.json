      "gridPos": {"h": 4, "w": 8, "x": 0, "y": 43},
      "id": 14,
      "options": {"colorMode": "value", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"},
      "targets": [{"editorMode": "code", "expr": "min((traefik_tls_certs_not_after{job=\"traefik\"} - time()) / 86400)", "instant": true, "legendFormat": "Days", "range": false, "refId": "A"}],
      "title": "Shortest Certificate Lifetime",
