      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 27},
      "id": 11,
      "options": {"legend": {"calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [{"editorMode": "code", "expr": "1000 * (rate(node_disk_read_time_seconds_total{job=\"node-exporter\",device!~\"^(ram|loop|fd|sr)[0-9]*$\"}[$__rate_interval]) + rate(node_disk_write_time_seconds_total{job=\"node-exporter\",device!~\"^(ram|loop|fd|sr)[0-9]*$\"}[$__rate_interval])) / clamp_min(rate(node_disk_reads_completed_total{job=\"node-exporter\",device!~\"^(ram|loop|fd|sr)[0-9]*$\"}[$__rate_interval]) + rate(node_disk_writes_completed_total{job=\"node-exporter\",device!~\"^(ram|loop|fd|sr)[0-9]*$\"}[$__rate_interval]), 0.001)", "legendFormat": "{{device}} average", "range": true, "refId": "A"}],
      "title": "Disk I/O Service Time",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []},
