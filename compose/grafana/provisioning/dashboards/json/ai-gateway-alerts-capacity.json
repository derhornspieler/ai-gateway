    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "This count includes the watchdog. Use Grafana Alerting for the grouped Alertmanager view and silence controls.",
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "gridPos": {"h": 4, "w": 8, "x": 16, "y": 43},
      "id": 16,
      "options": {"colorMode": "value", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"},
      "targets": [{"editorMode": "code", "expr": "sum(alertmanager_alerts{state=\"active\"}) or vector(0)", "instant": true, "legendFormat": "Active", "range": false, "refId": "A"}],
      "title": "Alertmanager Active Alerts",
      "type": "stat"
