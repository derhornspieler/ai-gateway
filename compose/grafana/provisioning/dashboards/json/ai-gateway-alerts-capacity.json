      "id": 15,
      "options": {"colorMode": "value", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"},
      "targets": [{"editorMode": "code", "expr": "100 * otelcol_exporter_queue_size{job=\"alloy\",component_id=\"otelcol.exporter.otlp.cribl\"} / clamp_min(otelcol_exporter_queue_capacity{job=\"alloy\",component_id=\"otelcol.exporter.otlp.cribl\"}, 1)", "instant": true, "legendFormat": "Queue", "range": false, "refId": "A"}],
