      "options": {"alignValue": "left", "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true}, "mergeValues": true, "rowHeight": 0.9, "showValue": "never", "tooltip": {"mode": "single", "sort": "none"}},
      "targets": [{"editorMode": "code", "expr": "max by (alertname, severity) (ALERTS{alertname!=\"AIGatewayWatchdog\"})", "legendFormat": "{{severity}} · {{alertname}}", "range": true, "refId": "A"}],
      "title": "Alert Lifecycle Timeline",
      "type": "state-timeline"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"max": 100, "min": 0, "unit": "percent"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 19},
      "id": 8,
      "options": {"legend": {"calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [
        {"editorMode": "code", "expr": "100 * (1 - avg by (instance) (rate(node_cpu_seconds_total{job=\"node-exporter\",mode=\"idle\"}[$__rate_interval])))", "legendFormat": "CPU busy", "range": true, "refId": "A"},
        {"editorMode": "code", "expr": "100 * (1 - node_memory_MemAvailable_bytes{job=\"node-exporter\"} / node_memory_MemTotal_bytes{job=\"node-exporter\"})", "legendFormat": "Memory used", "range": true, "refId": "B"},
        {"editorMode": "code", "expr": "100 * (node_memory_SwapTotal_bytes{job=\"node-exporter\"} - node_memory_SwapFree_bytes{job=\"node-exporter\"}) / clamp_min(node_memory_SwapTotal_bytes{job=\"node-exporter\"}, 1)", "legendFormat": "Swap used", "range": true, "refId": "C"}
      ],
      "title": "Host CPU, Memory, and Swap Pressure",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"max": 100, "min": 0, "unit": "percent"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 19},
      "id": 9,
      "options": {"legend": {"calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "asc"}},
      "targets": [
        {"editorMode": "code", "expr": "100 * node_filesystem_avail_bytes{job=\"node-exporter\",fstype!~\"tmpfs|devtmpfs|overlay|squashfs\"} / node_filesystem_size_bytes{job=\"node-exporter\",fstype!~\"tmpfs|devtmpfs|overlay|squashfs\"}", "legendFormat": "{{mountpoint}} space free", "range": true, "refId": "A"},
        {"editorMode": "code", "expr": "100 * node_filesystem_files_free{job=\"node-exporter\",fstype!~\"tmpfs|devtmpfs|overlay|squashfs\"} / node_filesystem_files{job=\"node-exporter\",fstype!~\"tmpfs|devtmpfs|overlay|squashfs\"}", "legendFormat": "{{mountpoint}} inodes free", "range": true, "refId": "B"}
      ],
      "title": "Filesystem Space and Inodes Free",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
