      "id": 10,
      "options": {"legend": {"calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [{"editorMode": "code", "expr": "100 * rate(node_disk_io_time_seconds_total{job=\"node-exporter\",device!~\"^(ram|loop|fd|sr)[0-9]*$\"}[$__rate_interval])", "legendFormat": "{{device}} busy", "range": true, "refId": "A"}],
