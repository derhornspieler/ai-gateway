      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 35},
      "id": 13,
      "options": {"legend": {"calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [{"editorMode": "code", "expr": "100 * sum by (service) (rate(traefik_service_requests_total{job=\"traefik\",code=~\"5..\"}[$__rate_interval])) / sum by (service) (rate(traefik_service_requests_total{job=\"traefik\"}[$__rate_interval]))", "legendFormat": "{{service}} 5xx", "range": true, "refId": "A"}],
      "title": "Service 5xx Error Rate",
      "type": "timeseries"
