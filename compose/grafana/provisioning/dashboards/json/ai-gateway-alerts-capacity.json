    {"keepTime": false, "tags": [], "targetBlank": false, "title": "Alert response runbooks", "type": "link", "url": "/d/aigw-alerts-capacity/ai-gateway-alerts-and-capacity?viewPanel=17"}
  ],
  "liveNow": false,
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Healthy only when Prometheus evaluates the watchdog, discovers Alertmanager, Alloy scrapes Alertmanager, and Alertmanager reports at least one active alert.",
      "fieldConfig": {"defaults": {"mappings": [{"options": {"0": {"color": "red", "text": "Broken"}, "1": {"color": "green", "text": "Healthy"}}, "type": "value"}], "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}}, "overrides": []},
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "id": 1,
      "options": {"colorMode": "background", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"},
      "targets": [{"editorMode": "code", "expr": "((sum(ALERTS{alertname=\"AIGatewayWatchdog\",alertstate=\"firing\"}) or vector(0)) == bool 1) * ((max(prometheus_notifications_alertmanagers_discovered{job=\"prometheus\"}) or vector(0)) >= bool 1) * ((sum(up{job=\"alertmanager\"}) or vector(0)) == bool 1) * ((sum(alertmanager_alerts{state=\"active\"}) or vector(0)) >= bool 1)", "instant": true, "legendFormat": "Alert path", "range": false, "refId": "A"}],
      "title": "Prometheus → Alertmanager → Grafana Watchdog",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"color": {"fixedColor": "red", "mode": "fixed"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 1}]}, "unit": "short"}, "overrides": []},
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "id": 2,
      "options": {"colorMode": "background", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"},
      "targets": [{"editorMode": "code", "expr": "sum(ALERTS{alertstate=\"firing\",severity=\"critical\",alertname!=\"AIGatewayWatchdog\"}) or vector(0)", "instant": true, "legendFormat": "Critical", "range": false, "refId": "A"}],
      "title": "Active Critical Alerts",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"color": {"fixedColor": "yellow", "mode": "fixed"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1}]}, "unit": "short"}, "overrides": []},
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "id": 3,
      "options": {"colorMode": "background", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"},
      "targets": [{"editorMode": "code", "expr": "sum(ALERTS{alertstate=\"firing\",severity=\"warning\"}) or vector(0)", "instant": true, "legendFormat": "Warning", "range": false, "refId": "A"}],
      "title": "Active Warning Alerts",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Alerts that fired at least once in the last 24 hours and are not firing now.",
      "fieldConfig": {"defaults": {"color": {"fixedColor": "blue", "mode": "fixed"}, "unit": "short"}, "overrides": []},
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "id": 4,
      "options": {"colorMode": "value", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"},
      "targets": [{"editorMode": "code", "expr": "count((max_over_time(ALERTS{alertstate=\"firing\",alertname!=\"AIGatewayWatchdog\"}[24h]) == 1) unless ALERTS{alertstate=\"firing\",alertname!=\"AIGatewayWatchdog\"}) or vector(0)", "instant": true, "legendFormat": "Resolved", "range": false, "refId": "A"}],
      "title": "Recently Resolved (24h)",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Every active Prometheus rule except the always-firing watchdog. Critical alerts inhibit matching warnings in Alertmanager but both evaluator states remain visible here.",
      "fieldConfig": {"defaults": {"custom": {"align": "auto", "cellOptions": {"type": "auto"}, "inspect": false}, "unit": "short"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "id": 5,
      "options": {"cellHeight": "sm", "footer": {"countRows": false, "fields": "", "reducer": ["sum"], "show": false}, "showHeader": true},
      "targets": [{"editorMode": "code", "expr": "ALERTS{alertstate=\"firing\",alertname!=\"AIGatewayWatchdog\"}", "format": "table", "instant": true, "legendFormat": "{{alertname}}", "range": false, "refId": "A"}],
      "title": "Active Alerts",
      "type": "table"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Prometheus retains rule-state history after Alertmanager removes the resolved alert from its active API.",
      "fieldConfig": {"defaults": {"custom": {"align": "auto", "cellOptions": {"type": "auto"}, "inspect": false}, "unit": "short"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "id": 6,
      "options": {"cellHeight": "sm", "footer": {"countRows": false, "fields": "", "reducer": ["sum"], "show": false}, "showHeader": true},
      "targets": [{"editorMode": "code", "expr": "(max_over_time(ALERTS{alertstate=\"firing\",alertname!=\"AIGatewayWatchdog\"}[24h]) == 1) unless ALERTS{alertstate=\"firing\",alertname!=\"AIGatewayWatchdog\"}", "format": "table", "instant": true, "legendFormat": "{{alertname}}", "range": false, "refId": "A"}],
      "title": "Recently Resolved Alerts",
      "type": "table"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"custom": {"fillOpacity": 70, "lineWidth": 0, "spanNulls": false}, "mappings": [{"options": {"1": {"color": "red", "text": "Firing"}}, "type": "value"}]}, "overrides": []},
