      "id": 12,
      "options": {"legend": {"calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [{"editorMode": "code", "expr": "histogram_quantile(0.95, sum by (service, le) (rate(traefik_service_request_duration_seconds_bucket{job=\"traefik\"}[$__rate_interval])))", "legendFormat": "{{service}} p95", "range": true, "refId": "A"}],
      "title": "Service p95 Latency",
