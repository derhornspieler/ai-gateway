// Grafana Alloy — observability fan-out (solution-map §1.8).
//
// Trust boundaries:
// - OTLP listens only on Alloy's fixed net-telemetry address. Port 4318 accepts
//   ordinary internal telemetry but strips the server-owned LiteLLM marker.
//   Port 4319 accepts LiteLLM traces only after bearer authentication. Attaching
//   Alloy to storage/export networks must never expose either receiver or its
//   HTTP UI on those networks.
// - Every signal that passes the source and credential gates is mirrored to
//   Cribl. The same sanitized logs and metrics still reach Loki and Prometheus.
//   Cribl is the trace store; this release has no local trace database.
// - Full prompt/completion bodies are deliberate span attributes (§9.7).
//   Credential-shaped values are removed before either local or Cribl output.
// - Docker logs are read from the host's json-file directory, read-only. The
//   Docker API socket is intentionally not mounted.

local.file "litellm_otel_token" {
  filename  = "/run/secrets/litellm_otel_token"
  is_secret = true
}

otelcol.auth.bearer "litellm" {
  token = local.file.litellm_otel_token.content
}

otelcol.receiver.otlp "default" {
  grpc { endpoint = sys.env("ALLOY_TELEMETRY_IP") + ":4317" }
  http { endpoint = sys.env("ALLOY_TELEMETRY_IP") + ":4318" }
  output {
    traces  = [otelcol.processor.attributes.untrusted_source.input]
    logs    = [otelcol.processor.memory_limiter.default.input]
    metrics = [otelcol.processor.memory_limiter.default.input]
  }
}

otelcol.receiver.otlp "litellm" {
  http {
    endpoint = sys.env("ALLOY_TELEMETRY_IP") + ":4319"
    auth     = otelcol.auth.bearer.litellm.handler
  }
  output {
    traces = [otelcol.processor.attributes.authenticated_litellm.input]
  }
}

// A caller cannot self-assert this marker. The open receiver deletes it, and
// the authenticated receiver overwrites it after checking the shared token.
otelcol.processor.attributes "untrusted_source" {
  action {
    key    = "aigw.security.source_authenticated"
    action = "delete"
  }
  output {
    traces = [otelcol.processor.filter.untrusted_source.input]
  }
}

// The open receiver is for ordinary internal telemetry, such as key-rotator.
// A peer may claim any resource name in its payload, so reject every LiteLLM
// claim here. Only the authenticated receiver below may admit that source.
otelcol.processor.filter "untrusted_source" {
  error_mode = "propagate"
  traces {
    span = [
      `resource.attributes["service.name"] == "litellm"`,
    ]
  }
  output {
    traces = [otelcol.processor.memory_limiter.default.input]
  }
}

otelcol.processor.attributes "authenticated_litellm" {
  action {
    key    = "aigw.security.source_authenticated"
    action = "upsert"
    value  = "litellm_bearer_v1"
  }
  output {
    traces = [otelcol.processor.memory_limiter.default.input]
  }
}

// The container limit is 512 MiB. Refuse/retry upstream before an exporter
// outage or several large full-prompt spans OOM-kill the collector.
otelcol.processor.memory_limiter "default" {
  check_interval = "1s"
  limit          = "384MiB"
  spike_limit    = "64MiB"
  output {
    traces  = [otelcol.processor.transform.aigw_correlation.input]
    logs    = [otelcol.processor.transform.aigw_sensitive_attributes.input]
    metrics = [otelcol.processor.transform.aigw_sensitive_attributes.input]
  }
}

// Build stable request attribution from LiteLLM's server callback fields.
// Caller end-user fields, auth metadata text, key aliases, headers, and JWTs
// are never name authority. The callback selects one reviewed source; Alloy
// validates it, copies it to the public audit fields, and later deletes the
// raw server fields.
// BEGIN AIGW MANAGED TRACE CORRELATION
otelcol.processor.transform "aigw_correlation" {
  error_mode = "propagate"

  trace_statements {
    context = "span"
    statements = [
      `set(attributes["aigw.user.id"], attributes["metadata.user_api_key_user_id"]) where resource.attributes["service.name"] == "litellm" and name == "litellm_request" and IsString(attributes["metadata.user_api_key_user_id"]) and IsMatch(attributes["metadata.user_api_key_user_id"], "^[A-Za-z0-9][A-Za-z0-9_.:@-]{0,127}$")`,
      `set(attributes["aigw.user.id"], attributes["aigw.server.user.id"]) where resource.attributes["service.name"] == "litellm" and name == "litellm_request" and IsString(attributes["aigw.server.user.id"]) and IsMatch(attributes["aigw.server.user.id"], "^[A-Za-z0-9][A-Za-z0-9_.:@-]{0,127}$") and attributes["aigw.server.user.name_source"] == "open_webui_signed_oidc"`,
      `set(attributes["aigw.api_key.id"], attributes["metadata.user_api_key_hash"]) where resource.attributes["service.name"] == "litellm" and name == "litellm_request" and IsString(attributes["metadata.user_api_key_hash"]) and IsMatch(attributes["metadata.user_api_key_hash"], "^[0-9a-f]{64}$")`,
      `set(attributes["aigw.request.id"], attributes["litellm.call_id"]) where resource.attributes["service.name"] == "litellm" and name == "litellm_request" and IsString(attributes["litellm.call_id"]) and IsMatch(attributes["litellm.call_id"], "^[A-Za-z0-9][A-Za-z0-9_.:-]{0,127}$")`,
      `set(attributes["aigw.project.id"], attributes["metadata.user_api_key_project_id"]) where resource.attributes["service.name"] == "litellm" and name == "litellm_request" and IsString(attributes["metadata.user_api_key_project_id"]) and IsMatch(attributes["metadata.user_api_key_project_id"], "^[a-z0-9][a-z0-9_.-]{0,63}$")`,
      `set(attributes["aigw.project.id"], ExtractPatterns(attributes["metadata.user_api_key_auth_metadata"], "['\\\"]aigw_project_id['\\\"][[:space:]]*:[[:space:]]*['\\\"](?P<project>[a-z0-9][a-z0-9_.-]{0,63})['\\\"]")["project"]) where resource.attributes["service.name"] == "litellm" and name == "litellm_request" and attributes["aigw.project.id"] == nil and IsString(attributes["metadata.user_api_key_auth_metadata"]) and IsMatch(attributes["metadata.user_api_key_auth_metadata"], "['\\\"]aigw_project_id['\\\"][[:space:]]*:[[:space:]]*['\\\"](?P<project>[a-z0-9][a-z0-9_.-]{0,63})['\\\"]")`,
      `delete_key(attributes, "aigw.user.name")`,
      `delete_key(attributes, "aigw.user.name_source")`,
      `set(attributes["aigw.user.name"], attributes["aigw.server.user.name"]) where resource.attributes["service.name"] == "litellm" and name == "litellm_request" and IsString(attributes["aigw.server.user.name"]) and IsMatch(attributes["aigw.server.user.name"], "^[A-Za-z0-9][A-Za-z0-9_.:@-]{0,127}$") and IsString(attributes["aigw.server.user.name_source"]) and (attributes["aigw.server.user.name_source"] == "portal_key_metadata" or attributes["aigw.server.user.name_source"] == "key_subject" or (attributes["aigw.server.user.name_source"] == "open_webui_signed_oidc" and IsString(attributes["aigw.server.user.id"]) and IsMatch(attributes["aigw.server.user.id"], "^[A-Za-z0-9][A-Za-z0-9_.:@-]{0,127}$")))`,
      `set(attributes["aigw.user.name_source"], attributes["aigw.server.user.name_source"]) where attributes["aigw.user.name"] != nil`,
    ]
  }

  output {
    traces = [otelcol.processor.transform.aigw_sensitive_attributes.input]
  }
}
// END AIGW MANAGED TRACE CORRELATION

// Promote correlation first, then remove every raw identity/credential source
// before any signal can reach Prometheus, Loki, or customer Cribl.  The
// application requirement to retain prompt/completion bodies is deliberate:
// gen_ai.input.messages, gen_ai.output.messages, and their legacy prompt /
// completion equivalents remain, but obvious credential-shaped values inside
// those strings are replaced before the prompt can enter a log or trace.
// BEGIN AIGW MANAGED SENSITIVE ATTRIBUTE FILTER
otelcol.processor.transform "aigw_sensitive_attributes" {
  // Attribute removal is a security boundary. A runtime transform failure
  // drops the affected telemetry instead of exporting an unsanitized copy.
  error_mode = "propagate"

  trace_statements {
    context = "resource"
    statements = [
      `delete_matching_keys(attributes, "(?i)^metadata\\.user_api_key_.*$")`,
      `delete_matching_keys(attributes, "(?i)^(?:(?:.*[._-])?(?:authorization|api[_-]?key|x[_-]?api[_-]?key|access[_-]?token|refresh[_-]?token|client[_-]?secret|password|headers?|hidden_params|proxy_server_request|requester_.*|session[._ -]?(?:id|token|secret|key|cookie)|vault[._ -]?(?:token|unseal[._ -]?(?:key|share|token)|recovery[._ -]?(?:key|share|token))|client[._ -]?assertion|id[._-]?token|jwt|token|private[._-]?key(?:[._-]?pem)?)|metadata\\.(?:requester_.*|spend_logs_metadata|prompt_management_metadata))$")`,
      `delete_matching_keys(attributes, "(?i)^http\\.request\\.header\\..*$")`,
      `delete_matching_keys(attributes, "(?i)^http\\.response\\.header\\.set[-_]?cookie$")`,
      `delete_matching_keys(attributes, "(?i)^(?:client|server|network\\.peer|net\\.peer)\\.(?:address|port|ip|name)$")`,
      `delete_matching_keys(attributes, "(?i)^(?:http\\.client_ip|url\\.query|http\\.target|requester_ip_address|(?:.*\\.)?(?:email|e_mail|e-mail))$")`,
    ]
  }

  trace_statements {
    context = "scope"
    statements = [
      `delete_matching_keys(attributes, "(?i)^metadata\\.user_api_key_.*$")`,
      `delete_matching_keys(attributes, "(?i)^(?:(?:.*[._-])?(?:authorization|api[_-]?key|x[_-]?api[_-]?key|access[_-]?token|refresh[_-]?token|client[_-]?secret|password|headers?|hidden_params|proxy_server_request|requester_.*|session[._ -]?(?:id|token|secret|key|cookie)|vault[._ -]?(?:token|unseal[._ -]?(?:key|share|token)|recovery[._ -]?(?:key|share|token))|client[._ -]?assertion|id[._-]?token|jwt|token|private[._-]?key(?:[._-]?pem)?)|metadata\\.(?:requester_.*|spend_logs_metadata|prompt_management_metadata))$")`,
      `delete_matching_keys(attributes, "(?i)^http\\.request\\.header\\..*$")`,
      `delete_matching_keys(attributes, "(?i)^http\\.response\\.header\\.set[-_]?cookie$")`,
      `delete_matching_keys(attributes, "(?i)^(?:client|server|network\\.peer|net\\.peer)\\.(?:address|port|ip|name)$")`,
      `delete_matching_keys(attributes, "(?i)^(?:http\\.client_ip|url\\.query|http\\.target|requester_ip_address|(?:.*\\.)?(?:email|e_mail|e-mail))$")`,
    ]
  }

  trace_statements {
    context = "span"
    statements = [
      // LiteLLM records the caller's optional request `user` in these raw
      // fields. They are prompt input, never identity authority. Keep the
      // server-owned aigw.user.* fields and remove these look-alikes.
      `delete_key(attributes, "llm.user")`,
      `delete_key(attributes, "llm.anthropic.metadata")`,
      `replace_pattern(attributes["gen_ai.input.messages"], "(?i)(?:authorization|api[_-]?key|x[_-]?api[_-]?key|access[_-]?token|refresh[_-]?token|client[_-]?secret|password|session[ _-]?(?:id|token|secret|key|cookie)|vault[ _-]?(?:token|unseal[ _-]?(?:key|share|token)|recovery[ _-]?(?:key|share|token))|client[ _-]?assertion)[^A-Za-z0-9\\r\\n]{0,3}[:=][^A-Za-z0-9\\r\\n\\\"]{0,3}\\\"(?:\\\\.|[^\\\"\\\\\\r\\n])+(?:\\\\)?\\\"", "<redacted-credential>") where IsString(attributes["gen_ai.input.messages"])`,
      `replace_pattern(attributes["gen_ai.input.messages"], "(?i)(?:authorization|api[_-]?key|x[_-]?api[_-]?key|access[_-]?token|refresh[_-]?token|client[_-]?secret|password|session[ _-]?(?:id|token|secret|key|cookie)|vault[ _-]?(?:token|unseal[ _-]?(?:key|share|token)|recovery[ _-]?(?:key|share|token))|client[ _-]?assertion)[^A-Za-z0-9\\r\\n]{0,3}[:=][^A-Za-z0-9\\r\\n']{0,3}'(?:\\\\.|[^'\\\\\\r\\n])+(?:\\\\)?'", "<redacted-credential>") where IsString(attributes["gen_ai.input.messages"])`,
      `replace_pattern(attributes["gen_ai.input.messages"], "(?i)(?:authorization|api[_-]?key|x[_-]?api[_-]?key|access[_-]?token|refresh[_-]?token|client[_-]?secret|password|session[ _-]?(?:id|token|secret|key|cookie)|vault[ _-]?(?:token|unseal[ _-]?(?:key|share|token)|recovery[ _-]?(?:key|share|token))|client[ _-]?assertion)[\\\"']?[[:space:]]*[:=][[:space:]]*[\\\"']?(?:(?:bearer|basic)[[:space:]]+)?[^\\\"'[:space:],}]+", "<redacted-credential>") where IsString(attributes["gen_ai.input.messages"])`,
      `replace_pattern(attributes["gen_ai.input.messages"], "(?i)\\b(?:bearer|basic)[[:space:]]+[A-Za-z0-9._~+/-]{8,}", "<redacted-authorization>") where IsString(attributes["gen_ai.input.messages"])`,
      `replace_pattern(attributes["gen_ai.input.messages"], "\\bsk-(?:ant-)?[A-Za-z0-9_-]{16,}\\b", "<redacted-vendor-key>") where IsString(attributes["gen_ai.input.messages"])`,
      `replace_pattern(attributes["gen_ai.input.messages"], "\\beyJ[A-Za-z0-9_-]{5,}\\.[A-Za-z0-9_-]{8,}\\.[A-Za-z0-9_-]{8,}\\b", "<redacted-jwt>") where IsString(attributes["gen_ai.input.messages"])`,
      `replace_pattern(attributes["gen_ai.input.messages"], "\\b(?:hvs|hvb|hvr|s|b)\\.[A-Za-z0-9_-]{16,}\\b", "<redacted-vault-token>") where IsString(attributes["gen_ai.input.messages"])`,
      `replace_pattern(attributes["gen_ai.input.messages"], "(?s)-----BEGIN (?:PRIVATE KEY|RSA PRIVATE KEY|EC PRIVATE KEY|DSA PRIVATE KEY|ENCRYPTED PRIVATE KEY|OPENSSH PRIVATE KEY)-----.*?(?:-----END (?:PRIVATE KEY|RSA PRIVATE KEY|EC PRIVATE KEY|DSA PRIVATE KEY|ENCRYPTED PRIVATE KEY|OPENSSH PRIVATE KEY)-----|$)", "<redacted-private-key>") where IsString(attributes["gen_ai.input.messages"])`,
      `replace_pattern(attributes["gen_ai.output.messages"], "(?i)(?:authorization|api[_-]?key|x[_-]?api[_-]?key|access[_-]?token|refresh[_-]?token|client[_-]?secret|password|session[ _-]?(?:id|token|secret|key|cookie)|vault[ _-]?(?:token|unseal[ _-]?(?:key|share|token)|recovery[ _-]?(?:key|share|token))|client[ _-]?assertion)[^A-Za-z0-9\\r\\n]{0,3}[:=][^A-Za-z0-9\\r\\n\\\"]{0,3}\\\"(?:\\\\.|[^\\\"\\\\\\r\\n])+(?:\\\\)?\\\"", "<redacted-credential>") where IsString(attributes["gen_ai.output.messages"])`,
      `replace_pattern(attributes["gen_ai.output.messages"], "(?i)(?:authorization|api[_-]?key|x[_-]?api[_-]?key|access[_-]?token|refresh[_-]?token|client[_-]?secret|password|session[ _-]?(?:id|token|secret|key|cookie)|vault[ _-]?(?:token|unseal[ _-]?(?:key|share|token)|recovery[ _-]?(?:key|share|token))|client[ _-]?assertion)[^A-Za-z0-9\\r\\n]{0,3}[:=][^A-Za-z0-9\\r\\n']{0,3}'(?:\\\\.|[^'\\\\\\r\\n])+(?:\\\\)?'", "<redacted-credential>") where IsString(attributes["gen_ai.output.messages"])`,
      `replace_pattern(attributes["gen_ai.output.messages"], "(?i)(?:authorization|api[_-]?key|x[_-]?api[_-]?key|access[_-]?token|refresh[_-]?token|client[_-]?secret|password|session[ _-]?(?:id|token|secret|key|cookie)|vault[ _-]?(?:token|unseal[ _-]?(?:key|share|token)|recovery[ _-]?(?:key|share|token))|client[ _-]?assertion)[\\\"']?[[:space:]]*[:=][[:space:]]*[\\\"']?(?:(?:bearer|basic)[[:space:]]+)?[^\\\"'[:space:],}]+", "<redacted-credential>") where IsString(attributes["gen_ai.output.messages"])`,
      `replace_pattern(attributes["gen_ai.output.messages"], "(?i)\\b(?:bearer|basic)[[:space:]]+[A-Za-z0-9._~+/-]{8,}", "<redacted-authorization>") where IsString(attributes["gen_ai.output.messages"])`,
      `replace_pattern(attributes["gen_ai.output.messages"], "\\bsk-(?:ant-)?[A-Za-z0-9_-]{16,}\\b", "<redacted-vendor-key>") where IsString(attributes["gen_ai.output.messages"])`,
      `replace_pattern(attributes["gen_ai.output.messages"], "\\beyJ[A-Za-z0-9_-]{5,}\\.[A-Za-z0-9_-]{8,}\\.[A-Za-z0-9_-]{8,}\\b", "<redacted-jwt>") where IsString(attributes["gen_ai.output.messages"])`,
      `replace_pattern(attributes["gen_ai.output.messages"], "\\b(?:hvs|hvb|hvr|s|b)\\.[A-Za-z0-9_-]{16,}\\b", "<redacted-vault-token>") where IsString(attributes["gen_ai.output.messages"])`,
      `replace_pattern(attributes["gen_ai.output.messages"], "(?s)-----BEGIN (?:PRIVATE KEY|RSA PRIVATE KEY|EC PRIVATE KEY|DSA PRIVATE KEY|ENCRYPTED PRIVATE KEY|OPENSSH PRIVATE KEY)-----.*?(?:-----END (?:PRIVATE KEY|RSA PRIVATE KEY|EC PRIVATE KEY|DSA PRIVATE KEY|ENCRYPTED PRIVATE KEY|OPENSSH PRIVATE KEY)-----|$)", "<redacted-private-key>") where IsString(attributes["gen_ai.output.messages"])`,
      `replace_pattern(attributes["gen_ai.prompt.0.content"], "(?i)(?:authorization|api[_-]?key|x[_-]?api[_-]?key|access[_-]?token|refresh[_-]?token|client[_-]?secret|password|session[ _-]?(?:id|token|secret|key|cookie)|vault[ _-]?(?:token|unseal[ _-]?(?:key|share|token)|recovery[ _-]?(?:key|share|token))|client[ _-]?assertion)[^A-Za-z0-9\\r\\n]{0,3}[:=][^A-Za-z0-9\\r\\n\\\"]{0,3}\\\"(?:\\\\.|[^\\\"\\\\\\r\\n])+(?:\\\\)?\\\"", "<redacted-credential>") where IsString(attributes["gen_ai.prompt.0.content"])`,
      `replace_pattern(attributes["gen_ai.prompt.0.content"], "(?i)(?:authorization|api[_-]?key|x[_-]?api[_-]?key|access[_-]?token|refresh[_-]?token|client[_-]?secret|password|session[ _-]?(?:id|token|secret|key|cookie)|vault[ _-]?(?:token|unseal[ _-]?(?:key|share|token)|recovery[ _-]?(?:key|share|token))|client[ _-]?assertion)[^A-Za-z0-9\\r\\n]{0,3}[:=][^A-Za-z0-9\\r\\n']{0,3}'(?:\\\\.|[^'\\\\\\r\\n])+(?:\\\\)?'", "<redacted-credential>") where IsString(attributes["gen_ai.prompt.0.content"])`,
      `replace_pattern(attributes["gen_ai.prompt.0.content"], "(?i)(?:authorization|api[_-]?key|x[_-]?api[_-]?key|access[_-]?token|refresh[_-]?token|client[_-]?secret|password|session[ _-]?(?:id|token|secret|key|cookie)|vault[ _-]?(?:token|unseal[ _-]?(?:key|share|token)|recovery[ _-]?(?:key|share|token))|client[ _-]?assertion)[\\\"']?[[:space:]]*[:=][[:space:]]*[\\\"']?(?:(?:bearer|basic)[[:space:]]+)?[^\\\"'[:space:],}]+", "<redacted-credential>") where IsString(attributes["gen_ai.prompt.0.content"])`,
      `replace_pattern(attributes["gen_ai.prompt.0.content"], "(?i)\\b(?:bearer|basic)[[:space:]]+[A-Za-z0-9._~+/-]{8,}", "<redacted-authorization>") where IsString(attributes["gen_ai.prompt.0.content"])`,
      `replace_pattern(attributes["gen_ai.prompt.0.content"], "\\bsk-(?:ant-)?[A-Za-z0-9_-]{16,}\\b", "<redacted-vendor-key>") where IsString(attributes["gen_ai.prompt.0.content"])`,
      `replace_pattern(attributes["gen_ai.prompt.0.content"], "\\beyJ[A-Za-z0-9_-]{5,}\\.[A-Za-z0-9_-]{8,}\\.[A-Za-z0-9_-]{8,}\\b", "<redacted-jwt>") where IsString(attributes["gen_ai.prompt.0.content"])`,
      `replace_pattern(attributes["gen_ai.prompt.0.content"], "\\b(?:hvs|hvb|hvr|s|b)\\.[A-Za-z0-9_-]{16,}\\b", "<redacted-vault-token>") where IsString(attributes["gen_ai.prompt.0.content"])`,
      `replace_pattern(attributes["gen_ai.prompt.0.content"], "(?s)-----BEGIN (?:PRIVATE KEY|RSA PRIVATE KEY|EC PRIVATE KEY|DSA PRIVATE KEY|ENCRYPTED PRIVATE KEY|OPENSSH PRIVATE KEY)-----.*?(?:-----END (?:PRIVATE KEY|RSA PRIVATE KEY|EC PRIVATE KEY|DSA PRIVATE KEY|ENCRYPTED PRIVATE KEY|OPENSSH PRIVATE KEY)-----|$)", "<redacted-private-key>") where IsString(attributes["gen_ai.prompt.0.content"])`,
      `replace_pattern(attributes["gen_ai.completion.0.content"], "(?i)(?:authorization|api[_-]?key|x[_-]?api[_-]?key|access[_-]?token|refresh[_-]?token|client[_-]?secret|password|session[ _-]?(?:id|token|secret|key|cookie)|vault[ _-]?(?:token|unseal[ _-]?(?:key|share|token)|recovery[ _-]?(?:key|share|token))|client[ _-]?assertion)[^A-Za-z0-9\\r\\n]{0,3}[:=][^A-Za-z0-9\\r\\n\\\"]{0,3}\\\"(?:\\\\.|[^\\\"\\\\\\r\\n])+(?:\\\\)?\\\"", "<redacted-credential>") where IsString(attributes["gen_ai.completion.0.content"])`,
      `replace_pattern(attributes["gen_ai.completion.0.content"], "(?i)(?:authorization|api[_-]?key|x[_-]?api[_-]?key|access[_-]?token|refresh[_-]?token|client[_-]?secret|password|session[ _-]?(?:id|token|secret|key|cookie)|vault[ _-]?(?:token|unseal[ _-]?(?:key|share|token)|recovery[ _-]?(?:key|share|token))|client[ _-]?assertion)[^A-Za-z0-9\\r\\n]{0,3}[:=][^A-Za-z0-9\\r\\n']{0,3}'(?:\\\\.|[^'\\\\\\r\\n])+(?:\\\\)?'", "<redacted-credential>") where IsString(attributes["gen_ai.completion.0.content"])`,
      `replace_pattern(attributes["gen_ai.completion.0.content"], "(?i)(?:authorization|api[_-]?key|x[_-]?api[_-]?key|access[_-]?token|refresh[_-]?token|client[_-]?secret|password|session[ _-]?(?:id|token|secret|key|cookie)|vault[ _-]?(?:token|unseal[ _-]?(?:key|share|token)|recovery[ _-]?(?:key|share|token))|client[ _-]?assertion)[\\\"']?[[:space:]]*[:=][[:space:]]*[\\\"']?(?:(?:bearer|basic)[[:space:]]+)?[^\\\"'[:space:],}]+", "<redacted-credential>") where IsString(attributes["gen_ai.completion.0.content"])`,
      `replace_pattern(attributes["gen_ai.completion.0.content"], "(?i)\\b(?:bearer|basic)[[:space:]]+[A-Za-z0-9._~+/-]{8,}", "<redacted-authorization>") where IsString(attributes["gen_ai.completion.0.content"])`,
      `replace_pattern(attributes["gen_ai.completion.0.content"], "\\bsk-(?:ant-)?[A-Za-z0-9_-]{16,}\\b", "<redacted-vendor-key>") where IsString(attributes["gen_ai.completion.0.content"])`,
      `replace_pattern(attributes["gen_ai.completion.0.content"], "\\beyJ[A-Za-z0-9_-]{5,}\\.[A-Za-z0-9_-]{8,}\\.[A-Za-z0-9_-]{8,}\\b", "<redacted-jwt>") where IsString(attributes["gen_ai.completion.0.content"])`,
      `replace_pattern(attributes["gen_ai.completion.0.content"], "\\b(?:hvs|hvb|hvr|s|b)\\.[A-Za-z0-9_-]{16,}\\b", "<redacted-vault-token>") where IsString(attributes["gen_ai.completion.0.content"])`,
      `replace_pattern(attributes["gen_ai.completion.0.content"], "(?s)-----BEGIN (?:PRIVATE KEY|RSA PRIVATE KEY|EC PRIVATE KEY|DSA PRIVATE KEY|ENCRYPTED PRIVATE KEY|OPENSSH PRIVATE KEY)-----.*?(?:-----END (?:PRIVATE KEY|RSA PRIVATE KEY|EC PRIVATE KEY|DSA PRIVATE KEY|ENCRYPTED PRIVATE KEY|OPENSSH PRIVATE KEY)-----|$)", "<redacted-private-key>") where IsString(attributes["gen_ai.completion.0.content"])`,
      // OTTL cannot recursively prove an array or map safe. Keep the reviewed
      // string form after the replacements above, and remove every other
      // representation before spanlogs can copy it into Loki or Cribl.
      `delete_matching_keys(attributes, "^gen_ai\\.input\\.messages$") where attributes["gen_ai.input.messages"] != nil and not IsString(attributes["gen_ai.input.messages"])`,
      `delete_matching_keys(attributes, "^gen_ai\\.output\\.messages$") where attributes["gen_ai.output.messages"] != nil and not IsString(attributes["gen_ai.output.messages"])`,
      `delete_matching_keys(attributes, "^gen_ai\\.prompt\\.0\\.content$") where attributes["gen_ai.prompt.0.content"] != nil and not IsString(attributes["gen_ai.prompt.0.content"])`,
      `delete_matching_keys(attributes, "^gen_ai\\.completion\\.0\\.content$") where attributes["gen_ai.completion.0.content"] != nil and not IsString(attributes["gen_ai.completion.0.content"])`,
      `delete_matching_keys(attributes, "^aigw\\.server\\.user\\.(?:id|name|name_source)$")`,
      `delete_key(attributes, "aigw.enduser.id")`,
      `delete_matching_keys(attributes, "(?i)^metadata\\.(?:headers?|request[_-]?headers?)$")`,
      `delete_matching_keys(attributes, "(?i)^(?:jwt|user[_-]?jwt|openwebui[_-]?user[_-]?jwt|x[_-]?openwebui[_-]?user[_-]?jwt|request[_-]?headers?)$")`,
      `delete_matching_keys(attributes, "(?i)^metadata\\.user_api_key_.*$")`,
      `delete_matching_keys(attributes, "(?i)^(?:(?:.*[._-])?(?:authorization|api[_-]?key|x[_-]?api[_-]?key|access[_-]?token|refresh[_-]?token|client[_-]?secret|password|headers?|hidden_params|proxy_server_request|requester_.*|session[._ -]?(?:id|token|secret|key|cookie)|vault[._ -]?(?:token|unseal[._ -]?(?:key|share|token)|recovery[._ -]?(?:key|share|token))|client[._ -]?assertion|id[._-]?token|jwt|token|private[._-]?key(?:[._-]?pem)?)|metadata\\.(?:requester_.*|spend_logs_metadata|prompt_management_metadata))$")`,
      `delete_matching_keys(attributes, "(?i)^http\\.request\\.header\\..*$")`,
      `delete_matching_keys(attributes, "(?i)^http\\.response\\.header\\.set[-_]?cookie$")`,
      `delete_matching_keys(attributes, "(?i)^(?:client|server|network\\.peer|net\\.peer)\\.(?:address|port|ip|name)$")`,
      `delete_matching_keys(attributes, "(?i)^(?:http\\.client_ip|url\\.query|http\\.target|requester_ip_address|(?:.*\\.)?(?:email|e_mail|e-mail))$")`,
    ]
  }

  trace_statements {
    context = "spanevent"
    statements = [
      `delete_matching_keys(attributes, "(?i)^metadata\\.user_api_key_.*$")`,
      `delete_matching_keys(attributes, "(?i)^(?:(?:.*[._-])?(?:authorization|api[_-]?key|x[_-]?api[_-]?key|access[_-]?token|refresh[_-]?token|client[_-]?secret|password|headers?|hidden_params|proxy_server_request|requester_.*|session[._ -]?(?:id|token|secret|key|cookie)|vault[._ -]?(?:token|unseal[._ -]?(?:key|share|token)|recovery[._ -]?(?:key|share|token))|client[._ -]?assertion|id[._-]?token|jwt|token|private[._-]?key(?:[._-]?pem)?)|metadata\\.(?:requester_.*|spend_logs_metadata|prompt_management_metadata))$")`,
      `delete_matching_keys(attributes, "(?i)^http\\.request\\.header\\..*$")`,
      `delete_matching_keys(attributes, "(?i)^http\\.response\\.header\\.set[-_]?cookie$")`,
      `delete_matching_keys(attributes, "(?i)^(?:client|server|network\\.peer|net\\.peer)\\.(?:address|port|ip|name)$")`,
      `delete_matching_keys(attributes, "(?i)^(?:http\\.client_ip|url\\.query|http\\.target|requester_ip_address|(?:.*\\.)?(?:email|e_mail|e-mail))$")`,
    ]
  }

  metric_statements {
    context = "resource"
    statements = [
      `delete_matching_keys(attributes, "(?i)^metadata\\.user_api_key_.*$")`,
      `delete_matching_keys(attributes, "(?i)^(?:(?:.*[._-])?(?:authorization|api[_-]?key|x[_-]?api[_-]?key|access[_-]?token|refresh[_-]?token|client[_-]?secret|password|headers?|hidden_params|proxy_server_request|requester_.*|session[._ -]?(?:id|token|secret|key|cookie)|vault[._ -]?(?:token|unseal[._ -]?(?:key|share|token)|recovery[._ -]?(?:key|share|token))|client[._ -]?assertion|id[._-]?token|jwt|token|private[._-]?key(?:[._-]?pem)?)|metadata\\.(?:requester_.*|spend_logs_metadata|prompt_management_metadata))$")`,
      `delete_matching_keys(attributes, "(?i)^http\\.request\\.header\\..*$")`,
      `delete_matching_keys(attributes, "(?i)^http\\.response\\.header\\.set[-_]?cookie$")`,
      `delete_matching_keys(attributes, "(?i)^(?:client|server|network\\.peer|net\\.peer)\\.(?:address|port|ip|name)$")`,
      `delete_matching_keys(attributes, "(?i)^(?:http\\.client_ip|url\\.query|http\\.target|requester_ip_address|(?:.*\\.)?(?:email|e_mail|e-mail))$")`,
    ]
  }

  metric_statements {
    context = "scope"
    statements = [
      `delete_matching_keys(attributes, "(?i)^metadata\\.user_api_key_.*$")`,
      `delete_matching_keys(attributes, "(?i)^(?:(?:.*[._-])?(?:authorization|api[_-]?key|x[_-]?api[_-]?key|access[_-]?token|refresh[_-]?token|client[_-]?secret|password|headers?|hidden_params|proxy_server_request|requester_.*|session[._ -]?(?:id|token|secret|key|cookie)|vault[._ -]?(?:token|unseal[._ -]?(?:key|share|token)|recovery[._ -]?(?:key|share|token))|client[._ -]?assertion|id[._-]?token|jwt|token|private[._-]?key(?:[._-]?pem)?)|metadata\\.(?:requester_.*|spend_logs_metadata|prompt_management_metadata))$")`,
      `delete_matching_keys(attributes, "(?i)^http\\.request\\.header\\..*$")`,
      `delete_matching_keys(attributes, "(?i)^http\\.response\\.header\\.set[-_]?cookie$")`,
      `delete_matching_keys(attributes, "(?i)^(?:client|server|network\\.peer|net\\.peer)\\.(?:address|port|ip|name)$")`,
      `delete_matching_keys(attributes, "(?i)^(?:http\\.client_ip|url\\.query|http\\.target|requester_ip_address|(?:.*\\.)?(?:email|e_mail|e-mail))$")`,
    ]
  }

  metric_statements {
    context = "datapoint"
    statements = [
      `delete_matching_keys(attributes, "(?i)^metadata\\.user_api_key_.*$")`,
      `delete_matching_keys(attributes, "(?i)^(?:(?:.*[._-])?(?:authorization|api[_-]?key|x[_-]?api[_-]?key|access[_-]?token|refresh[_-]?token|client[_-]?secret|password|headers?|hidden_params|proxy_server_request|requester_.*|session[._ -]?(?:id|token|secret|key|cookie)|vault[._ -]?(?:token|unseal[._ -]?(?:key|share|token)|recovery[._ -]?(?:key|share|token))|client[._ -]?assertion|id[._-]?token|jwt|token|private[._-]?key(?:[._-]?pem)?)|metadata\\.(?:requester_.*|spend_logs_metadata|prompt_management_metadata))$")`,
      `delete_matching_keys(attributes, "(?i)^http\\.request\\.header\\..*$")`,
      `delete_matching_keys(attributes, "(?i)^http\\.response\\.header\\.set[-_]?cookie$")`,
      `delete_matching_keys(attributes, "(?i)^(?:client|server|network\\.peer|net\\.peer)\\.(?:address|port|ip|name)$")`,
      `delete_matching_keys(attributes, "(?i)^(?:http\\.client_ip|url\\.query|http\\.target|requester_ip_address|(?:.*\\.)?(?:email|e_mail|e-mail))$")`,
    ]
  }

  log_statements {
    context = "resource"
    statements = [
      `delete_matching_keys(attributes, "(?i)^metadata\\.user_api_key_.*$")`,
      `delete_matching_keys(attributes, "(?i)^(?:(?:.*[._-])?(?:authorization|api[_-]?key|x[_-]?api[_-]?key|access[_-]?token|refresh[_-]?token|client[_-]?secret|password|headers?|hidden_params|proxy_server_request|requester_.*|session[._ -]?(?:id|token|secret|key|cookie)|vault[._ -]?(?:token|unseal[._ -]?(?:key|share|token)|recovery[._ -]?(?:key|share|token))|client[._ -]?assertion|id[._-]?token|jwt|token|private[._-]?key(?:[._-]?pem)?)|metadata\\.(?:requester_.*|spend_logs_metadata|prompt_management_metadata))$")`,
      `delete_matching_keys(attributes, "(?i)^http\\.request\\.header\\..*$")`,
      `delete_matching_keys(attributes, "(?i)^http\\.response\\.header\\.set[-_]?cookie$")`,
      `delete_matching_keys(attributes, "(?i)^(?:client|server|network\\.peer|net\\.peer)\\.(?:address|port|ip|name)$")`,
      `delete_matching_keys(attributes, "(?i)^(?:http\\.client_ip|url\\.query|http\\.target|requester_ip_address|(?:.*\\.)?(?:email|e_mail|e-mail))$")`,
    ]
  }

  log_statements {
    context = "scope"
    statements = [
      `delete_matching_keys(attributes, "(?i)^metadata\\.user_api_key_.*$")`,
      `delete_matching_keys(attributes, "(?i)^(?:(?:.*[._-])?(?:authorization|api[_-]?key|x[_-]?api[_-]?key|access[_-]?token|refresh[_-]?token|client[_-]?secret|password|headers?|hidden_params|proxy_server_request|requester_.*|session[._ -]?(?:id|token|secret|key|cookie)|vault[._ -]?(?:token|unseal[._ -]?(?:key|share|token)|recovery[._ -]?(?:key|share|token))|client[._ -]?assertion|id[._-]?token|jwt|token|private[._-]?key(?:[._-]?pem)?)|metadata\\.(?:requester_.*|spend_logs_metadata|prompt_management_metadata))$")`,
      `delete_matching_keys(attributes, "(?i)^http\\.request\\.header\\..*$")`,
      `delete_matching_keys(attributes, "(?i)^http\\.response\\.header\\.set[-_]?cookie$")`,
      `delete_matching_keys(attributes, "(?i)^(?:client|server|network\\.peer|net\\.peer)\\.(?:address|port|ip|name)$")`,
      `delete_matching_keys(attributes, "(?i)^(?:http\\.client_ip|url\\.query|http\\.target|requester_ip_address|(?:.*\\.)?(?:email|e_mail|e-mail))$")`,
    ]
  }

  log_statements {
    context = "log"
    statements = [
      `delete_matching_keys(attributes, "(?i)^metadata\\.user_api_key_.*$")`,
      `delete_matching_keys(attributes, "(?i)^(?:(?:.*[._-])?(?:authorization|api[_-]?key|x[_-]?api[_-]?key|access[_-]?token|refresh[_-]?token|client[_-]?secret|password|headers?|hidden_params|proxy_server_request|requester_.*|session[._ -]?(?:id|token|secret|key|cookie)|vault[._ -]?(?:token|unseal[._ -]?(?:key|share|token)|recovery[._ -]?(?:key|share|token))|client[._ -]?assertion|id[._-]?token|jwt|token|private[._-]?key(?:[._-]?pem)?)|metadata\\.(?:requester_.*|spend_logs_metadata|prompt_management_metadata))$")`,
      `delete_matching_keys(attributes, "(?i)^http\\.request\\.header\\..*$")`,
      `delete_matching_keys(attributes, "(?i)^http\\.response\\.header\\.set[-_]?cookie$")`,
      `delete_matching_keys(attributes, "(?i)^(?:client|server|network\\.peer|net\\.peer)\\.(?:address|port|ip|name)$")`,
      `delete_matching_keys(attributes, "(?i)^(?:http\\.client_ip|url\\.query|http\\.target|requester_ip_address|(?:.*\\.)?(?:email|e_mail|e-mail))$")`,
      `delete_matching_keys(body, "(?i)^(?:authorization|api[_-]?key|x[_-]?api[_-]?key|access[_-]?token|refresh[_-]?token|client[_-]?secret|password|headers?|hidden_params|proxy_server_request|requester_.*|metadata\\.user_api_key_.*)$") where IsMap(body)`,
      // Arbitrarily nested maps cannot be recursively proven safe in OTTL.
      // Preserve severity/timestamps/attributes, but fail closed on the body.
      `set(body, "<redacted-structured-log-body>") where IsMap(body)`,
      `replace_pattern(body, "(?i)(?:authorization|api[_-]?key|x[_-]?api[_-]?key|access[_-]?token|refresh[_-]?token|client[_-]?secret|password)[\\\"']?[[:space:]]*[:=][[:space:]]*[\\\"']?(?:(?:bearer|basic)[[:space:]]+)?[^\\\"'[:space:],}]+", "<redacted-credential>") where IsString(body)`,
      `replace_pattern(body, "(?i)\\b(?:bearer|basic)[[:space:]]+[A-Za-z0-9._~+/-]{8,}", "<redacted-authorization>") where IsString(body)`,
      `replace_pattern(body, "\\bsk-(?:ant-)?[A-Za-z0-9_-]{16,}\\b", "<redacted-vendor-key>") where IsString(body)`,
      `replace_pattern(body, "(?i)(?:session[ _-]?(?:id|token|secret|key|cookie)|vault[ _-]?(?:token|unseal[ _-]?(?:key|share|token)|recovery[ _-]?(?:key|share|token))|client[ _-]?assertion)[\\\"']?[[:space:]]*[:=][[:space:]]*[\\\"']?[^\\\"'[:space:],}]+", "<redacted-credential>") where IsString(body)`,
      `replace_pattern(body, "\\beyJ[A-Za-z0-9_-]{5,}\\.[A-Za-z0-9_-]{8,}\\.[A-Za-z0-9_-]{8,}\\b", "<redacted-jwt>") where IsString(body)`,
      `replace_pattern(body, "\\b(?:hvs|hvb|hvr|s|b)\\.[A-Za-z0-9_-]{16,}\\b", "<redacted-vault-token>") where IsString(body)`,
      `replace_pattern(body, "(?s)-----BEGIN (?:PRIVATE KEY|RSA PRIVATE KEY|EC PRIVATE KEY|DSA PRIVATE KEY|ENCRYPTED PRIVATE KEY|OPENSSH PRIVATE KEY)-----.*?(?:-----END (?:PRIVATE KEY|RSA PRIVATE KEY|EC PRIVATE KEY|DSA PRIVATE KEY|ENCRYPTED PRIVATE KEY|OPENSSH PRIVATE KEY)-----|$)", "<redacted-private-key>") where IsString(body)`,
    ]
  }

  output {
    traces  = [otelcol.processor.transform.aigw_signal_context.input]
    logs    = [otelcol.processor.transform.aigw_signal_context.input]
    metrics = [otelcol.processor.transform.aigw_signal_context.input]
  }
}
// END AIGW MANAGED SENSITIVE ATTRIBUTE FILTER

// The deployment label is server-owned on every signal. An OTLP peer may set
// a service identity, but it cannot make preprod data look like production or
// vice versa at either the local store or Cribl.
otelcol.processor.transform "aigw_signal_context" {
  error_mode = "propagate"
  trace_statements {
    context = "resource"
    statements = [
      `set(attributes["deployment.environment"], "` + sys.env("AIGW_DEPLOYMENT_ENVIRONMENT") + `")`,
      `delete_matching_keys(attributes, "^aigw\\.security\\.(?:event_class|producer|schema_version)$")`,
    ]
  }
  trace_statements {
    context = "scope"
    statements = [
      `delete_matching_keys(attributes, "^(?:deployment\\.environment|service\\.name|aigw\\.security\\.(?:event_class|producer|schema_version))$")`,
    ]
  }
  trace_statements {
    context = "span"
    statements = [
      `delete_matching_keys(attributes, "^(?:deployment\\.environment|service\\.name|aigw\\.security\\.(?:event_class|producer|schema_version))$")`,
    ]
  }
  trace_statements {
    context = "spanevent"
    statements = [
      `delete_matching_keys(attributes, "^(?:deployment\\.environment|service\\.name|aigw\\.security\\.(?:event_class|producer|schema_version))$")`,
    ]
  }
  metric_statements {
    context = "resource"
    statements = [
      `set(attributes["deployment.environment"], "` + sys.env("AIGW_DEPLOYMENT_ENVIRONMENT") + `")`,
      `delete_matching_keys(attributes, "^aigw\\.security\\.(?:event_class|producer|schema_version)$")`,
    ]
  }
  metric_statements {
    context = "scope"
    statements = [
      `delete_matching_keys(attributes, "^(?:deployment\\.environment|service\\.name|aigw\\.security\\.(?:event_class|producer|schema_version))$")`,
    ]
  }
  metric_statements {
    context = "datapoint"
    statements = [
      `delete_matching_keys(attributes, "^(?:deployment\\.environment|service\\.name|aigw\\.security\\.(?:event_class|producer|schema_version))$")`,
    ]
  }
  log_statements {
    context = "resource"
    statements = [
      `set(attributes["deployment.environment"], "` + sys.env("AIGW_DEPLOYMENT_ENVIRONMENT") + `")`,
      `delete_matching_keys(attributes, "^aigw\\.security\\.(?:event_class|producer|schema_version)$")`,
    ]
  }
  log_statements {
    context = "scope"
    statements = [
      `delete_matching_keys(attributes, "^(?:deployment\\.environment|service\\.name|aigw\\.security\\.(?:event_class|producer|schema_version))$")`,
    ]
  }
  log_statements {
    context = "log"
    statements = [
      `delete_matching_keys(attributes, "^(?:deployment\\.environment|service\\.name|aigw\\.security\\.(?:event_class|producer|schema_version))$")`,
    ]
  }
  output {
    traces  = [otelcol.processor.batch.default.input]
    logs    = [otelcol.processor.batch.default.input]
    metrics = [otelcol.processor.batch.default.input]
  }
}

otelcol.processor.batch "default" {
  timeout             = "1s"
  send_batch_size     = 512
  send_batch_max_size = 1024
  output {
    traces = [
      otelcol.connector.spanmetrics.default.input,
      otelcol.processor.filter.aigw_request_spans.input,
      otelcol.processor.batch.cribl_traces.input,
    ]
    logs = [
      otelcol.exporter.loki.local.input,
      otelcol.processor.batch.cribl_logs.input,
    ]
    metrics = [
      otelcol.exporter.prometheus.local.input,
      otelcol.processor.batch.cribl_metrics.input,
    ]
  }
}

// LiteLLM's Prometheus endpoint is enterprise-gated. Derive bounded
// request-rate/latency/error metrics from spans. Key aliases are deliberately
// NOT dimensions: users choose them and can mint arbitrarily many keys, which
// otherwise creates an unbounded Prometheus series-cardinality DoS.
otelcol.connector.spanmetrics "default" {
  histogram { explicit {} }
  dimension { name = "gen_ai.request.model" }
  output {
    metrics = [
      otelcol.exporter.prometheus.local.input,
      otelcol.processor.batch.cribl_metrics.input,
    ]
  }
}

// Per-request audit stream (owner decision): one Loki log line per
// litellm_request span so Grafana Logs Drilldown can filter AI requests by
// user/key/project and show the approved prompt/completion content. The
// sensitive-attribute sanitizer above has already removed every credential
// and raw-identity source before this branch; prompt bodies are deliberately
// retained here, in this stream only. Sibling spans (raw_gen_ai_request,
// Received Proxy Server Request), a look-alike span from another service, and
// every malformed record cannot become a normalized request-audit log. Their
// already-sanitized source traces still follow the general Cribl trace path.
otelcol.processor.filter "aigw_request_spans" {
  error_mode = "propagate"
  traces {
    span = [
      `attributes["aigw.security.source_authenticated"] != "litellm_bearer_v1"`,
      `resource.attributes["service.name"] != "litellm" or name != "litellm_request"`,
      `not IsString(attributes["aigw.user.id"]) or not IsMatch(attributes["aigw.user.id"], "^[A-Za-z0-9][A-Za-z0-9_.:@-]{0,127}$")`,
      `not IsString(attributes["aigw.user.name"]) or not IsMatch(attributes["aigw.user.name"], "^[A-Za-z0-9][A-Za-z0-9_.:@-]{0,127}$")`,
      `not IsString(attributes["aigw.user.name_source"]) or (attributes["aigw.user.name_source"] != "portal_key_metadata" and attributes["aigw.user.name_source"] != "open_webui_signed_oidc" and attributes["aigw.user.name_source"] != "key_subject")`,
      `not IsString(attributes["aigw.api_key.id"]) or not IsMatch(attributes["aigw.api_key.id"], "^[0-9a-f]{64}$")`,
      `not IsString(attributes["aigw.project.id"]) or not IsMatch(attributes["aigw.project.id"], "^[a-z0-9][a-z0-9_.-]{0,63}$")`,
      `not IsString(attributes["aigw.request.id"]) or not IsMatch(attributes["aigw.request.id"], "^[A-Za-z0-9][A-Za-z0-9_.:-]{0,127}$")`,
    ]
  }
  output {
    traces = [otelcol.processor.transform.aigw_request_event_time.input]
  }
}

// spanlogs does not copy an input span's timestamp into its OTLP LogRecord in
// the pinned Alloy release. Carry the reviewed source time as one internal
// attribute, then restore it to the real log timestamp immediately afterward.
// The final common-record gate validates the resulting UTC epoch value.
otelcol.processor.transform "aigw_request_event_time" {
  error_mode = "propagate"
  trace_statements {
    context = "span"
    statements = [
      `set(attributes["aigw.security.source_time_unix_nano"], start_time_unix_nano)`,
    ]
  }
  output {
    traces = [otelcol.connector.spanlogs.aigw_requests.input]
  }
}

// One log line per surviving span, carrying only the explicit allow-listed
// span attributes. The body is logfmt-style key=value text, so LogQL's
// `| logfmt` yields aigw_user_id / gen_ai_* fields for dashboards.
//
// `labels` re-emits the listed keys as log ATTRIBUTES so the downstream
// loki.attribute.labels hint can promote them to Loki stream labels, giving
// Logs Drilldown label tabs and dashboard dropdowns. Cardinality is a
// deliberate, bounded decision: the user and project populations are small
// (dozens) and this is a single dedicated stream; aigw.user.name is
// regex-validated at promotion and the writer's max_streams=1000 is the
// hard backstop. aigw.request.id and aigw.api_key.id are unbounded/high-
// churn and MUST stay line fields, never labels.
otelcol.connector.spanlogs "aigw_requests" {
  spans  = true
  labels = [
    "aigw.user.name",
    // Preserve the reviewed identity source as an OTLP log attribute for the
    // SOC feed. It is not included in loki.attribute.labels below, so it does
    // not change Loki stream cardinality.
    "aigw.user.name_source",
    "aigw.project.id",
    // spanlogs copies a label only when the same key is in span_attributes.
    // Carry the timestamp in both lists, restore it, then scrub the temporary
    // body field before this record can leave Alloy.
    "aigw.security.source_time_unix_nano",
  ]
  span_attributes = [
    "aigw.security.source_time_unix_nano",
    "aigw.user.id",
    "aigw.user.name",
    "aigw.user.name_source",
    "aigw.api_key.id",
    "aigw.project.id",
    "aigw.request.id",
    "gen_ai.request.model",
    "gen_ai.response.model",
    "litellm.model_group",
    "gen_ai.usage.input_tokens",
    "gen_ai.usage.output_tokens",
    "gen_ai.usage.total_tokens",
    "gen_ai.cost.total_cost",
    "gen_ai.response.finish_reasons",
    "llm.is_streaming",
    "http.route",
    "litellm.call_id",
    "gen_ai.input.messages",
    "gen_ai.output.messages",
    "gen_ai.prompt.0.content",
    "gen_ai.completion.0.content",
  ]
  output {
    logs = [otelcol.processor.transform.aigw_request_stream.input]
  }
}

// Stable stream identity: Grafana's Logs Drilldown keys its whole UI on the
// OTel-semantic service_name label, so pin the resource service.name to the
// dedicated stream value before label promotion.
otelcol.processor.transform "aigw_request_stream" {
  // These static fields are part of the reviewed external event contract.
  // Drop the record if they cannot be applied; never export an unclassified
  // request log after a transform failure.
  error_mode = "propagate"
  log_statements {
    context = "resource"
    statements = [
      `set(attributes["service.name"], "aigw-requests")`,
    ]
  }
  log_statements {
    context = "log"
    statements = [
      `set(time_unix_nano, attributes["aigw.security.source_time_unix_nano"])`,
      `replace_pattern(body, "^(span=litellm_request dur=[0-9]+ns(?: status=[^[:space:]]+)?) aigw\\.security\\.source_time_unix_nano=[0-9]+", "$1") where IsString(body)`,
      `delete_key(attributes, "aigw.security.source_time_unix_nano")`,
      `set(attributes["aigw.security.event_class"], "ai_request_audit")`,
      `set(attributes["aigw.security.schema_version"], 1)`,
      `set(attributes["aigw.security.source"], "litellm_request")`,
    ]
  }
  output {
    logs = [otelcol.processor.attributes.aigw_request_stream_labels.input]
  }
}

// otelcol.exporter.loki promotes OTLP attributes into Loki labels only via
// the documented hint attributes; loki.resource.labels turns the resource
// service.name into the service_name stream label, and loki.attribute.labels
// promotes the spanlogs-emitted attribution attributes into the bounded
// aigw_user_name / aigw_project_id stream labels (Prometheus-format names).
otelcol.processor.attributes "aigw_request_stream_labels" {
  action {
    key    = "loki.resource.labels"
    action = "insert"
    value  = "service.name"
  }
  action {
    key    = "loki.attribute.labels"
    action = "insert"
    value  = "aigw.user.name, aigw.project.id"
  }
  output {
    logs = [
      otelcol.exporter.loki.local.input,
      otelcol.processor.transform.cribl_security_contract.input,
    ]
  }
}

// Every approved external log receives the same server-owned common fields,
// regardless of whether it began as a request spanlog or a classified Docker
// record. Clear ambiguous caller fields first, then assign one literal producer
// and service identity from the reviewed event class. The structured-security
// path may use only the five service names its earlier classifier admitted.
// A transform failure propagates and therefore cannot bypass this boundary.
otelcol.processor.transform "cribl_security_contract" {
  error_mode = "propagate"
  log_statements {
    context = "log"
    statements = [
      `set(attributes["aigw.security.event_class"], attributes["aigw_security_event_class"]) where attributes["aigw.security.event_class"] == nil and IsString(attributes["aigw_security_event_class"])`,
      `delete_matching_keys(attributes, "^(?:deployment\\.environment|service\\.name|aigw\\.security\\.producer|aigw_security_event_class)$")`,
      `set(attributes["aigw.security.schema_version"], 1)`,
      `set(attributes["aigw.security.producer"], "")`,
      `set(resource.attributes["service.name"], "")`,
      `set(resource.attributes["deployment.environment"], "` + sys.env("AIGW_DEPLOYMENT_ENVIRONMENT") + `")`,
      `set(attributes["aigw.security.producer"], "litellm") where attributes["aigw.security.event_class"] == "ai_request_audit"`,
      `set(resource.attributes["service.name"], "litellm") where attributes["aigw.security.event_class"] == "ai_request_audit"`,
      `set(attributes["aigw.security.producer"], "keycloak") where attributes["aigw.security.event_class"] == "keycloak_event"`,
      `set(resource.attributes["service.name"], "keycloak") where attributes["aigw.security.event_class"] == "keycloak_event"`,
      `set(attributes["aigw.security.producer"], "envoy-egress") where attributes["aigw.security.event_class"] == "egress_tls"`,
      `set(resource.attributes["service.name"], "envoy-egress") where attributes["aigw.security.event_class"] == "egress_tls"`,
      `set(attributes["aigw.security.producer"], "vault") where attributes["aigw.security.event_class"] == "vault_audit"`,
      `set(resource.attributes["service.name"], "vault") where attributes["aigw.security.event_class"] == "vault_audit"`,
      `set(attributes["aigw.security.producer"], "dev-portal") where attributes["aigw.security.event_class"] == "security_event" and attributes["service"] == "dev-portal"`,
      `set(resource.attributes["service.name"], "dev-portal") where attributes["aigw.security.event_class"] == "security_event" and attributes["service"] == "dev-portal"`,
      `set(attributes["aigw.security.producer"], "admin-portal") where attributes["aigw.security.event_class"] == "security_event" and attributes["service"] == "admin-portal"`,
      `set(resource.attributes["service.name"], "admin-portal") where attributes["aigw.security.event_class"] == "security_event" and attributes["service"] == "admin-portal"`,
      `set(attributes["aigw.security.producer"], "key-rotator") where attributes["aigw.security.event_class"] == "security_event" and attributes["service"] == "key-rotator"`,
      `set(resource.attributes["service.name"], "key-rotator") where attributes["aigw.security.event_class"] == "security_event" and attributes["service"] == "key-rotator"`,
      `set(attributes["aigw.security.producer"], "envoy-egress") where attributes["aigw.security.event_class"] == "security_event" and attributes["service"] == "envoy-egress"`,
      `set(resource.attributes["service.name"], "envoy-egress") where attributes["aigw.security.event_class"] == "security_event" and attributes["service"] == "envoy-egress"`,
      `set(attributes["aigw.security.producer"], "litellm") where attributes["aigw.security.event_class"] == "security_event" and attributes["service"] == "litellm"`,
      `set(resource.attributes["service.name"], "litellm") where attributes["aigw.security.event_class"] == "security_event" and attributes["service"] == "litellm"`,
      `set(attributes["aigw.security.producer"], "controller") where attributes["aigw.security.event_class"] == "controller_lifecycle"`,
      `set(resource.attributes["service.name"], "controller") where attributes["aigw.security.event_class"] == "controller_lifecycle"`,
    ]
  }
  output {
    logs = [otelcol.processor.filter.cribl_common_record.input]
  }
}

// Event time is the original OTLP/Docker/Vault UTC timestamp. Admit at most
// the approved 24-hour delivery window at queue ingress and one minute of
// forward clock skew. This keeps a host reboot or collector restart from
// discarding unread records; queue delay happens after this gate. Zero, stale,
// future, or unclassified records are removed before the Cribl log batch.
// error_mode=propagate makes an evaluation error fail closed too.
otelcol.processor.filter "cribl_common_record" {
  error_mode = "propagate"
  logs {
    log_record = [
      `attributes["aigw.security.schema_version"] != 1`,
      `resource.attributes["deployment.environment"] != "preprod" and resource.attributes["deployment.environment"] != "production"`,
      `not IsString(attributes["aigw.security.producer"]) or attributes["aigw.security.producer"] == ""`,
      `not IsString(resource.attributes["service.name"]) or resource.attributes["service.name"] != attributes["aigw.security.producer"]`,
      `attributes["aigw.security.event_class"] == "ai_request_audit" and attributes["aigw.security.producer"] != "litellm"`,
      `attributes["aigw.security.event_class"] == "keycloak_event" and attributes["aigw.security.producer"] != "keycloak"`,
      `attributes["aigw.security.event_class"] == "egress_tls" and attributes["aigw.security.producer"] != "envoy-egress"`,
      `attributes["aigw.security.event_class"] == "vault_audit" and attributes["aigw.security.producer"] != "vault"`,
      `attributes["aigw.security.event_class"] == "security_event" and attributes["aigw.security.producer"] != "dev-portal" and attributes["aigw.security.producer"] != "admin-portal" and attributes["aigw.security.producer"] != "key-rotator" and attributes["aigw.security.producer"] != "envoy-egress" and attributes["aigw.security.producer"] != "litellm"`,
      `attributes["aigw.security.event_class"] == "controller_lifecycle" and attributes["aigw.security.producer"] != "controller"`,
      `attributes["aigw.security.event_class"] != "ai_request_audit" and attributes["aigw.security.event_class"] != "keycloak_event" and attributes["aigw.security.event_class"] != "egress_tls" and attributes["aigw.security.event_class"] != "vault_audit" and attributes["aigw.security.event_class"] != "security_event" and attributes["aigw.security.event_class"] != "controller_lifecycle"`,
      `time_unix_nano == 0`,
      `time_unix_nano < UnixNano(Now()) - 86400000000000`,
      `time_unix_nano > UnixNano(Now()) + 60000000000`,
    ]
  }
  output {
    logs = [otelcol.processor.batch.cribl_logs.input]
  }
}

// Keep the three signal batches independent before the shared durable queue.
// A burst of metrics must not prevent a ready log or trace batch from flushing.
// The exporter remains non-blocking, so a Cribl outage cannot stop inference.
otelcol.processor.batch "cribl_logs" {
  timeout             = "1s"
  send_batch_size     = 512
  send_batch_max_size = 1024
  output {
    logs = [otelcol.exporter.otlp.cribl.input]
  }
}

otelcol.processor.batch "cribl_metrics" {
  timeout             = "1s"
  send_batch_size     = 512
  send_batch_max_size = 1024
  output {
    metrics = [otelcol.exporter.otlp.cribl.input]
  }
}

otelcol.processor.batch "cribl_traces" {
  timeout             = "1s"
  send_batch_size     = 512
  send_batch_max_size = 1024
  output {
    traces = [otelcol.exporter.otlp.cribl.input]
  }
}

otelcol.exporter.prometheus "local" {
  forward_to = [prometheus.remote_write.local.receiver]
}

prometheus.remote_write "local" {
  endpoint { url = "http://prometheus:9090/api/v1/write" }
}

// Prometheus is the sole alert evaluator. It returns only its two generated
// alert-state series over a dedicated mTLS listener on net-observability.
// This branch goes to Cribl only. It must never feed the local Prometheus
// writer, or one alert sample could create a telemetry loop.
prometheus.receive_http "alert_state" {
  http {
    listen_address       = sys.env("ALLOY_OBSERVABILITY_IP")
    listen_port          = 12346
    server_read_timeout  = "10s"
    server_write_timeout = "10s"
    tls {
      cert_file        = "/run/secrets/alert_state_alloy.crt"
      key_file         = "/run/secrets/alert_state_alloy.key"
      client_auth_type = "RequireAndVerifyClientCert"
      client_ca_file   = "/run/secrets/alert_state_ca.pem"
      min_version      = "VersionTLS13"
    }
  }
  forward_to = [prometheus.relabel.alert_state.receiver]
}

prometheus.relabel "alert_state" {
  max_cache_size = 128
  forward_to     = [otelcol.receiver.prometheus.alert_state.receiver]

  rule {
    source_labels = ["__name__"]
    regex         = "ALERTS|ALERTS_FOR_STATE"
    action        = "keep"
  }
  rule {
    source_labels = ["alertname"]
    regex         = "AIGatewayWatchdog|AIGatewayScrapeTargetDown|AIGatewayAlertmanagerUnavailable|AIGatewayAlertmanagerDeliveryFailures|AIGatewayAlloyExporterSendFailures|AIGatewayAlloyExporterEnqueueFailures|AIGatewayAlloyExporterQueueSaturation|AIGatewayLokiWriteDrops|AIGatewayLokiWriteRetriesHigh|AIGatewayPrometheusRemoteWriteFailures|AIGatewayPrometheusRemoteWriteBacklog|AIGatewayHostCPUHigh|AIGatewayHostCPUCritical|AIGatewayHostLoadHigh|AIGatewayHostLoadCritical|AIGatewayHostMemoryLow|AIGatewayHostMemoryCritical|AIGatewayHostSwapHigh|AIGatewayHostOOMKill|AIGatewayFilesystemSpaceLow|AIGatewayFilesystemSpaceCritical|AIGatewayFilesystemPredictedFull|AIGatewayFilesystemInodesLow|AIGatewayFilesystemInodesCritical|AIGatewayHostDiskLatencyHigh|AIGatewayHostDiskIOSaturation|AIGatewayHostFileDescriptorsHigh|AIGatewayHostFileDescriptorsCritical|AIGatewayServiceLatencyHigh|AIGatewayServiceLatencyCritical|AIGatewayServiceErrorRateHigh|AIGatewayServiceErrorRateCritical|AIGatewayCertificateExpiresSoon|AIGatewayCertificateExpiryCritical"
    action        = "keep"
  }
  rule {
    regex  = "__name__|alertname|alertstate|severity|owner|alert_class|instance|job|device|mountpoint|service|component_id|remote_name"
    action = "labelkeep"
  }
  rule {
    target_label = "deployment_environment"
    replacement  = sys.env("AIGW_DEPLOYMENT_ENVIRONMENT")
    action       = "replace"
  }
  rule {
    target_label = "aigw_signal"
    replacement  = "alert-state"
    action       = "replace"
  }
}

otelcol.receiver.prometheus "alert_state" {
  output {
    metrics = [otelcol.processor.memory_limiter.alert_state.input]
  }
}

otelcol.processor.memory_limiter "alert_state" {
  check_interval = "1s"
  // Memory limiters observe the whole Alloy process, not one branch. Keep
  // this narrow branch at the same bounded thresholds as the main pipeline.
  limit          = "384MiB"
  spike_limit    = "64MiB"
  output {
    metrics = [otelcol.processor.batch.cribl_metrics.input]
  }
}

// Alloy owns the only scrape graph. Prometheus receives the resulting samples
// over its private remote-write endpoint and evaluates the committed rules.
// This makes Alloy the one local and Cribl fan-out point for every metric.
prometheus.scrape "gateway" {
  scrape_interval = "15s"
  targets = [
    { "__address__" = "traefik-int:9100", "job" = "traefik" },
    { "__address__" = "traefik-adm:9100", "job" = "traefik" },
    { "__address__" = "envoy-egress:9902", "__metrics_path__" = "/stats/prometheus", "job" = "envoy-egress" },
    { "__address__" = "keycloak:9000", "__metrics_path__" = "/metrics", "job" = "keycloak" },
    { "__address__" = sys.env("ALLOY_OBSERVABILITY_IP") + ":12345", "job" = "alloy" },
    { "__address__" = "grafana:3000", "job" = "grafana" },
    { "__address__" = "prometheus-observability:9090", "job" = "prometheus" },
    { "__address__" = "alertmanager:9093", "job" = "alertmanager" },
    { "__address__" = "loki:3100", "job" = "loki" },
    { "__address__" = "node-exporter:9100", "job" = "node-exporter" },
    // BEGIN AIGW PREPROD ALERT FIXTURE
    // END AIGW PREPROD ALERT FIXTURE
  ]
  forward_to = [otelcol.receiver.prometheus.gateway.receiver]
}

otelcol.receiver.prometheus "gateway" {
  output {
    metrics = [otelcol.processor.memory_limiter.default.input]
  }
}

otelcol.exporter.loki "local" {
  forward_to = [loki.write.local.receiver]
}

loki.write "local" {
  max_streams = 1000
  endpoint {
    url              = "http://loki:3100/loki/api/v1/push"
    batch_size       = "1MiB"
    batch_wait       = "1s"
    follow_redirects = false
    remote_timeout   = "10s"
  }
}

// Persistent exporter queue survives Alloy restarts and endpoint outages.
// queue_size remains byte-bounded at the exporter; fsync trades a small
// amount of throughput for a durable telemetry backlog. Alloy has no
// per-record queue TTL. The 24-hour retry limit is the strongest supported
// time bound; the byte cap may shorten it during a high-volume outage.
otelcol.storage.file "cribl_queue" {
  directory             = "/var/lib/alloy/queues/cribl"
  directory_permissions = "0700"
  fsync                  = true
  timeout                = "5s"

  compaction {
    cleanup_on_start              = true
    on_start                      = true
    on_rebound                    = true
    rebound_needed_threshold_mib  = 2048
    rebound_trigger_threshold_mib = 512
  }
}

// Customer Cribl (or the cribl-mock stand-in). This is the only outbound
// telemetry exporter. It carries admitted logs, metrics, and traces over
// native OTLP/gRPC. The queue is byte-bounded so one endpoint outage cannot
// consume all collector memory. Plaintext remains an explicit test-only switch
// enforced by Ansible.
otelcol.exporter.otlp "cribl" {
  client {
    endpoint = sys.env("CRIBL_OTLP_ENDPOINT")
    // Pure Compose is a development profile pointed only at cribl-mock.
    // Ansible replaces this entire marked block with either this plaintext
    // form or a verified customer TLS form. Do not mix TLS-only arguments
    // into the insecure block: Alloy 1.18.0 then attempts a TLS handshake.
    // BEGIN AIGW MANAGED CRIBL TLS
    tls {
      insecure = true
    }
    // END AIGW MANAGED CRIBL TLS
  }
  sending_queue {
    enabled           = true
    num_consumers     = 2
    // Owner decision: the on-disk queue is the Cribl-outage buffer and must
    // hold at most the intended 24-hour delivery window. The 2 GiB cap is a
    // safety limit, not proof that every workload gets exactly 24 hours.
    queue_size        = 2147483648
    sizer             = "bytes"
    block_on_overflow = false
    storage           = otelcol.storage.file.cribl_queue.handler
  }
  retry_on_failure {
    enabled          = true
    initial_interval = "1s"
    max_interval     = "30s"
    max_elapsed_time = "24h"
  }
}

// Docker json-file logs. Compose configures the project/service labels as
// json-file attributes, so querying never needs a high-cardinality filename or
// container-id label. Positions persist under Alloy's --storage.path volume.
loki.source.file "docker" {
  targets = [{
    __path__ = "/var/lib/docker/containers/*/*-json.log",
    job      = "docker",
  }]
  forward_to = [loki.process.docker.receiver]
  file_match {
    enabled     = true
    sync_period = "10s"
  }
}

loki.process "docker" {
  stage.json {
    expressions = {
      message   = "log",
      stream    = "stream",
      timestamp = "time",
      project   = "attrs.\"com.docker.compose.project\"",
      service   = "attrs.\"com.docker.compose.service\"",
    }
  }
  stage.timestamp {
    source = "timestamp"
    format = "RFC3339Nano"
  }
  stage.labels {
    values = {
      project = "",
      service = "",
      stream  = "",
      // Grafana's Logs Drilldown app keys its whole UI on the OTel-semantic
      // service_name label; without it every stream is invisible there.
      service_name = "service",
    }
  }
  stage.output { source = "message" }
  // Full prompts live in traces by explicit policy. Ordinary service logs are
  // a different data class: redact credential-shaped fields and vendor keys if
  // a dependency ever prints them during an error path.
  stage.replace {
    // Alloy replaces the CAPTURED text, not the full regular-expression
    // match. Capture only the credential so the field name remains useful.
    expression = `(?i)"?(?:api[_-]?key|client[_-]?secret|password|access[_-]?token|refresh[_-]?token|authorization)"?\s*[:=]\s*["']?(?:(?:bearer|basic)\s+)?([^"'\s,}]{8,})`
    replace    = `<redacted>`
  }
  stage.replace {
    expression = `(?i)\b(?:bearer|basic)\s+([A-Za-z0-9._~+/-]{8,})`
    replace    = `<redacted-authorization>`
  }
  stage.replace {
    expression = `(\bsk-(?:ant-)?[A-Za-z0-9_-]{16,}\b)`
    replace    = `<redacted-vendor-key>`
  }
  stage.replace {
    expression = `(?i)"?(?:session[ _-]?(?:id|token|secret|key|cookie)|vault[ _-]?(?:token|unseal[ _-]?(?:key|share|token)|recovery[ _-]?(?:key|share|token))|client[ _-]?assertion)"?\s*[:=]\s*["']?([^"'\s,}]{8,})`
    replace    = `<redacted-credential>`
  }
  stage.replace {
    expression = `(\beyJ[A-Za-z0-9_-]{5,}\.[A-Za-z0-9_-]{8,}\.[A-Za-z0-9_-]{8,}\b)`
    replace    = `<redacted-jwt>`
  }
  stage.replace {
    expression = `(\b(?:hvs|hvb|hvr|s|b)\.[A-Za-z0-9_-]{16,}\b)`
    replace    = `<redacted-vault-token>`
  }
  stage.replace {
    expression = `(?s)(-----BEGIN (?:PRIVATE KEY|RSA PRIVATE KEY|EC PRIVATE KEY|DSA PRIVATE KEY|ENCRYPTED PRIVATE KEY|OPENSSH PRIVATE KEY)-----.*?(?:-----END (?:PRIVATE KEY|RSA PRIVATE KEY|EC PRIVATE KEY|DSA PRIVATE KEY|ENCRYPTED PRIVATE KEY|OPENSSH PRIVATE KEY)-----|$))`
    replace    = `<redacted-private-key>`
  }
  stage.label_drop { values = ["filename"] }
  forward_to = [
    loki.write.local.receiver,
    loki.process.cribl_admitted_docker.receiver,
    loki.process.cribl_keycloak_auth.receiver,
    loki.process.cribl_envoy_tls.receiver,
    loki.process.cribl_structured_security.receiver,
  ]
}

// Mirror ordinary Docker logs after the shared source-side redaction above.
// Security producers often include extra fields that must not leave the host.
// Their raw records are excluded here and their reviewed projections follow
// the existing structured branches below instead. Raw Vault audit records use
// a separate file source and likewise never enter this generic branch.
loki.process "cribl_admitted_docker" {
  stage.regex {
    expression = `(?P<aigw_normalized_security_source>AIGW_SECURITY_EVENT|"log\.logger":"org\.keycloak\.events"|"upstream_transport_failure_reason":)`
  }
  stage.labels {
    values = {
      aigw_normalized_security_source = "",
    }
  }
  stage.match {
    selector            = "{aigw_normalized_security_source!=\"\"}"
    action              = "drop"
    drop_counter_reason = "raw_security_record_requires_projection"
  }
  stage.label_drop { values = ["aigw_normalized_security_source"] }
  forward_to = [otelcol.receiver.loki.cribl_admitted_logs.receiver]
}

// Loki stages already removed credential-shaped values from the message. The
// OTLP bridge repeats the fail-closed sanitizer for defense in depth, stamps
// the server-owned environment, and sends only to the external log batch.
otelcol.receiver.loki "cribl_admitted_logs" {
  output {
    logs = [otelcol.processor.transform.cribl_admitted_logs.input]
  }
}

otelcol.processor.transform "cribl_admitted_logs" {
  error_mode = "propagate"
  log_statements {
    context = "log"
    statements = [
      `set(resource.attributes["deployment.environment"], "` + sys.env("AIGW_DEPLOYMENT_ENVIRONMENT") + `")`,
      `set(resource.attributes["service.name"], attributes["service"]) where IsString(attributes["service"])`,
      `delete_matching_keys(attributes, "(?i)^metadata\\.user_api_key_.*$")`,
      `delete_matching_keys(attributes, "(?i)^(?:authorization|api[_-]?key|x[_-]?api[_-]?key|access[_-]?token|refresh[_-]?token|client[_-]?secret|password|headers?|hidden_params|proxy_server_request|requester_.*)$")`,
      `replace_pattern(body, "(?i)(?:authorization|api[_-]?key|x[_-]?api[_-]?key|access[_-]?token|refresh[_-]?token|client[_-]?secret|password|session[ _-]?(?:id|token|secret|key|cookie)|vault[ _-]?(?:token|unseal[ _-]?(?:key|share|token)|recovery[ _-]?(?:key|share|token))|client[ _-]?assertion)[\\\"']?[[:space:]]*[:=][[:space:]]*[\\\"']?(?:(?:bearer|basic)[[:space:]]+)?[^\\\"'[:space:],}]+", "<redacted-credential>") where IsString(body)`,
      `replace_pattern(body, "(?i)\\b(?:bearer|basic)[[:space:]]+[A-Za-z0-9._~+/-]{8,}", "<redacted-authorization>") where IsString(body)`,
      `replace_pattern(body, "\\bsk-(?:ant-)?[A-Za-z0-9_-]{16,}\\b", "<redacted-vendor-key>") where IsString(body)`,
      `replace_pattern(body, "\\beyJ[A-Za-z0-9_-]{5,}\\.[A-Za-z0-9_-]{8,}\\.[A-Za-z0-9_-]{8,}\\b", "<redacted-jwt>") where IsString(body)`,
      `replace_pattern(body, "\\b(?:hvs|hvb|hvr|s|b)\\.[A-Za-z0-9_-]{16,}\\b", "<redacted-vault-token>") where IsString(body)`,
      `replace_pattern(body, "(?s)-----BEGIN (?:PRIVATE KEY|RSA PRIVATE KEY|EC PRIVATE KEY|DSA PRIVATE KEY|ENCRYPTED PRIVATE KEY|OPENSSH PRIVATE KEY)-----.*?(?:-----END (?:PRIVATE KEY|RSA PRIVATE KEY|EC PRIVATE KEY|DSA PRIVATE KEY|ENCRYPTED PRIVATE KEY|OPENSSH PRIVATE KEY)-----|$)", "<redacted-private-key>") where IsString(body)`,
    ]
  }
  output {
    logs = [otelcol.processor.batch.cribl_logs.input]
  }
}

// Keycloak authentication events are emitted by its reviewed jboss-logging
// event listener in JSON console logs. The project, service, logger, and event
// type must all match exactly. Missing or malformed fields are dropped.
loki.process "cribl_keycloak_auth" {
  stage.match {
    selector            = "{project!~\"ai-gateway|aigw-preprod\"}"
    action              = "drop"
    drop_counter_reason = "unapproved_project"
  }
  stage.match {
    selector            = "{service!=\"keycloak\"}"
    action              = "drop"
    drop_counter_reason = "unapproved_security_service"
  }
  stage.json {
    expressions = {
      keycloak_logger  = "\"log.logger\"",
      keycloak_message = "message",
    }
  }
  stage.labels {
    values = {
      keycloak_logger = "",
    }
  }
  stage.match {
    selector            = "{keycloak_logger!=\"org.keycloak.events\"}"
    action              = "drop"
    drop_counter_reason = "unapproved_keycloak_logger"
  }
  stage.regex {
    source     = "keycloak_message"
    expression = `^type="(?P<keycloak_event>CLIENT_LOGIN|CLIENT_LOGIN_ERROR|CODE_TO_TOKEN|CODE_TO_TOKEN_ERROR|IDENTITY_PROVIDER_FIRST_LOGIN|IDENTITY_PROVIDER_FIRST_LOGIN_ERROR|IDENTITY_PROVIDER_LOGIN|IDENTITY_PROVIDER_LOGIN_ERROR|IDENTITY_PROVIDER_POST_LOGIN|IDENTITY_PROVIDER_POST_LOGIN_ERROR|IMPERSONATE|IMPERSONATE_ERROR|LOGIN|LOGIN_ERROR|LOGOUT|LOGOUT_ERROR|REFRESH_TOKEN|REFRESH_TOKEN_ERROR|USER_DISABLED_BY_PERMANENT_LOCKOUT|USER_DISABLED_BY_PERMANENT_LOCKOUT_ERROR|USER_DISABLED_BY_TEMPORARY_LOCKOUT|USER_DISABLED_BY_TEMPORARY_LOCKOUT_ERROR)"(?:,|$)`
  }
  stage.regex {
    source     = "keycloak_message"
    expression = `(?:^|, )realmId="(?P<keycloak_realm_id>[A-Za-z0-9_.:@-]{1,128})"(?:,|$)`
  }
  stage.regex {
    source     = "keycloak_message"
    expression = `(?:^|, )clientId="(?P<keycloak_client_id>[A-Za-z0-9_.:@/-]{1,128})"(?:,|$)`
  }
  stage.regex {
    source     = "keycloak_message"
    expression = `(?:^|, )userId="(?P<keycloak_user_id>[A-Za-z0-9_.:@-]{1,128})"(?:,|$)`
  }
  stage.labels {
    values = {
      keycloak_event            = "",
      keycloak_client_id        = "",
      keycloak_realm_id         = "",
      keycloak_user_id          = "",
    }
  }
  stage.static_labels {
    values = {
      aigw_security_event_class = "keycloak_event",
      aigw_security_schema      = "1",
    }
  }
  stage.match {
    selector            = "{keycloak_event=\"\"}"
    action              = "drop"
    drop_counter_reason = "unapproved_keycloak_event"
  }
  stage.match {
    selector            = "{keycloak_realm_id=\"\"}"
    action              = "drop"
    drop_counter_reason = "missing_keycloak_realm"
  }
  stage.match {
    selector            = "{keycloak_client_id=\"\"}"
    action              = "drop"
    drop_counter_reason = "missing_keycloak_client"
  }
  stage.match {
    selector            = "{keycloak_user_id=\"\"}"
    action              = "drop"
    drop_counter_reason = "missing_keycloak_user"
  }
  // Reconstruct from bounded fields instead of forwarding the original
  // Keycloak line. This drops IP, username/email, redirect URI, code/session
  // IDs, error detail, and any future unreviewed field by construction.
  stage.template {
    source   = "keycloak_security_line"
    template = `schema_version=1 event=aigw.keycloak.authentication event_type={{ .keycloak_event }} realm_id={{ .keycloak_realm_id }} client_id={{ .keycloak_client_id }} user_id={{ .keycloak_user_id }}`
  }
  stage.output { source = "keycloak_security_line" }
  stage.label_drop {
    values = [
      "keycloak_client_id",
      "keycloak_logger",
      "keycloak_realm_id",
      "keycloak_user_id",
    ]
  }
  forward_to = [otelcol.receiver.loki.cribl_security_logs.receiver]
}

// Envoy's access log exposes upstream transport failures. Forward only a
// reviewed provider plus a known TLS failure token. Rebuild a fixed message so
// the raw TLS library error, host details, and request metadata stay local.
loki.process "cribl_envoy_tls" {
  stage.match {
    selector            = "{project!~\"ai-gateway|aigw-preprod\"}"
    action              = "drop"
    drop_counter_reason = "unapproved_project"
  }
  stage.match {
    selector            = "{service!=\"envoy-egress\"}"
    action              = "drop"
    drop_counter_reason = "unapproved_security_service"
  }
  stage.json {
    expressions = {
      envoy_transport_failure = "upstream_transport_failure_reason",
      envoy_upstream          = "upstream",
    }
  }
  stage.regex {
    source     = "envoy_transport_failure"
    expression = `(?i)(?P<envoy_tls_failure>TLS_error|SSLV3_ALERT_[A-Z_]+|TLSV1_ALERT_[A-Z_]+|CERTIFICATE_VERIFY_FAILED|CERTIFICATE_[A-Z_]+)`
  }
  stage.labels {
    values = {
      envoy_tls_failure = "",
      envoy_upstream    = "",
    }
  }
  stage.match {
    selector            = "{envoy_tls_failure=\"\"}"
    action              = "drop"
    drop_counter_reason = "not_an_upstream_tls_failure"
  }
  stage.match {
    selector            = "{envoy_upstream!=\"anthropic\"}"
    action              = "drop"
    drop_counter_reason = "unapproved_egress_provider"
  }
  stage.template {
    source   = "envoy_tls_security_line"
    template = `schema_version=1 event=aigw.egress.trust action=upstream_tls_failure outcome=failed provider={{ .envoy_upstream }} reason=tls_transport_failure`
  }
  stage.output { source = "envoy_tls_security_line" }
  stage.static_labels {
    values = {
      aigw_security_event_class = "egress_tls",
      aigw_security_schema      = "1",
    }
  }
  stage.label_drop { values = ["envoy_tls_failure", "envoy_upstream"] }
  forward_to = [otelcol.receiver.loki.cribl_security_logs.receiver]
}

// Gateway-owned components prefix reviewed, bounded JSON records with one
// marker. Exact service/event/action/outcome allow-lists prevent ordinary
// stdout, stack traces, or a look-alike container from entering the SOC feed.
// The accepted body is rebuilt from approved scalar fields below. The source
// JSON is never forwarded, so an unknown or nested field cannot leave the host.
loki.process "cribl_structured_security" {
  stage.match {
    selector            = "{project!~\"ai-gateway|aigw-preprod\"}"
    action              = "drop"
    drop_counter_reason = "unapproved_project"
  }
  stage.match {
    selector            = "{service!~\"dev-portal|admin-portal|key-rotator|envoy-egress|litellm\"}"
    action              = "drop"
    drop_counter_reason = "unapproved_security_service"
  }
  stage.regex {
    expression = `(?:^|.*[[:space:]])AIGW_SECURITY_EVENT[[:space:]]+(?P<aigw_security_json>\{.*\})[[:space:]]*$`
  }
  stage.json {
    source = "aigw_security_json"
    expressions = {
      security_action                  = "action",
      security_amount_usd              = "amount_usd",
      security_attempt_present         = "contains(keys(@), 'attempt')",
      security_ca_fingerprints         = "ca_sha256_fingerprints",
      security_changed                 = "changed",
      security_changed_present         = "contains(keys(@), 'changed')",
      security_changed_type            = "type(changed)",
      security_change_kind             = "change_kind",
      security_completeness            = "completeness",
      security_control                 = "control",
      security_error_type              = "error_type",
      security_event                   = "event",
      security_event_id                = "event_id",
      security_effective_at            = "effective_at",
      security_exact_sans              = "exact_sans",
      security_field_count             = "length(keys(@))",
      security_group                   = "group",
      security_ldap_provider           = "ldap_provider",
      security_model                   = "model",
      security_outcome                 = "outcome",
      security_operation_id            = "operation_id",
      security_policy_sha256            = "policy_sha256",
      security_old_policy_sha256        = "old_policy_sha256",
      security_provider                = "provider",
      security_project                 = "project",
      security_providers               = "providers",
      security_purpose                 = "purpose",
      security_reason                  = "reason",
      security_request_id              = "request_id",
      security_review_note_sha256       = "review_note_sha256",
      security_rotation_id             = "rotation_id",
      security_rotation_status         = "rotation_status",
      security_schema                  = "schema_version",
      security_source_reference        = "source_reference",
      security_sni                     = "sni",
      security_state                   = "state",
      security_subject                 = "subject",
      security_target_subject          = "target_subject",
      security_token_unit              = "token_unit",
      security_usage_class             = "usage_class",
      security_candidate_sha256        = "candidate_sha256",
      security_vendor                  = "vendor",
    }
  }
  // JSON numbers enter the extracted map as numeric values. Loki labels accept
  // strings only, so normalize the schema value before the exact-match gate.
  // Without this stage every valid structured record is silently dropped.
  stage.template {
    source   = "security_schema"
    template = "{{ .Value }}"
  }
  stage.template {
    source   = "security_changed"
    template = `{{ if and (eq .security_changed_type "boolean") (eq .Value "true") }}true{{ else if and (eq .security_changed_type "boolean") (eq .Value "false") }}false{{ end }}`
  }
  stage.template {
    source   = "security_field_count"
    template = "{{ .Value }}"
  }
  stage.template {
    source   = "security_changed_present"
    template = `{{ if eq .Value "true" }}present{{ end }}`
  }
  // Alloy stringifies extracted template values, so templates cannot tell a
  // JSON number from a quoted look-alike. JMESPath checks only root object keys,
  // including null, false, zero, and empty values, then emits a bounded marker.
  // Capture the value separately from either reviewed producer JSON shape.
  // Anchoring at byte zero prevents a nested or prefixed field from matching.
  stage.template {
    source   = "security_attempt_present"
    template = `{{ if eq .Value "true" }}present{{ end }}`
  }
  stage.regex {
    source     = "aigw_security_json"
    expression = `^(?:\{"action":"(?:attempt|recovery|rotate)",|\{"schema_version":1,"event":"aigw\.provider\.rotation","action":"(?:attempt|recovery|rotate)","outcome":"(?:success|failure|failed)","vendor":"(?:anthropic|static-anthropic)","rotation_id":"[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}",)"attempt":(?P<security_attempt>[1-9][0-9]{0,2})(?:,|\})`
  }
  // These internal flags let the event-specific gates reject a field that its
  // producer never emits. They are removed before export.
  stage.template {
    source   = "security_detail_any"
    template = `{{ if or .security_attempt .security_ca_fingerprints .security_changed .security_change_kind .security_error_type .security_exact_sans .security_group .security_ldap_provider .security_operation_id .security_policy_sha256 .security_project .security_providers .security_purpose .security_reason .security_rotation_id .security_rotation_status .security_sni .security_state .security_target_subject .security_vendor }}present{{ end }}`
  }
  stage.template {
    source   = "security_detail_except_changed"
    template = `{{ if or .security_attempt .security_ca_fingerprints .security_change_kind .security_error_type .security_exact_sans .security_group .security_ldap_provider .security_operation_id .security_policy_sha256 .security_project .security_providers .security_purpose .security_reason .security_rotation_id .security_rotation_status .security_sni .security_state .security_target_subject .security_vendor }}present{{ end }}`
  }
  stage.template {
    source   = "security_detail_except_error"
    template = `{{ if or .security_attempt .security_ca_fingerprints .security_changed .security_change_kind .security_exact_sans .security_group .security_ldap_provider .security_operation_id .security_policy_sha256 .security_project .security_providers .security_purpose .security_reason .security_rotation_id .security_rotation_status .security_sni .security_state .security_target_subject .security_vendor }}present{{ end }}`
  }
  stage.template {
    source   = "security_detail_except_ldap_error"
    template = `{{ if or .security_attempt .security_ca_fingerprints .security_changed .security_change_kind .security_exact_sans .security_group .security_operation_id .security_policy_sha256 .security_project .security_providers .security_purpose .security_reason .security_rotation_id .security_rotation_status .security_sni .security_state .security_target_subject .security_vendor }}present{{ end }}`
  }
  stage.template {
    source   = "security_detail_except_ldap"
    template = `{{ if or .security_attempt .security_ca_fingerprints .security_changed .security_change_kind .security_error_type .security_exact_sans .security_group .security_operation_id .security_policy_sha256 .security_project .security_providers .security_purpose .security_reason .security_rotation_id .security_rotation_status .security_sni .security_state .security_target_subject .security_vendor }}present{{ end }}`
  }
  stage.template {
    source   = "security_detail_except_group"
    template = `{{ if or .security_attempt .security_ca_fingerprints .security_changed .security_change_kind .security_error_type .security_exact_sans .security_ldap_provider .security_operation_id .security_policy_sha256 .security_project .security_providers .security_purpose .security_reason .security_rotation_id .security_rotation_status .security_sni .security_state .security_target_subject .security_vendor }}present{{ end }}`
  }
  stage.template {
    source   = "security_detail_except_group_target"
    template = `{{ if or .security_attempt .security_ca_fingerprints .security_changed .security_change_kind .security_error_type .security_exact_sans .security_ldap_provider .security_operation_id .security_policy_sha256 .security_project .security_providers .security_purpose .security_reason .security_rotation_id .security_rotation_status .security_sni .security_state .security_vendor }}present{{ end }}`
  }
  stage.template {
    source   = "security_detail_except_group_target_project"
    template = `{{ if or .security_attempt .security_ca_fingerprints .security_changed .security_change_kind .security_error_type .security_exact_sans .security_ldap_provider .security_operation_id .security_policy_sha256 .security_providers .security_purpose .security_reason .security_rotation_id .security_rotation_status .security_sni .security_state .security_vendor }}present{{ end }}`
  }
  stage.template {
    source   = "security_detail_except_group_operation"
    template = `{{ if or .security_attempt .security_ca_fingerprints .security_changed .security_change_kind .security_error_type .security_exact_sans .security_ldap_provider .security_policy_sha256 .security_project .security_providers .security_purpose .security_reason .security_rotation_id .security_rotation_status .security_sni .security_state .security_target_subject .security_vendor }}present{{ end }}`
  }
  stage.template {
    source   = "security_detail_except_group_target_operation"
    template = `{{ if or .security_attempt .security_ca_fingerprints .security_changed .security_change_kind .security_error_type .security_exact_sans .security_ldap_provider .security_policy_sha256 .security_project .security_providers .security_purpose .security_reason .security_rotation_id .security_rotation_status .security_sni .security_state .security_vendor }}present{{ end }}`
  }
  stage.template {
    source   = "security_detail_except_group_project_operation"
    template = `{{ if or .security_attempt .security_ca_fingerprints .security_changed .security_change_kind .security_error_type .security_exact_sans .security_ldap_provider .security_policy_sha256 .security_providers .security_purpose .security_reason .security_rotation_id .security_rotation_status .security_sni .security_state .security_target_subject .security_vendor }}present{{ end }}`
  }
  stage.template {
    source   = "security_detail_except_group_target_project_operation"
    template = `{{ if or .security_attempt .security_ca_fingerprints .security_changed .security_change_kind .security_error_type .security_exact_sans .security_ldap_provider .security_policy_sha256 .security_providers .security_purpose .security_reason .security_rotation_id .security_rotation_status .security_sni .security_state .security_vendor }}present{{ end }}`
  }
  stage.template {
    source   = "security_detail_except_project_operation"
    template = `{{ if or .security_attempt .security_ca_fingerprints .security_changed .security_change_kind .security_error_type .security_exact_sans .security_group .security_ldap_provider .security_policy_sha256 .security_providers .security_purpose .security_reason .security_rotation_id .security_rotation_status .security_sni .security_state .security_target_subject .security_vendor }}present{{ end }}`
  }
  stage.template {
    source   = "security_detail_except_error_operation"
    template = `{{ if or .security_attempt .security_ca_fingerprints .security_changed .security_change_kind .security_exact_sans .security_group .security_ldap_provider .security_policy_sha256 .security_project .security_providers .security_purpose .security_reason .security_rotation_id .security_rotation_status .security_sni .security_state .security_target_subject .security_vendor }}present{{ end }}`
  }
  stage.template {
    source   = "security_detail_except_ldap_operation"
    template = `{{ if or .security_attempt .security_ca_fingerprints .security_changed .security_change_kind .security_error_type .security_exact_sans .security_group .security_policy_sha256 .security_project .security_providers .security_purpose .security_reason .security_rotation_id .security_rotation_status .security_sni .security_state .security_target_subject .security_vendor }}present{{ end }}`
  }
  stage.template {
    source   = "security_detail_except_managed_change"
    template = `{{ if or .security_attempt .security_ca_fingerprints .security_error_type .security_exact_sans .security_group .security_ldap_provider .security_policy_sha256 .security_project .security_providers .security_purpose .security_reason .security_rotation_id .security_rotation_status .security_sni .security_state .security_target_subject .security_vendor }}present{{ end }}`
  }
  stage.template {
    source   = "security_detail_except_operation"
    template = `{{ if or .security_attempt .security_ca_fingerprints .security_changed .security_change_kind .security_error_type .security_exact_sans .security_group .security_ldap_provider .security_policy_sha256 .security_project .security_providers .security_purpose .security_reason .security_rotation_id .security_rotation_status .security_sni .security_state .security_target_subject .security_vendor }}present{{ end }}`
  }
  stage.template {
    source   = "security_detail_except_model_limit"
    template = `{{ if or .security_attempt .security_ca_fingerprints .security_changed .security_change_kind .security_error_type .security_exact_sans .security_group .security_ldap_provider .security_operation_id .security_policy_sha256 .security_provider .security_providers .security_purpose .security_rotation_id .security_rotation_status .security_sni .security_state .security_subject .security_target_subject .security_usage_class .security_vendor }}present{{ end }}`
  }
  stage.template {
    source   = "security_detail_except_usage"
    template = `{{ if or .security_attempt .security_ca_fingerprints .security_changed .security_change_kind .security_control .security_error_type .security_exact_sans .security_group .security_ldap_provider .security_operation_id .security_policy_sha256 .security_providers .security_purpose .security_reason .security_rotation_id .security_rotation_status .security_sni .security_state .security_target_subject .security_usage_class .security_vendor }}present{{ end }}`
  }
  stage.template {
    source   = "security_price_detail"
    template = `{{ if or .security_amount_usd .security_candidate_sha256 .security_effective_at .security_old_policy_sha256 .security_review_note_sha256 .security_source_reference .security_token_unit }}present{{ end }}`
  }
  stage.template {
    source   = "security_detail_except_price"
    template = `{{ if or .security_attempt .security_ca_fingerprints .security_changed .security_change_kind .security_completeness .security_control .security_error_type .security_event_id .security_exact_sans .security_group .security_ldap_provider .security_policy_sha256 .security_project .security_providers .security_purpose .security_reason .security_request_id .security_rotation_id .security_rotation_status .security_sni .security_state .security_target_subject .security_vendor }}present{{ end }}`
  }
  stage.labels {
    values = {
      aigw_security_schema      = "security_schema",
      security_action           = "",
      security_amount_usd       = "",
      security_attempt          = "",
      security_attempt_present  = "",
      security_ca_fingerprints  = "",
      security_changed          = "",
      security_changed_present  = "",
      security_change_kind      = "",
      security_completeness     = "",
      security_control          = "",
      security_detail_any       = "",
      security_detail_except_changed = "",
      security_detail_except_error = "",
      security_detail_except_group = "",
      security_detail_except_group_operation = "",
      security_detail_except_group_project_operation = "",
      security_detail_except_group_target = "",
      security_detail_except_group_target_operation = "",
      security_detail_except_group_target_project = "",
      security_detail_except_group_target_project_operation = "",
      security_detail_except_ldap = "",
      security_detail_except_ldap_operation = "",
      security_detail_except_ldap_error = "",
      security_detail_except_managed_change = "",
      security_detail_except_model_limit = "",
      security_detail_except_price = "",
      security_detail_except_usage = "",
      security_detail_except_operation = "",
      security_detail_except_project_operation = "",
      security_detail_except_error_operation = "",
      security_error_type       = "",
      security_event            = "",
      security_event_id         = "",
      security_effective_at     = "",
      security_exact_sans       = "",
      security_field_count      = "",
      security_group            = "",
      security_ldap_provider    = "",
      security_model            = "",
      security_outcome          = "",
      security_operation_id     = "",
      security_old_policy_sha256 = "",
      security_policy_sha256    = "",
      security_price_detail     = "",
      security_provider         = "",
      security_project          = "",
      security_providers        = "",
      security_purpose          = "",
      security_reason           = "",
      security_request_id       = "",
      security_review_note_sha256 = "",
      security_rotation_id      = "",
      security_rotation_status  = "",
      security_sni              = "",
      security_source_reference = "",
      security_state            = "",
      security_subject          = "",
      security_target_subject   = "",
      security_token_unit       = "",
      security_usage_class      = "",
      security_candidate_sha256 = "",
      security_vendor           = "",
    }
  }
  stage.static_labels {
    values = {
      aigw_security_event_class = "security_event",
    }
  }
  stage.match {
    selector            = "{aigw_security_schema!=\"1\"}"
    action              = "drop"
    drop_counter_reason = "unsupported_security_schema"
  }
  stage.match {
    selector            = "{service=~\"dev-portal|admin-portal\",security_event!=\"aigw.portal.audit\"}"
    action              = "drop"
    drop_counter_reason = "mismatched_security_emitter"
  }
  stage.match {
    selector            = "{service=\"key-rotator\",security_event!~\"aigw[.]identity[.]audit|aigw[.]price[.]audit|aigw[.]provider[.]rotation|aigw[.]usage[.]audit|aigw[.]vault[.]state\"}"
    action              = "drop"
    drop_counter_reason = "mismatched_security_emitter"
  }
  stage.match {
    selector            = "{service=\"envoy-egress\",security_event!=\"aigw.egress.trust\"}"
    action              = "drop"
    drop_counter_reason = "mismatched_security_emitter"
  }
  stage.match {
    selector            = "{service=\"litellm\",security_event!~\"aigw[.]model[.]limit|aigw[.]usage[.]audit\"}"
    action              = "drop"
    drop_counter_reason = "mismatched_security_emitter"
  }
  stage.match {
    selector            = "{security_event=\"aigw.price.audit\",service!=\"key-rotator\"}"
    action              = "drop"
    drop_counter_reason = "mismatched_price_emitter"
  }
  stage.match {
    selector            = "{security_event=\"aigw.price.audit\",security_action!~\"create|backdate_preview|backdate_confirm\"}"
    action              = "drop"
    drop_counter_reason = "unapproved_price_action"
  }
  stage.match {
    selector            = "{security_event=\"aigw.price.audit\",security_outcome!=\"success\"}"
    action              = "drop"
    drop_counter_reason = "mismatched_price_result"
  }
  stage.match {
    selector            = "{security_event=\"aigw.price.audit\",security_field_count!=\"16\"}"
    action              = "drop"
    drop_counter_reason = "unexpected_price_field_shape"
  }
  stage.match {
    selector            = "{security_event=\"aigw.price.audit\",security_detail_except_price!=\"\"}"
    action              = "drop"
    drop_counter_reason = "unexpected_price_detail"
  }
  stage.match {
    selector            = "{security_event=\"aigw.price.audit\",security_subject=\"\"}"
    action              = "drop"
    drop_counter_reason = "missing_price_subject"
  }
  stage.match {
    selector            = "{security_event=\"aigw.price.audit\",security_model=\"\"}"
    action              = "drop"
    drop_counter_reason = "missing_price_model"
  }
  stage.match {
    selector            = "{security_event=\"aigw.price.audit\",security_provider!=\"anthropic\"}"
    action              = "drop"
    drop_counter_reason = "missing_price_provider"
  }
  stage.match {
    selector            = "{security_event=\"aigw.price.audit\",security_usage_class=\"\"}"
    action              = "drop"
    drop_counter_reason = "missing_price_usage_class"
  }
  stage.match {
    selector            = "{security_event=\"aigw.price.audit\",security_operation_id=\"\"}"
    action              = "drop"
    drop_counter_reason = "missing_price_operation_id"
  }
  stage.match {
