// Grafana Alloy — observability fan-out (solution-map §1.8).
//
// Trust boundaries:
// - OTLP listens only on Alloy's fixed net-telemetry address. Attaching Alloy
//   to storage/export networks must never expose its unauthenticated receiver
//   or HTTP UI on those networks.
// - Full prompt/completion bodies are deliberate span attributes (§9.7). They
//   go to the customer Cribl endpoint and, for litellm_request spans only, to
//   the local per-request Loki stream (service_name="aigw-requests"); they are
//   not metric labels and are never written to stdout by this configuration.
// - Docker logs are read from the host's json-file directory, read-only. The
//   Docker API socket is intentionally not mounted.

otelcol.receiver.otlp "default" {
  grpc { endpoint = sys.env("ALLOY_TELEMETRY_IP") + ":4317" }
  http { endpoint = sys.env("ALLOY_TELEMETRY_IP") + ":4318" }
  output {
    traces  = [otelcol.processor.memory_limiter.default.input]
    logs    = [otelcol.processor.memory_limiter.default.input]
    metrics = [otelcol.processor.memory_limiter.default.input]
  }
}

// The container limit is 512 MiB. Refuse/retry upstream before an exporter
// outage or several large full-prompt spans OOM-kill the collector.
otelcol.processor.memory_limiter "default" {
  check_interval = "1s"
  limit          = "384MiB"
  spike_limit    = "64MiB"
  output {
    traces  = [otelcol.processor.transform.aigw_correlation.input]
    logs    = [otelcol.processor.transform.aigw_sensitive_attributes.input]
    metrics = [otelcol.processor.transform.aigw_sensitive_attributes.input]
  }
}

// Promote only server-authenticated LiteLLM key metadata into stable,
// first-class trace correlation fields. These are trace attributes, never
// metric labels. Client-supplied llm.user and raw authorization/token fields
// are intentionally not authoritative inputs. Missing or malformed metadata
// leaves the span untouched; error_mode=ignore prevents a bad optional field
// from dropping prompt-bearing traces.
//
// aigw.user.name is the HUMAN-READABLE identity beside the stable opaque
// aigw.user.id (Keycloak subject UUID). Source priority, first match wins:
//   1. metadata.user_api_key_end_user_id — the end user LiteLLM records from
//      general_settings.user_header_name (chat path: Open WebUI forwards the
//      authenticated preferred_username) or a caller-supplied `user` field.
//      ATTRIBUTION ONLY: it grants no authorization; an API caller spoofing
//      it only mislabels its own already-authenticated traffic, whose key
//      identity is still recorded in aigw.user.id / aigw.api_key.id. It is
//      also kept as its own field, aigw.enduser.id.
//   2. aigw_username from the key's portal-stamped metadata (dev-portal
//      writes the OIDC preferred_username at mint time), extracted from the
//      serialized server-side auth metadata like the project fallback below.
//   3. metadata.user_api_key_alias — the key's human-chosen alias.
//   4. aigw.user.id — so the field is always present for label filtering.
// Every source is bounded and strictly validated: these become log fields
// and (for aigw.user.name) a Loki stream label on the aigw-requests stream.
// BEGIN AIGW MANAGED TRACE CORRELATION
otelcol.processor.transform "aigw_correlation" {
  error_mode = "ignore"

  trace_statements {
    context = "span"
    statements = [
      `set(attributes["aigw.user.id"], attributes["metadata.user_api_key_user_id"]) where resource.attributes["service.name"] == "litellm" and name == "litellm_request" and IsString(attributes["metadata.user_api_key_user_id"]) and IsMatch(attributes["metadata.user_api_key_user_id"], "^[A-Za-z0-9][A-Za-z0-9_.:@-]{0,127}$")`,
      `set(attributes["aigw.api_key.id"], attributes["metadata.user_api_key_hash"]) where resource.attributes["service.name"] == "litellm" and name == "litellm_request" and IsString(attributes["metadata.user_api_key_hash"]) and IsMatch(attributes["metadata.user_api_key_hash"], "^[0-9a-f]{64}$")`,
      `set(attributes["aigw.request.id"], attributes["litellm.call_id"]) where resource.attributes["service.name"] == "litellm" and name == "litellm_request" and IsString(attributes["litellm.call_id"]) and IsMatch(attributes["litellm.call_id"], "^[A-Za-z0-9][A-Za-z0-9_.:-]{0,127}$")`,
      `set(attributes["aigw.project.id"], attributes["metadata.user_api_key_project_id"]) where resource.attributes["service.name"] == "litellm" and name == "litellm_request" and IsString(attributes["metadata.user_api_key_project_id"]) and IsMatch(attributes["metadata.user_api_key_project_id"], "^[a-z0-9][a-z0-9_.-]{0,63}$")`,
      `set(attributes["aigw.project.id"], ExtractPatterns(attributes["metadata.user_api_key_auth_metadata"], "['\\\"]aigw_project_id['\\\"][[:space:]]*:[[:space:]]*['\\\"](?P<project>[a-z0-9][a-z0-9_.-]{0,63})['\\\"]")["project"]) where resource.attributes["service.name"] == "litellm" and name == "litellm_request" and attributes["aigw.project.id"] == nil and IsString(attributes["metadata.user_api_key_auth_metadata"]) and IsMatch(attributes["metadata.user_api_key_auth_metadata"], "['\\\"]aigw_project_id['\\\"][[:space:]]*:[[:space:]]*['\\\"](?P<project>[a-z0-9][a-z0-9_.-]{0,63})['\\\"]")`,
      `set(attributes["aigw.enduser.id"], attributes["metadata.user_api_key_end_user_id"]) where resource.attributes["service.name"] == "litellm" and name == "litellm_request" and IsString(attributes["metadata.user_api_key_end_user_id"]) and IsMatch(attributes["metadata.user_api_key_end_user_id"], "^[A-Za-z0-9][A-Za-z0-9_.:@-]{0,127}$")`,
      `set(attributes["aigw.user.name"], attributes["aigw.enduser.id"]) where resource.attributes["service.name"] == "litellm" and name == "litellm_request" and IsString(attributes["aigw.enduser.id"])`,
      `set(attributes["aigw.user.name"], ExtractPatterns(attributes["metadata.user_api_key_auth_metadata"], "['\\\"]aigw_username['\\\"][[:space:]]*:[[:space:]]*['\\\"](?P<username>[A-Za-z0-9][A-Za-z0-9_.@-]{0,63})['\\\"]")["username"]) where resource.attributes["service.name"] == "litellm" and name == "litellm_request" and attributes["aigw.user.name"] == nil and IsString(attributes["metadata.user_api_key_auth_metadata"]) and IsMatch(attributes["metadata.user_api_key_auth_metadata"], "['\\\"]aigw_username['\\\"][[:space:]]*:[[:space:]]*['\\\"](?P<username>[A-Za-z0-9][A-Za-z0-9_.@-]{0,63})['\\\"]")`,
      `set(attributes["aigw.user.name"], attributes["metadata.user_api_key_alias"]) where resource.attributes["service.name"] == "litellm" and name == "litellm_request" and attributes["aigw.user.name"] == nil and IsString(attributes["metadata.user_api_key_alias"]) and IsMatch(attributes["metadata.user_api_key_alias"], "^[A-Za-z0-9][A-Za-z0-9_.:@-]{0,127}$")`,
      `set(attributes["aigw.user.name"], attributes["aigw.user.id"]) where resource.attributes["service.name"] == "litellm" and name == "litellm_request" and attributes["aigw.user.name"] == nil and IsString(attributes["aigw.user.id"])`,
    ]
  }

  output {
    traces = [otelcol.processor.transform.aigw_sensitive_attributes.input]
  }
}
// END AIGW MANAGED TRACE CORRELATION

// Promote correlation first, then remove every raw identity/credential source
// before any signal can reach Prometheus, Loki, or customer Cribl.  The
// application requirement to retain prompt/completion bodies is deliberate:
// gen_ai.input.messages, gen_ai.output.messages, and their legacy prompt /
// completion equivalents are not matched by these deletion rules.
// BEGIN AIGW MANAGED SENSITIVE ATTRIBUTE FILTER
otelcol.processor.transform "aigw_sensitive_attributes" {
  // Attribute removal is a security boundary. A runtime transform failure
  // drops the affected telemetry instead of exporting an unsanitized copy.
  error_mode = "propagate"

  trace_statements {
    context = "resource"
    statements = [
      `delete_matching_keys(attributes, "(?i)^metadata\\.user_api_key_.*$")`,
      `delete_matching_keys(attributes, "(?i)^(?:authorization|api[_-]?key|x[_-]?api[_-]?key|access[_-]?token|refresh[_-]?token|client[_-]?secret|password|headers?|hidden_params|proxy_server_request|requester_.*|metadata\\.(?:requester_.*|spend_logs_metadata|prompt_management_metadata))$")`,
      `delete_matching_keys(attributes, "(?i)^http\\.request\\.header\\..*$")`,
      `delete_matching_keys(attributes, "(?i)^http\\.response\\.header\\.set[-_]?cookie$")`,
      `delete_matching_keys(attributes, "(?i)^(?:client|server|network\\.peer|net\\.peer)\\.(?:address|port|ip|name)$")`,
      `delete_matching_keys(attributes, "(?i)^(?:http\\.client_ip|url\\.query|http\\.target|requester_ip_address|(?:.*\\.)?(?:email|e_mail|e-mail))$")`,
    ]
  }

  trace_statements {
    context = "scope"
    statements = [
      `delete_matching_keys(attributes, "(?i)^metadata\\.user_api_key_.*$")`,
      `delete_matching_keys(attributes, "(?i)^(?:authorization|api[_-]?key|x[_-]?api[_-]?key|access[_-]?token|refresh[_-]?token|client[_-]?secret|password|headers?|hidden_params|proxy_server_request|requester_.*|metadata\\.(?:requester_.*|spend_logs_metadata|prompt_management_metadata))$")`,
      `delete_matching_keys(attributes, "(?i)^http\\.request\\.header\\..*$")`,
      `delete_matching_keys(attributes, "(?i)^http\\.response\\.header\\.set[-_]?cookie$")`,
      `delete_matching_keys(attributes, "(?i)^(?:client|server|network\\.peer|net\\.peer)\\.(?:address|port|ip|name)$")`,
      `delete_matching_keys(attributes, "(?i)^(?:http\\.client_ip|url\\.query|http\\.target|requester_ip_address|(?:.*\\.)?(?:email|e_mail|e-mail))$")`,
    ]
  }

  trace_statements {
    context = "span"
    statements = [
      `delete_matching_keys(attributes, "(?i)^metadata\\.user_api_key_.*$")`,
      `delete_matching_keys(attributes, "(?i)^(?:authorization|api[_-]?key|x[_-]?api[_-]?key|access[_-]?token|refresh[_-]?token|client[_-]?secret|password|headers?|hidden_params|proxy_server_request|requester_.*|metadata\\.(?:requester_.*|spend_logs_metadata|prompt_management_metadata))$")`,
      `delete_matching_keys(attributes, "(?i)^http\\.request\\.header\\..*$")`,
      `delete_matching_keys(attributes, "(?i)^http\\.response\\.header\\.set[-_]?cookie$")`,
      `delete_matching_keys(attributes, "(?i)^(?:client|server|network\\.peer|net\\.peer)\\.(?:address|port|ip|name)$")`,
      `delete_matching_keys(attributes, "(?i)^(?:http\\.client_ip|url\\.query|http\\.target|requester_ip_address|(?:.*\\.)?(?:email|e_mail|e-mail))$")`,
    ]
  }

  trace_statements {
    context = "spanevent"
    statements = [
      `delete_matching_keys(attributes, "(?i)^metadata\\.user_api_key_.*$")`,
      `delete_matching_keys(attributes, "(?i)^(?:authorization|api[_-]?key|x[_-]?api[_-]?key|access[_-]?token|refresh[_-]?token|client[_-]?secret|password|headers?|hidden_params|proxy_server_request|requester_.*|metadata\\.(?:requester_.*|spend_logs_metadata|prompt_management_metadata))$")`,
      `delete_matching_keys(attributes, "(?i)^http\\.request\\.header\\..*$")`,
      `delete_matching_keys(attributes, "(?i)^http\\.response\\.header\\.set[-_]?cookie$")`,
      `delete_matching_keys(attributes, "(?i)^(?:client|server|network\\.peer|net\\.peer)\\.(?:address|port|ip|name)$")`,
      `delete_matching_keys(attributes, "(?i)^(?:http\\.client_ip|url\\.query|http\\.target|requester_ip_address|(?:.*\\.)?(?:email|e_mail|e-mail))$")`,
    ]
  }

  metric_statements {
    context = "resource"
    statements = [
      `delete_matching_keys(attributes, "(?i)^metadata\\.user_api_key_.*$")`,
      `delete_matching_keys(attributes, "(?i)^(?:authorization|api[_-]?key|x[_-]?api[_-]?key|access[_-]?token|refresh[_-]?token|client[_-]?secret|password|headers?|hidden_params|proxy_server_request|requester_.*|metadata\\.(?:requester_.*|spend_logs_metadata|prompt_management_metadata))$")`,
      `delete_matching_keys(attributes, "(?i)^http\\.request\\.header\\..*$")`,
      `delete_matching_keys(attributes, "(?i)^http\\.response\\.header\\.set[-_]?cookie$")`,
      `delete_matching_keys(attributes, "(?i)^(?:client|server|network\\.peer|net\\.peer)\\.(?:address|port|ip|name)$")`,
      `delete_matching_keys(attributes, "(?i)^(?:http\\.client_ip|url\\.query|http\\.target|requester_ip_address|(?:.*\\.)?(?:email|e_mail|e-mail))$")`,
    ]
  }

  metric_statements {
    context = "scope"
    statements = [
      `delete_matching_keys(attributes, "(?i)^metadata\\.user_api_key_.*$")`,
      `delete_matching_keys(attributes, "(?i)^(?:authorization|api[_-]?key|x[_-]?api[_-]?key|access[_-]?token|refresh[_-]?token|client[_-]?secret|password|headers?|hidden_params|proxy_server_request|requester_.*|metadata\\.(?:requester_.*|spend_logs_metadata|prompt_management_metadata))$")`,
      `delete_matching_keys(attributes, "(?i)^http\\.request\\.header\\..*$")`,
      `delete_matching_keys(attributes, "(?i)^http\\.response\\.header\\.set[-_]?cookie$")`,
      `delete_matching_keys(attributes, "(?i)^(?:client|server|network\\.peer|net\\.peer)\\.(?:address|port|ip|name)$")`,
      `delete_matching_keys(attributes, "(?i)^(?:http\\.client_ip|url\\.query|http\\.target|requester_ip_address|(?:.*\\.)?(?:email|e_mail|e-mail))$")`,
    ]
  }

  metric_statements {
    context = "datapoint"
    statements = [
      `delete_matching_keys(attributes, "(?i)^metadata\\.user_api_key_.*$")`,
      `delete_matching_keys(attributes, "(?i)^(?:authorization|api[_-]?key|x[_-]?api[_-]?key|access[_-]?token|refresh[_-]?token|client[_-]?secret|password|headers?|hidden_params|proxy_server_request|requester_.*|metadata\\.(?:requester_.*|spend_logs_metadata|prompt_management_metadata))$")`,
      `delete_matching_keys(attributes, "(?i)^http\\.request\\.header\\..*$")`,
      `delete_matching_keys(attributes, "(?i)^http\\.response\\.header\\.set[-_]?cookie$")`,
      `delete_matching_keys(attributes, "(?i)^(?:client|server|network\\.peer|net\\.peer)\\.(?:address|port|ip|name)$")`,
      `delete_matching_keys(attributes, "(?i)^(?:http\\.client_ip|url\\.query|http\\.target|requester_ip_address|(?:.*\\.)?(?:email|e_mail|e-mail))$")`,
    ]
  }

  log_statements {
    context = "resource"
    statements = [
      `delete_matching_keys(attributes, "(?i)^metadata\\.user_api_key_.*$")`,
      `delete_matching_keys(attributes, "(?i)^(?:authorization|api[_-]?key|x[_-]?api[_-]?key|access[_-]?token|refresh[_-]?token|client[_-]?secret|password|headers?|hidden_params|proxy_server_request|requester_.*|metadata\\.(?:requester_.*|spend_logs_metadata|prompt_management_metadata))$")`,
      `delete_matching_keys(attributes, "(?i)^http\\.request\\.header\\..*$")`,
      `delete_matching_keys(attributes, "(?i)^http\\.response\\.header\\.set[-_]?cookie$")`,
      `delete_matching_keys(attributes, "(?i)^(?:client|server|network\\.peer|net\\.peer)\\.(?:address|port|ip|name)$")`,
      `delete_matching_keys(attributes, "(?i)^(?:http\\.client_ip|url\\.query|http\\.target|requester_ip_address|(?:.*\\.)?(?:email|e_mail|e-mail))$")`,
    ]
  }

  log_statements {
    context = "scope"
    statements = [
      `delete_matching_keys(attributes, "(?i)^metadata\\.user_api_key_.*$")`,
      `delete_matching_keys(attributes, "(?i)^(?:authorization|api[_-]?key|x[_-]?api[_-]?key|access[_-]?token|refresh[_-]?token|client[_-]?secret|password|headers?|hidden_params|proxy_server_request|requester_.*|metadata\\.(?:requester_.*|spend_logs_metadata|prompt_management_metadata))$")`,
      `delete_matching_keys(attributes, "(?i)^http\\.request\\.header\\..*$")`,
      `delete_matching_keys(attributes, "(?i)^http\\.response\\.header\\.set[-_]?cookie$")`,
      `delete_matching_keys(attributes, "(?i)^(?:client|server|network\\.peer|net\\.peer)\\.(?:address|port|ip|name)$")`,
      `delete_matching_keys(attributes, "(?i)^(?:http\\.client_ip|url\\.query|http\\.target|requester_ip_address|(?:.*\\.)?(?:email|e_mail|e-mail))$")`,
    ]
  }

  log_statements {
    context = "log"
    statements = [
      `delete_matching_keys(attributes, "(?i)^metadata\\.user_api_key_.*$")`,
      `delete_matching_keys(attributes, "(?i)^(?:authorization|api[_-]?key|x[_-]?api[_-]?key|access[_-]?token|refresh[_-]?token|client[_-]?secret|password|headers?|hidden_params|proxy_server_request|requester_.*|metadata\\.(?:requester_.*|spend_logs_metadata|prompt_management_metadata))$")`,
      `delete_matching_keys(attributes, "(?i)^http\\.request\\.header\\..*$")`,
      `delete_matching_keys(attributes, "(?i)^http\\.response\\.header\\.set[-_]?cookie$")`,
      `delete_matching_keys(attributes, "(?i)^(?:client|server|network\\.peer|net\\.peer)\\.(?:address|port|ip|name)$")`,
      `delete_matching_keys(attributes, "(?i)^(?:http\\.client_ip|url\\.query|http\\.target|requester_ip_address|(?:.*\\.)?(?:email|e_mail|e-mail))$")`,
      `delete_matching_keys(body, "(?i)^(?:authorization|api[_-]?key|x[_-]?api[_-]?key|access[_-]?token|refresh[_-]?token|client[_-]?secret|password|headers?|hidden_params|proxy_server_request|requester_.*|metadata\\.user_api_key_.*)$") where IsMap(body)`,
      // Arbitrarily nested maps cannot be recursively proven safe in OTTL.
      // Preserve severity/timestamps/attributes, but fail closed on the body.
      `set(body, "<redacted-structured-log-body>") where IsMap(body)`,
      `replace_pattern(body, "(?i)(?:authorization|api[_-]?key|x[_-]?api[_-]?key|access[_-]?token|refresh[_-]?token|client[_-]?secret|password)[\\\"']?[[:space:]]*[:=][[:space:]]*[\\\"']?(?:(?:bearer|basic)[[:space:]]+)?[^\\\"'[:space:],}]+", "<redacted-credential>") where IsString(body)`,
      `replace_pattern(body, "(?i)\\b(?:bearer|basic)[[:space:]]+[A-Za-z0-9._~+/-]{8,}", "<redacted-authorization>") where IsString(body)`,
      `replace_pattern(body, "\\bsk-(?:ant-)?[A-Za-z0-9_-]{16,}\\b", "<redacted-vendor-key>") where IsString(body)`,
    ]
  }

  output {
    traces  = [otelcol.processor.batch.default.input]
    logs    = [otelcol.processor.batch.default.input]
    metrics = [otelcol.processor.batch.default.input]
  }
}
// END AIGW MANAGED SENSITIVE ATTRIBUTE FILTER

otelcol.processor.batch "default" {
  timeout             = "1s"
  send_batch_size     = 512
  send_batch_max_size = 1024
  output {
    traces = [
      otelcol.exporter.otlp.cribl.input,
      otelcol.connector.spanmetrics.default.input,
      otelcol.processor.filter.aigw_request_spans.input,
    ]
    logs = [
      otelcol.exporter.otlp.cribl.input,
      otelcol.exporter.loki.local.input,
    ]
    metrics = [
      otelcol.exporter.otlp.cribl.input,
      otelcol.exporter.prometheus.local.input,
    ]
  }
}

// LiteLLM's Prometheus endpoint is enterprise-gated. Derive bounded
// request-rate/latency/error metrics from spans. Key aliases are deliberately
// NOT dimensions: users choose them and can mint arbitrarily many keys, which
// otherwise creates an unbounded Prometheus series-cardinality DoS.
otelcol.connector.spanmetrics "default" {
  histogram { explicit {} }
  dimension { name = "gen_ai.request.model" }
  output {
    metrics = [otelcol.exporter.prometheus.local.input]
  }
}

// Per-request audit stream (owner decision): one Loki log line per
// litellm_request span so Grafana Logs Drilldown can filter AI requests by
// user/key/project and show the approved prompt/completion content. The
// sensitive-attribute sanitizer above has already removed every credential
// and raw-identity source before this branch; prompt bodies are deliberately
// retained here, in this stream only. Sibling spans (raw_gen_ai_request,
// Received Proxy Server Request) never enter it — the filter drops everything
// that is not the exact litellm_request span; they still reach Cribl through
// the batch fan-out with everything else.
otelcol.processor.filter "aigw_request_spans" {
  error_mode = "ignore"
  traces {
    span = [
      `name != "litellm_request"`,
    ]
  }
  output {
    traces = [otelcol.connector.spanlogs.aigw_requests.input]
  }
}

// One log line per surviving span, carrying only the explicit allow-listed
// span attributes. The body is logfmt-style key=value text, so LogQL's
// `| logfmt` yields aigw_user_id / gen_ai_* fields for dashboards.
//
// `labels` re-emits the listed keys as log ATTRIBUTES so the downstream
// loki.attribute.labels hint can promote them to Loki stream labels, giving
// Logs Drilldown label tabs and dashboard dropdowns. Cardinality is a
// deliberate, bounded decision: the user and project populations are small
// (dozens) and this is a single dedicated stream; aigw.user.name is
// regex-validated at promotion and the writer's max_streams=1000 is the
// hard backstop. aigw.request.id and aigw.api_key.id are unbounded/high-
// churn and MUST stay line fields, never labels.
otelcol.connector.spanlogs "aigw_requests" {
  spans  = true
  labels = [
    "aigw.user.name",
    "aigw.project.id",
  ]
  span_attributes = [
    "aigw.user.id",
    "aigw.user.name",
    "aigw.enduser.id",
    "aigw.api_key.id",
    "aigw.project.id",
    "aigw.request.id",
    "gen_ai.request.model",
    "gen_ai.response.model",
    "litellm.model_group",
    "gen_ai.usage.input_tokens",
    "gen_ai.usage.output_tokens",
    "gen_ai.usage.total_tokens",
    "gen_ai.cost.total_cost",
    "gen_ai.response.finish_reasons",
    "llm.is_streaming",
    "http.route",
    "litellm.call_id",
    "gen_ai.input.messages",
    "gen_ai.output.messages",
  ]
  output {
    logs = [otelcol.processor.transform.aigw_request_stream.input]
  }
}

// Stable stream identity: Grafana's Logs Drilldown keys its whole UI on the
// OTel-semantic service_name label, so pin the resource service.name to the
// dedicated stream value before label promotion.
otelcol.processor.transform "aigw_request_stream" {
  error_mode = "ignore"
  log_statements {
    context = "resource"
    statements = [
      `set(attributes["service.name"], "aigw-requests")`,
    ]
  }
  output {
    logs = [otelcol.processor.attributes.aigw_request_stream_labels.input]
  }
}

// otelcol.exporter.loki promotes OTLP attributes into Loki labels only via
// the documented hint attributes; loki.resource.labels turns the resource
// service.name into the service_name stream label, and loki.attribute.labels
// promotes the spanlogs-emitted attribution attributes into the bounded
// aigw_user_name / aigw_project_id stream labels (Prometheus-format names).
otelcol.processor.attributes "aigw_request_stream_labels" {
  action {
    key    = "loki.resource.labels"
    action = "insert"
    value  = "service.name"
  }
  action {
    key    = "loki.attribute.labels"
    action = "insert"
    value  = "aigw.user.name, aigw.project.id"
  }
  output {
    logs = [otelcol.exporter.loki.local.input]
  }
}

otelcol.exporter.prometheus "local" {
  forward_to = [prometheus.remote_write.local.receiver]
}

prometheus.remote_write "local" {
  endpoint { url = "http://prometheus:9090/api/v1/write" }
}

otelcol.exporter.loki "local" {
  forward_to = [loki.write.local.receiver]
}

loki.write "local" {
  max_streams = 1000
  endpoint {
    url              = "http://loki:3100/loki/api/v1/push"
    batch_size       = "1MiB"
    batch_wait       = "1s"
    follow_redirects = false
    remote_timeout   = "10s"
  }
}

// Persistent exporter queue survives Alloy restarts and endpoint outages.
// queue_size remains byte-bounded at the exporter; fsync trades a small
// amount of throughput for a durable customer audit trail.
otelcol.storage.file "cribl_queue" {
  directory             = "/var/lib/alloy/queues/cribl"
  directory_permissions = "0700"
  fsync                  = true
  timeout                = "5s"

  compaction {
    cleanup_on_start              = true
    on_start                      = true
    on_rebound                    = true
    rebound_needed_threshold_mib  = 2048
    rebound_trigger_threshold_mib = 512
  }
}

// Customer Cribl (or the cribl-mock stand-in). The queue is byte-bounded so
// one endpoint outage cannot consume all collector memory. Plaintext remains
// an explicit lab-only switch enforced by Ansible.
otelcol.exporter.otlp "cribl" {
  client {
    endpoint = sys.env("CRIBL_OTLP_ENDPOINT")
    // Pure Compose is a development profile pointed only at cribl-mock.
    // Ansible replaces this entire marked block with either this plaintext
    // form or a verified customer TLS form. Do not mix TLS-only arguments
    // into the insecure block: Alloy 1.17.1 then attempts a TLS handshake.
    // BEGIN AIGW MANAGED CRIBL TLS
    tls {
      insecure = true
    }
    // END AIGW MANAGED CRIBL TLS
  }
  sending_queue {
    enabled           = true
    num_consumers     = 2
    // Owner decision: the on-disk queue is the Cribl-outage buffer and must
    // hold roughly 24 hours of this deployment's telemetry (prompt-bearing
    // spans included). 2 GiB is deliberately generous for the lab volume.
    queue_size        = 2147483648
    sizer             = "bytes"
    block_on_overflow = false
    storage           = otelcol.storage.file.cribl_queue.handler
  }
  retry_on_failure {
    enabled          = true
    initial_interval = "1s"
    max_interval     = "30s"
    max_elapsed_time = "0s"
  }
}

// Docker json-file logs. Compose configures the project/service labels as
// json-file attributes, so querying never needs a high-cardinality filename or
// container-id label. Positions persist under Alloy's --storage.path volume.
loki.source.file "docker" {
  targets = [{
    __path__ = "/var/lib/docker/containers/*/*-json.log",
    job      = "docker",
  }]
  forward_to = [loki.process.docker.receiver]
  file_match {
    enabled     = true
    sync_period = "10s"
  }
}

loki.process "docker" {
  stage.json {
    expressions = {
      message   = "log",
      stream    = "stream",
      timestamp = "time",
      project   = "attrs.\"com.docker.compose.project\"",
      service   = "attrs.\"com.docker.compose.service\"",
    }
  }
  stage.timestamp {
    source = "timestamp"
    format = "RFC3339Nano"
  }
  stage.labels {
    values = {
      project = "",
      service = "",
      stream  = "",
      // Grafana's Logs Drilldown app keys its whole UI on the OTel-semantic
      // service_name label; without it every stream is invisible there.
      service_name = "service",
    }
  }
  stage.output { source = "message" }
  // Full prompts live in traces by explicit policy. Ordinary service logs are
  // a different data class: redact credential-shaped fields and vendor keys if
  // a dependency ever prints them during an error path.
  stage.replace {
    expression = `(?i)("?(?:api[_-]?key|client[_-]?secret|password|access[_-]?token|refresh[_-]?token|authorization)"?\s*[:=]\s*["']?(?:(?:bearer|basic)\s+)?)[^"'\s,}]{8,}`
    replace    = `${1}<redacted>`
  }
  stage.replace {
    expression = `(?i)\b((?:bearer|basic)\s+)[A-Za-z0-9._~+/-]{8,}`
    replace    = `${1}<redacted>`
  }
  stage.replace {
    expression = `\bsk-(?:ant-)?[A-Za-z0-9_-]{16,}\b`
    replace    = `<redacted-vendor-key>`
  }
  stage.label_drop { values = ["filename"] }
  forward_to = [
    loki.write.local.receiver,
    loki.process.external_file_logs.receiver,
  ]
}

// Do not feed the collector's own logs or the development Cribl debug sink
// back into Cribl: either path forms a recursive log-amplification loop.
loki.process "external_file_logs" {
  stage.match {
    selector            = "{service=~\"alloy|cribl-mock\"}"
    action              = "drop"
    drop_counter_reason = "telemetry_feedback_loop"
  }
  forward_to = [otelcol.receiver.loki.file_logs.receiver]
}

// Vault audit records are HMAC-redacted by Vault and live on a dedicated
// read-only mount in Alloy. They are retained locally and dual-exported.
loki.source.file "vault_audit" {
  targets = [{
    __path__ = "/var/log/aigw/vault/audit.log",
    job      = "vault-audit",
    service  = "vault-audit",
  }]
  forward_to = [
    loki.write.local.receiver,
    otelcol.receiver.loki.file_logs.receiver,
  ]
  file_match {
    enabled     = true
    sync_period = "10s"
  }
}

// Bridge stable Loki file tailing into OTLP for the Cribl copy. Keep it on a
// separate batch path so the local Loki write is never duplicated.
otelcol.receiver.loki "file_logs" {
  output {
    logs = [otelcol.processor.batch.file_logs.input]
  }
}

otelcol.processor.batch "file_logs" {
  timeout             = "1s"
  send_batch_size     = 512
  send_batch_max_size = 1024
  output {
    logs = [otelcol.exporter.otlp.cribl.input]
  }
}
