    drop_counter_reason = "missing_egress_failure_reason"
  }
  stage.template {
    source = "aigw_security_line"
    template = `schema_version=1 event={{ .security_event }} action={{ .security_action }} outcome={{ .security_outcome }}{{ if .security_event_id }} event_id={{ .security_event_id }}{{ end }}{{ if .security_request_id }} request_id={{ .security_request_id }}{{ end }}{{ if .security_subject }} subject={{ .security_subject }}{{ end }}{{ if .security_model }} model={{ .security_model }}{{ end }}{{ if .security_control }} control={{ .security_control }}{{ end }}{{ if .security_provider }} provider={{ .security_provider }}{{ end }}{{ if .security_usage_class }} usage_class={{ .security_usage_class }}{{ end }}{{ if .security_amount_usd }} amount_usd={{ .security_amount_usd }}{{ end }}{{ if .security_token_unit }} token_unit={{ .security_token_unit }}{{ end }}{{ if .security_effective_at }} effective_at={{ .security_effective_at }}{{ end }}{{ if .security_source_reference }} source_reference={{ .security_source_reference }}{{ end }}{{ if .security_review_note_sha256 }} review_note_sha256={{ .security_review_note_sha256 }}{{ end }}{{ if .security_old_policy_sha256 }} old_policy_sha256={{ .security_old_policy_sha256 }}{{ end }}{{ if .security_candidate_sha256 }} candidate_sha256={{ .security_candidate_sha256 }}{{ end }}{{ if .security_completeness }} completeness={{ .security_completeness }}{{ end }}{{ if .security_group }} group={{ .security_group }}{{ end }}{{ if .security_target_subject }} target_subject={{ .security_target_subject }}{{ end }}{{ if .security_project }} project={{ .security_project }}{{ end }}{{ if .security_changed }} changed={{ .security_changed }}{{ end }}{{ if .security_change_kind }} change_kind={{ .security_change_kind }}{{ end }}{{ if .security_operation_id }} operation_id={{ .security_operation_id }}{{ end }}{{ if .security_error_type }} error_type={{ .security_error_type }}{{ end }}{{ if .security_ldap_provider }} ldap_provider={{ .security_ldap_provider }}{{ end }}{{ if .security_purpose }} purpose={{ .security_purpose }}{{ end }}{{ if .security_vendor }} vendor={{ .security_vendor }}{{ end }}{{ if .security_rotation_id }} rotation_id={{ .security_rotation_id }}{{ end }}{{ if .security_attempt }} attempt={{ .security_attempt }}{{ end }}{{ if .security_rotation_status }} rotation_status={{ .security_rotation_status }}{{ end }}{{ if .security_state }} state={{ .security_state }}{{ end }}{{ if .security_policy_sha256 }} policy_sha256={{ .security_policy_sha256 }}{{ end }}{{ if .security_providers }} providers={{ .security_providers }}{{ end }}{{ if .security_sni }} sni={{ .security_sni }}{{ end }}{{ if .security_exact_sans }} exact_sans={{ .security_exact_sans }}{{ end }}{{ if .security_ca_fingerprints }} ca_sha256_fingerprints={{ .security_ca_fingerprints }}{{ end }}{{ if .security_reason }} reason={{ .security_reason }}{{ end }}`
  }
  stage.output { source = "aigw_security_line" }
  stage.label_drop {
    values = [
      "security_action",
      "security_amount_usd",
      "security_attempt",
      "security_attempt_present",
      "security_ca_fingerprints",
      "security_changed",
      "security_changed_present",
      "security_change_kind",
      "security_completeness",
      "security_control",
      "security_detail_any",
      "security_detail_except_changed",
      "security_detail_except_error",
      "security_detail_except_error_operation",
      "security_detail_except_group",
      "security_detail_except_group_operation",
      "security_detail_except_group_project_operation",
      "security_detail_except_group_target",
      "security_detail_except_group_target_operation",
      "security_detail_except_group_target_project",
      "security_detail_except_group_target_project_operation",
      "security_detail_except_ldap",
      "security_detail_except_ldap_operation",
      "security_detail_except_ldap_error",
      "security_detail_except_managed_change",
      "security_detail_except_model_limit",
      "security_detail_except_price",
      "security_detail_except_usage",
      "security_detail_except_operation",
      "security_detail_except_project_operation",
      "security_error_type",
      "security_event",
      "security_event_id",
      "security_effective_at",
      "security_exact_sans",
      "security_field_count",
      "security_group",
      "security_ldap_provider",
      "security_model",
      "security_outcome",
      "security_operation_id",
      "security_old_policy_sha256",
      "security_policy_sha256",
      "security_price_detail",
      "security_provider",
      "security_project",
      "security_providers",
      "security_purpose",
      "security_reason",
      "security_request_id",
      "security_review_note_sha256",
      "security_rotation_id",
      "security_rotation_status",
      "security_sni",
      "security_source_reference",
      "security_state",
      "security_subject",
      "security_target_subject",
      "security_token_unit",
      "security_usage_class",
      "security_candidate_sha256",
      "security_vendor",
    ]
  }
  forward_to = [otelcol.receiver.loki.cribl_security_logs.receiver]
}

// The controller writes one exact, sorted JSON schema to an owned two-file
// rotation boundary. Match the full line so extra keys, missing keys, quoted
// numeric fields, unknown actions, and malformed release identifiers fail
// closed. Rebuild the exported body from the fixed captures only.
loki.source.file "controller_lifecycle" {
  targets = [
    {
      __path__ = "/var/log/aigw/controller/lifecycle.jsonl",
      job      = "controller-lifecycle",
    },
    {
      __path__ = "/var/log/aigw/controller/lifecycle.jsonl.1",
      job      = "controller-lifecycle",
    },
  ]
  forward_to = [loki.process.cribl_controller_lifecycle.receiver]
  file_match {
    enabled     = true
    sync_period = "10s"
  }
}

loki.process "cribl_controller_lifecycle" {
  stage.regex {
    expression = `^\{"action":"(?P<controller_action>upgrade|rollback)","egress_policy_sha256":"(?P<controller_egress_policy_sha256>[0-9a-f]{64})","envoy_image_id":"(?P<controller_envoy_image_id>sha256:[0-9a-f]{64})","event":"aigw\.controller\.lifecycle","operation_id":"(?P<controller_operation_id>[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12})","outcome":"(?P<controller_outcome>started|success|failed)","release_commit":"(?P<controller_release_commit>(?:[0-9a-f]{40}|[0-9a-f]{64}))","release_manifest_sha256":"(?P<controller_release_manifest_sha256>[0-9a-f]{64})","schema_version":(?P<controller_schema>1),"timestamp":"(?P<controller_timestamp>[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\.[0-9]{3}Z)"\}$`
  }
  stage.labels {
    values = {
      controller_action                  = "",
      controller_egress_policy_sha256    = "",
      controller_envoy_image_id          = "",
      controller_operation_id            = "",
      controller_outcome                 = "",
      controller_release_commit          = "",
      controller_release_manifest_sha256 = "",
      controller_schema                  = "",
      controller_timestamp               = "",
    }
  }
  stage.match {
    selector            = "{controller_schema!=\"1\"}"
    action              = "drop"
    drop_counter_reason = "malformed_controller_lifecycle_record"
  }
  stage.timestamp {
    source = "controller_timestamp"
    format = "2006-01-02T15:04:05.000Z"
  }
  stage.template {
    source = "controller_security_line"
    template = `schema_version=1 event=aigw.controller.lifecycle action={{ .controller_action }} outcome={{ .controller_outcome }} operation_id={{ .controller_operation_id }} release_manifest_sha256={{ .controller_release_manifest_sha256 }} release_commit={{ .controller_release_commit }} envoy_image_id={{ .controller_envoy_image_id }} egress_policy_sha256={{ .controller_egress_policy_sha256 }}`
  }
  stage.output { source = "controller_security_line" }
  stage.static_labels {
    values = {
      aigw_security_event_class = "controller_lifecycle",
      aigw_security_schema      = "1",
    }
  }
  stage.label_drop {
    values = [
      "controller_action",
      "controller_egress_policy_sha256",
      "controller_envoy_image_id",
      "controller_operation_id",
      "controller_outcome",
      "controller_release_commit",
      "controller_release_manifest_sha256",
      "controller_schema",
      "controller_timestamp",
    ]
  }
  forward_to = [
    loki.write.local.receiver,
    otelcol.receiver.loki.cribl_security_logs.receiver,
  ]
}

// Vault writes its HMAC-protected JSON audit records to a dedicated read-only
// mount. The raw records remain local. A second fail-closed processor emits
// only bounded metadata; the key-rotator watcher emits seal-state changes.
loki.source.file "vault_audit" {
  targets = [{
    __path__ = "/var/log/aigw/vault/audit.log",
    job      = "vault-audit",
    service  = "vault-audit",
  }]
  forward_to = [
    loki.write.local.receiver,
    loki.process.cribl_vault_audit.receiver,
  ]
  file_match {
    enabled     = true
    sync_period = "10s"
  }
}

// Never forward a raw Vault audit record. Keep only its record type, operation,
// a small path category, success/failure, and the fact that Vault HMAC-protected
// the source. Unknown JSON, paths, operations, and record types fail closed.
loki.process "cribl_vault_audit" {
  stage.json {
    expressions = {
      vault_error     = "error",
      vault_operation = "request.operation",
      vault_path      = "request.path",
      vault_type      = "type",
    }
  }
  stage.regex {
    source     = "vault_path"
    expression = `^(?P<vault_path_class>kv/(?:data|metadata)/ai-gateway|auth/token|sys/(?:audit|mounts|policies))(?:/.*)?$`
  }
  stage.template {
    source   = "vault_outcome"
    template = `{{ if .vault_error }}failure{{ else }}success{{ end }}`
  }
  stage.labels {
    values = {
      vault_operation  = "",
      vault_outcome    = "",
      vault_path_class = "",
      vault_type       = "",
    }
  }
  stage.match {
    selector            = "{vault_type!~\"request|response\"}"
    action              = "drop"
    drop_counter_reason = "unapproved_vault_record_type"
  }
  stage.match {
    selector            = "{vault_operation!~\"create|delete|list|patch|read|update\"}"
    action              = "drop"
    drop_counter_reason = "unapproved_vault_operation"
  }
  stage.match {
    selector            = "{vault_path_class!~\"kv/(data|metadata)/ai-gateway|auth/token|sys/(audit|mounts|policies)\"}"
    action              = "drop"
    drop_counter_reason = "unapproved_vault_path"
  }
  stage.template {
    source = "vault_security_line"
    template = `schema_version=1 event=aigw.vault.audit record_type={{ .vault_type }} operation={{ .vault_operation }} path_class={{ .vault_path_class }} outcome={{ .vault_outcome }} hmac_protected=true`
  }
  stage.output { source = "vault_security_line" }
  stage.static_labels {
    values = {
      aigw_security_event_class = "vault_audit",
      aigw_security_schema      = "1",
    }
  }
  forward_to = [otelcol.receiver.loki.cribl_security_logs.receiver]
}

// Bridge only the fail-closed security classifiers above into OTLP logs.
// The request-audit spanlog joins the same queue directly after its exact
// trace filter. No trace or metric output exists on this receiver or batch.
otelcol.receiver.loki "cribl_security_logs" {
  output {
    logs = [otelcol.processor.transform.cribl_security_contract.input]
  }
}
