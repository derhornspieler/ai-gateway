{
  "realm": "aigw",
  "enabled": true,
  "displayName": "AI Gateway",
  "sslRequired": "external",
  "registrationAllowed": false,
  "eventsEnabled": true,
  "eventsExpiration": 86400,
  "eventsListeners": ["jboss-logging"],
  "enabledEventTypes": [
    "CLIENT_LOGIN",
    "CLIENT_LOGIN_ERROR",
    "CODE_TO_TOKEN",
    "CODE_TO_TOKEN_ERROR",
    "IDENTITY_PROVIDER_FIRST_LOGIN",
    "IDENTITY_PROVIDER_FIRST_LOGIN_ERROR",
    "IDENTITY_PROVIDER_LOGIN",
    "IDENTITY_PROVIDER_LOGIN_ERROR",
    "IDENTITY_PROVIDER_POST_LOGIN",
    "IDENTITY_PROVIDER_POST_LOGIN_ERROR",
    "IMPERSONATE",
    "IMPERSONATE_ERROR",
    "LOGIN",
    "LOGIN_ERROR",
    "LOGOUT",
    "LOGOUT_ERROR",
    "REFRESH_TOKEN",
    "REFRESH_TOKEN_ERROR",
    "USER_DISABLED_BY_PERMANENT_LOCKOUT",
    "USER_DISABLED_BY_PERMANENT_LOCKOUT_ERROR",
    "USER_DISABLED_BY_TEMPORARY_LOCKOUT",
    "USER_DISABLED_BY_TEMPORARY_LOCKOUT_ERROR"
  ],
  "adminEventsEnabled": false,
  "adminEventsDetailsEnabled": false,
  "bruteForceProtected": true,
  "permanentLockout": false,
  "maxTemporaryLockouts": 0,
  "bruteForceStrategy": "MULTIPLE",
  "failureFactor": 5,
  "waitIncrementSeconds": 60,
  "quickLoginCheckMilliSeconds": 1000,
  "minimumQuickLoginWaitSeconds": 60,
  "maxFailureWaitSeconds": 900,
  "maxDeltaTimeSeconds": 43200,
  "loginTheme": "keycloak",
  "accessTokenLifespan": 600,
  "ssoSessionIdleTimeout": 28800,
  "ssoSessionMaxLifespan": 36000,
  "roles": {
    "realm": [
      { "name": "aigw-admins", "description": "Admin portal + Grafana + rotation control" },
      { "name": "aigw-developers", "description": "dev-portal self-service key issuance" },
      { "name": "aigw-chat", "description": "Open WebUI chat access" },
      { "name": "aigw-users", "description": "DEPRECATED — no longer gates chat (aigw-chat does); retained for existing assignments" }
    ]
  },
  "clients": [
    {
      "clientId": "open-webui",
      "name": "Open WebUI",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "fullScopeAllowed": false,
      "secret": "${WEBUI_OIDC_CLIENT_SECRET}",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": ["https://chat.aigw.example.internal/oauth/oidc/callback"],
      "webOrigins": ["https://chat.aigw.example.internal"],
      "attributes": {
        "post.logout.redirect.uris": "https://chat.aigw.example.internal/"
      },
      "protocolMappers": [
        {
          "name": "realm-roles-to-roles-claim",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "claim.name": "roles",
            "jsonType.label": "String",
            "multivalued": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "dev-portal",
      "name": "Developer Portal",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "fullScopeAllowed": false,
      "secret": "${PORTAL_OIDC_CLIENT_SECRET}",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": ["https://portal.aigw.example.internal/auth/callback"],
      "webOrigins": ["https://portal.aigw.example.internal"],
      "attributes": {
        "post.logout.redirect.uris": "https://portal.aigw.example.internal/login"
      },
      "protocolMappers": [
        {
          "name": "realm-roles-to-roles-claim",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "claim.name": "roles",
            "jsonType.label": "String",
            "multivalued": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "admin-portal",
      "name": "AI Gateway Admin Portal",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "fullScopeAllowed": false,
      "secret": "${ADMIN_PORTAL_OIDC_CLIENT_SECRET}",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": ["https://admin.aigw.example.internal/auth/callback"],
      "webOrigins": ["https://admin.aigw.example.internal"],
      "attributes": {
        "post.logout.redirect.uris": "https://admin.aigw.example.internal/login"
      },
      "protocolMappers": [
        {
          "name": "realm-roles-to-roles-claim",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "claim.name": "roles",
            "jsonType.label": "String",
            "multivalued": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "admin-ui",
      "name": "ADM reverse-proxy OIDC gates",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "fullScopeAllowed": false,
      "secret": "${OAUTH2_PROXY_CLIENT_SECRET}",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": [
        "https://litellm-admin.aigw.example.internal/oauth2/callback",
        "https://grafana.aigw.example.internal/oauth2/callback",
        "https://prometheus.aigw.example.internal/oauth2/callback",
        "https://vault.aigw.example.internal/oauth2/callback"
      ],
      "webOrigins": [
        "https://litellm-admin.aigw.example.internal",
        "https://grafana.aigw.example.internal",
        "https://prometheus.aigw.example.internal",
        "https://vault.aigw.example.internal"
      ],
      "attributes": {
        "post.logout.redirect.uris": "https://litellm-admin.aigw.example.internal/##https://grafana.aigw.example.internal/##https://prometheus.aigw.example.internal/##https://vault.aigw.example.internal/"
      },
      "protocolMappers": [
        {
          "name": "realm-roles-to-roles-claim",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "claim.name": "roles",
            "jsonType.label": "String",
            "multivalued": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "vault",
      "name": "Vault UI and CLI OIDC login",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "fullScopeAllowed": false,
      "secret": "${VAULT_OIDC_CLIENT_SECRET}",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": [
        "https://vault.aigw.example.internal/ui/vault/auth/oidc/oidc/callback",
        "http://localhost:8250/oidc/callback"
      ],
      "webOrigins": ["https://vault.aigw.example.internal"],
      "protocolMappers": [
        {
          "name": "realm-roles-to-roles-claim",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "claim.name": "roles",
            "jsonType.label": "String",
            "multivalued": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ],
  "scopeMappings": [
    {
      "client": "open-webui",
      "roles": ["aigw-admins", "aigw-chat", "aigw-developers", "aigw-users"]
    },
    {
      "client": "dev-portal",
      "roles": ["aigw-admins", "aigw-chat", "aigw-developers", "aigw-users"]
    },
    {
      "client": "admin-portal",
      "roles": ["aigw-admins", "aigw-chat", "aigw-developers", "aigw-users"]
    },
    {
      "client": "admin-ui",
      "roles": ["aigw-admins", "aigw-chat", "aigw-developers", "aigw-users"]
    },
    {
      "client": "vault",
      "roles": ["aigw-admins", "aigw-chat", "aigw-developers", "aigw-users"]
    }
  ]
}
