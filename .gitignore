# secrets & generated material — never commit
compose/.env
compose/secrets/
compose/certs/
**/vault-init.json
*.key
!**/templates/*.key

# python
__pycache__/
*.pyc
.venv/
.pytest_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# workstation metadata
.DS_Store

# Local AI-assistant instructions and working memory — never commit
.claude/
.codex/
AGENTS.md
CLAUDE.md
TASKS.md

# ansible
*.retry
.aigw-vault-pass
ansible/inventory/group_vars/gateway/vault.yml.predeploy-*
ansible/inventory/generated/

# Controller-held Vault unseal custody (encrypted, environment-specific — never in git)
ansible/inventory/group_vars/*/vault-unseal.yml
ansible/inventory/generated/

# Controller-local edge-TLS intermediate material staged for customer-intermediate
# (lab convenience or production). The private key is already caught by *.key;
# this also keeps the intermediate cert/chain PEMs out of git.
ansible/inventory/local-pki/

# Claude Code agent worktrees
.claude/worktrees/

# macOS/Finder duplicate-file artifacts (never source)
*[[:space:]]2.json
*[[:space:]]2.example
*[[:space:]]2.py
*[[:space:]]2.yml
*[[:space:]]2.sh
