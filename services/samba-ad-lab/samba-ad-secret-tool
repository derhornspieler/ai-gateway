#!/usr/bin/python3
"""Invoke pinned Samba administration code without secrets in OS argv/env.

Docker secret paths and non-secret identifiers are the only process
arguments. The password is read into this process and passed directly to
Samba's in-process command dispatcher; no credential-bearing child process is
spawned and the value is never copied into ``sys.argv`` or the environment.
"""

from __future__ import annotations

import os
import re
import stat
import sys

from samba.netcmd.main import samba_tool


NAME_RE = re.compile(r"[A-Za-z0-9][A-Za-z0-9._-]{0,127}\Z")
REALM_RE = re.compile(r"[A-Z0-9][A-Z0-9.-]{2,252}[A-Z0-9]\Z")
DOMAIN_RE = re.compile(r"[A-Z0-9][A-Z0-9-]{0,14}\Z")
HOST_RE = re.compile(r"[a-z0-9][a-z0-9-]{0,62}\Z")
OU_RE = re.compile(r"OU=[A-Za-z][A-Za-z0-9-]{0,63}\Z")
SECRET_PATH_RE = re.compile(r"/run/secrets/[A-Za-z0-9][A-Za-z0-9_.-]{0,127}\Z")


def die(message: str) -> "NoReturn":
    print(f"samba-ad-secret-tool: {message}", file=sys.stderr)
    raise SystemExit(2)


def read_secret(path: str) -> str:
    if not SECRET_PATH_RE.fullmatch(path):
        die("secret path must be a simple file under /run/secrets")
    flags = os.O_RDONLY | getattr(os, "O_NOFOLLOW", 0)
    try:
        descriptor = os.open(path, flags)
        try:
            metadata = os.fstat(descriptor)
            if not stat.S_ISREG(metadata.st_mode) or metadata.st_size > 513:
                die("secret file is not a bounded regular file")
            raw = os.read(descriptor, 514)
        finally:
            os.close(descriptor)
    except OSError:
        die("secret file is unavailable")
    try:
        value = raw.decode("utf-8").rstrip("\r\n")
    except UnicodeDecodeError:
        die("secret file is not valid UTF-8")
    lowered = value.lower()
    if len(value) < 16 or len(value) > 512 or any(ord(ch) < 32 for ch in value):
        die("secret must be 16-512 printable characters")
    if any(marker in lowered for marker in ("change_me", "changeme", "password")):
        die("secret is an obvious placeholder")
    return value


def checked(value: str, pattern: re.Pattern[str], label: str) -> str:
    if not pattern.fullmatch(value):
        die(f"{label} contains unsupported characters")
    return value


def invoke(tool_args: list[str], secret: str) -> None:
    # samba_tool dispatches in this Python process. Critically, `secret` is
    # present only in this ordinary object and tool_args; neither sys.argv nor
    # the kernel-visible environment is changed.
    result = samba_tool(*tool_args)
    tool_args.clear()
    secret = ""  # best-effort lifetime bound; Python strings are immutable
    if result:
        raise SystemExit(result)


def main(argv: list[str]) -> None:
    if len(argv) < 3:
        die("usage: <domain-provision|user-create|user-setpassword> SECRET_FILE ...")
    operation, secret_path, *arguments = argv[1:]
    secret = read_secret(secret_path)

    if operation == "domain-provision":
        if len(arguments) != 3:
            die("domain-provision requires REALM DOMAIN HOSTNAME")
        realm = checked(arguments[0], REALM_RE, "realm")
        domain = checked(arguments[1], DOMAIN_RE, "domain")
        hostname = checked(arguments[2], HOST_RE, "hostname")
        invoke(
            [
                "domain",
                "provision",
                "--server-role=dc",
                "--use-rfc2307",
                "--dns-backend=SAMBA_INTERNAL",
                f"--realm={realm}",
                f"--domain={domain}",
                f"--host-name={hostname}",
                "--option=server min protocol = SMB2_02",
                "--option=ntlm auth = ntlmv2-only",
                "--option=restrict anonymous = 2",
                "--option=tls enabled = yes",
                "--option=tls keyfile = /var/lib/samba/private/tls/key.pem",
                "--option=tls certfile = /var/lib/samba/private/tls/cert.pem",
                "--option=tls cafile = /var/lib/samba/private/tls/ca.pem",
                f"--adminpass={secret}",
            ],
            secret,
        )
        return

    if operation in {"user-create", "bind-user-create"}:
        if len(arguments) not in {1, 2}:
            die("user-create requires USERNAME [OU=NAME]")
        username = checked(arguments[0], NAME_RE, "username")
        tool_args = ["user", "create", username, secret]
        if len(arguments) == 2:
            tool_args.append(f"--userou={checked(arguments[1], OU_RE, 'user OU')}")
        description = (
            "Keycloak read-only LDAP bind account"
            if operation == "bind-user-create"
            else "Disposable AI Gateway lab identity"
        )
        tool_args.append(f"--description={description}")
        invoke(tool_args, secret)
        return

    if operation == "user-setpassword":
        if len(arguments) != 1:
            die("user-setpassword requires USERNAME")
        username = checked(arguments[0], NAME_RE, "username")
        invoke(
            ["user", "setpassword", username, f"--newpassword={secret}"],
            secret,
        )
        return

    die("unsupported operation")


if __name__ == "__main__":
    main(sys.argv)
