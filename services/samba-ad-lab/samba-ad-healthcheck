#!/bin/sh
set -eu

test -s /var/lib/samba/private/sam.ldb
test -s /etc/samba/smb.conf
smbcontrol samba ping >/dev/null 2>&1
samba-tool domain info 127.0.0.1 2>/dev/null \
    | grep -Eq '^Domain[[:space:]]+:'
password_settings=$(samba-tool domain passwordsettings show 2>/dev/null)
printf '%s\n' "$password_settings" \
    | grep -Eq '^Account lockout threshold \(attempts\):[[:space:]]+5$'
printf '%s\n' "$password_settings" \
    | grep -Eq '^Account lockout duration \(mins\):[[:space:]]+15$'
printf '%s\n' "$password_settings" \
    | grep -Eq '^Reset account lockout after \(mins\):[[:space:]]+15$'
# Verify LDAPS against the exact FQDN the endpoint is addressed by
# (ldaps://samba-ad.$DOMAIN:636) — the only name the customer-CA-signed leaf
# bears. Falls back to <host>.<forest> for a bare docker run. This exercises
# hostname verification, not merely that a socket answers on 636.
fqdn=${SAMBA_LDAPS_FQDN:-$(hostname).$(samba-tool domain info 127.0.0.1 2>/dev/null \
    | awk -F: '/^Forest[[:space:]]*:/ {gsub(/[[:space:]]/, "", $2); print tolower($2)}')}
test -n "$fqdn"

# Choose the verification anchor deliberately. /var/lib/samba-public/ca.pem is
# the DC's OWN published anchor: the entrypoint republishes into it whatever cert
# the DC currently serves, so a self-signed fallback would verify against itself
# and a silent downgrade would stay green. Once CA-issued material has been in
# force (persistent marker written by the entrypoint), the trust path MUST be
# load-bearing on the REAL customer chain — the delivered leaf+intermediate+root
# in $tls_cert_src — not on that self-published anchor. This makes the
# healthcheck FAIL if the DC ever serves a self-signed certificate while CA
# material was expected.
ca_material_marker=/var/lib/samba/.aigw-ca-material-in-force
tls_cert_src=${SAMBA_TLS_CERT_FILE:-/run/secrets/samba_ad_tls_cert}
if [ -f "$ca_material_marker" ]; then
    test -s "$tls_cert_src"
    verify_cafile=$tls_cert_src
else
    verify_cafile=/var/lib/samba-public/ca.pem
fi
timeout 5 openssl s_client \
    -connect 127.0.0.1:636 \
    -CAfile "$verify_cafile" \
    -verify_hostname "$fqdn" \
    -verify_return_error </dev/null >/dev/null 2>&1
