#!/usr/bin/env bash
# SAFE EXECUTABLE TEMPLATE: fill only non-secret path/connection values below.
set -euo pipefail

: "${AIGW_SSH_TARGET:?set to ansible@LAB_ADM_IP}"
: "${AIGW_INVENTORY:?set to the lab inventory path}"
: "${AIGW_INVENTORY_ALIAS:?set to the lab host alias}"
: "${AIGW_VAULT_ID:?set to the Ansible Vault ID label}"
: "${AIGW_VAULT_PASSWORD_FILE:?set to a private 0600 controller file}"

# The first ordinary converge deploys a fresh, deliberately uninitialized
# Vault. It is a staging phase, not a completed deployment.
ansible-playbook -i "$AIGW_INVENTORY" ansible/site.yml \
  --limit "$AIGW_INVENTORY_ALIAS" \
  --vault-id "$AIGW_VAULT_ID@$AIGW_VAULT_PASSWORD_FILE"

# vault-bootstrap emits only the accepted share on captured stdout and does so
# only after its complete runtime wait succeeds. Normal output stays on stderr.
ssh -T "$AIGW_SSH_TARGET" \
  'sudo -- /opt/ai-gateway/scripts/vault-bootstrap.sh --emit-unseal-key' |
  python3 scripts/store-vault-unseal-key.py \
    --vault-file ansible/inventory/group_vars/gateway/vault-unseal.yml \
    --vault-id "$AIGW_VAULT_ID" \
    --vault-password-file "$AIGW_VAULT_PASSWORD_FILE"

# This ordinary converge proves the encrypted controller variable is loadable,
# Vault is unsealed, and strict dependency readiness succeeds.
ansible-playbook -i "$AIGW_INVENTORY" ansible/site.yml \
  --limit "$AIGW_INVENTORY_ALIAS" \
  --vault-id "$AIGW_VAULT_ID@$AIGW_VAULT_PASSWORD_FILE"

printf '%s\n' \
  'Full readiness passed. Separately custody/revoke the bootstrap root token,' \
  'then securely delete /opt/ai-gateway/secrets/vault-init.json on the VM.'

