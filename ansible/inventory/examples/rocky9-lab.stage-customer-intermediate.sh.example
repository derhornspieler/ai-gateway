#!/usr/bin/env bash
# SAFE EXECUTABLE TEMPLATE: the one-time controller-side pre-step that stages an
# intermediate CA (certificate + PRIVATE KEY + complete chain) into the
# gitignored controller-local path the lab customer-intermediate inventory
# references. Run it ONCE from the repository root before the lab converge.
#
# It does NOT hardcode any source path: point AIGW_LOCAL_PKI_* at your local
# aegisgroup.ch PKI outputs (platform_services' scripts/pki/generate-ca.sh emits
# exactly <name>-ca.pem + <name>-ca-key.pem + ca-chain.pem for an intermediate).
# The customer ROOT key is never referenced, copied, or staged.
set -euo pipefail
umask 077

# Source material — three files from your local intermediate CA. Example values
# assume a platform_services-style layout; override for your own PKI.
: "${AIGW_LOCAL_PKI_INT_CERT:?path to the intermediate CA certificate PEM}"
: "${AIGW_LOCAL_PKI_INT_KEY:?path to the intermediate CA PRIVATE KEY PEM (0600)}"
: "${AIGW_LOCAL_PKI_CHAIN:?path to the complete intermediate+root chain PEM}"

# Destination — the gitignored controller-local staging dir the lab inventory
# points at (ansible/inventory/local-pki/{intermediate.pem,intermediate.key,ca-chain.pem}).
DEST="${AIGW_LOCAL_PKI_DEST:-ansible/inventory/local-pki}"

for src in "$AIGW_LOCAL_PKI_INT_CERT" "$AIGW_LOCAL_PKI_INT_KEY" "$AIGW_LOCAL_PKI_CHAIN"; do
  [[ -f "$src" && ! -L "$src" ]] || { echo "FATAL: not a regular file: $src" >&2; exit 1; }
done
if ! grep -q "PRIVATE KEY" "$AIGW_LOCAL_PKI_INT_KEY"; then
  echo "FATAL: $AIGW_LOCAL_PKI_INT_KEY does not contain a private key" >&2; exit 1
fi
for public in "$AIGW_LOCAL_PKI_INT_CERT" "$AIGW_LOCAL_PKI_CHAIN"; do
  if grep -q "PRIVATE KEY" "$public"; then
    echo "FATAL: $public contains private key material; the cert/chain are public only" >&2
    exit 1
  fi
done

mkdir -p "$DEST"
chmod 0700 "$DEST"
install -m 0644 -- "$AIGW_LOCAL_PKI_INT_CERT" "$DEST/intermediate.pem"
install -m 0644 -- "$AIGW_LOCAL_PKI_CHAIN"    "$DEST/ca-chain.pem"
install -m 0600 -- "$AIGW_LOCAL_PKI_INT_KEY"  "$DEST/intermediate.key"

echo ">> staged intermediate material into $DEST (key 0600). Now converge:"
echo ">>   ansible-playbook -i <lab inventory> ansible/site.yml   # pass 1 stages secrets/"
echo ">>   sudo scripts/vault-bootstrap.sh                        # lab Vault init (defers edge)"
echo ">>   ansible-playbook -i <lab inventory> ansible/site.yml   # pass 2"
echo ">> then on the VM, the import ceremony:"
echo ">>   read -rsp 'Vault token: ' TOK; printf '\\n'"
echo ">>   printf '%s\\n' \"\$TOK\" | sudo scripts/vault-pki-intermediate.sh import-intermediate \\"
echo ">>       --intermediate secrets/aigw-intermediate-import.pem \\"
echo ">>       --intermediate-key secrets/aigw-intermediate-import.key \\"
echo ">>       --chain secrets/aigw-intermediate-import-chain.pem; unset TOK"
