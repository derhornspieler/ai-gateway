---
# SAFE TEMPLATE ONLY — a disposable three-interface lab exercising the
# customer-intermediate edge-TLS mode with material sourced from the LOCAL
# Aegis (aegisgroup.ch) PKI.
#
# customer-intermediate is ONE mode used by both lab and production; they differ
# only in WHERE the intermediate material comes from. In the lab the operator
# stages an intermediate CA (certificate + PRIVATE KEY + chain) from the local
# aegisgroup.ch PKI onto the controller ONCE, then a normal converge "just
# works". In production the deploying engineer supplies the same three paths
# from their own CA. No platform_services path is baked into shipped code: this
# inventory references a controller-local path the operator stages with
# rocky9-lab.stage-customer-intermediate.sh.example.
deployment_profile: rocky9-lab
ansible_host: "<LAB_ADM_INTERFACE_IP>"
ansible_user: ansible
ansible_become: true
# aigw_domain MUST fall inside the intermediate's / root's permitted
# name-constraint subtree. The Aegis Group Root CA permits DNS:aegisgroup.ch,
# so aigw.aegisgroup.ch verifies; a domain outside it fails the import ceremony
# fail-closed with OpenSSL's "permitted subtree violation".
aigw_domain: aigw.aegisgroup.ch
aigw_management_ssh_port: 22

nic_egress: "<LAB_EGRESS_INTERFACE>"
nic_adm: "<LAB_ADM_INTERFACE>"
nic_internal: "<LAB_INTERNAL_INTERFACE>"
eth0_ip: "<LAB_EGRESS_STATIC_IP>"
eth0_gateway: "<LAB_EGRESS_GATEWAY>"
eth1_ip: "<LAB_ADM_STATIC_IP>"
eth1_gateway: "<LAB_ADM_GATEWAY>"
eth2_ip: "<LAB_INTERNAL_STATIC_IP>"
eth2_gateway: "<LAB_INTERNAL_GATEWAY>"
vpn_client_cidr: "<LAB_ADM_ALLOWED_CIDR>"
internal_cidr: "<LAB_INTERNAL_ALLOWED_CIDR>"

internal_dns_servers:
  - "<LAB_INTERNAL_RECURSIVE_DNS>"
egress_dns_servers:
  - "<LAB_INTERNET_RECURSIVE_DNS>"
platform_authoritative_dns_enabled: true
aigw_vault_ui_enabled: true

manage_networking: true
require_encrypted_state: false
require_preupgrade_backup: false
aigw_ssh_password_authentication: true
samba_lab_enabled: true
aigw_seed_test_users: true
retain_bootstrap_admin_user: true

# ── Edge TLS: customer-intermediate ───────────────────────────────────────
# Controller-local PEM paths staged ONCE by
# rocky9-lab.stage-customer-intermediate.sh.example. The key file must be 0600,
# a regular non-symlink single-link file (the preflight and the on-host ceremony
# both enforce this). The chain file is the COMPLETE intermediate + root chain.
# ansible/inventory/local-pki/ is gitignored so this material never lands in git.
#
# These MUST be absolute paths. Ansible resolves a relative stat/copy path
# against the invoking playbook's own directory (ansible/), never the
# repository root — so a relative value here silently mis-resolves (e.g.
# "ansible/inventory/local-pki/x.pem" becomes
# "ansible/ansible/inventory/local-pki/x.pem") and the preflight fails closed
# with a clear "must be an absolute path" error. Substitute your own absolute
# repository path below.
aigw_edge_tls_mode: customer-intermediate
aigw_edge_tls_intermediate_cert_file: "<ABSOLUTE_PATH_TO_REPO>/ansible/inventory/local-pki/intermediate.pem"
aigw_edge_tls_intermediate_key_file: "<ABSOLUTE_PATH_TO_REPO>/ansible/inventory/local-pki/intermediate.key"
aigw_edge_tls_intermediate_chain_file: "<ABSOLUTE_PATH_TO_REPO>/ansible/inventory/local-pki/ca-chain.pem"
