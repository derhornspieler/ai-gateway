---
# SAFE TEMPLATE ONLY. This is the production/customer Rocky 9 input surface.
# `rocky9-production` is the canonical profile (Ansible group
# production_rocky9); `generic-rocky9` remains the backwards-compatible
# DEPRECATED alias and keeps working for previously generated inventories.
aigw_generic_inventory_alias: production-aigw01
deployment_profile: rocky9-production

ansible_host: "<ADM_INTERFACE_IP_OR_SSH_HOST>"
ansible_user: ansible
ansible_become: true
aigw_domain: "<INTERNAL_DNS_ZONE>"
aigw_management_ssh_port: 22

nic_egress: "<EGRESS_INTERFACE>"
nic_adm: "<ADM_INTERFACE>"
nic_internal: "<INTERNAL_INTERFACE>"
eth0_ip: "<EGRESS_STATIC_IP>"
eth0_gateway: "<EGRESS_GATEWAY>"
eth1_ip: "<ADM_STATIC_IP>"
eth1_gateway: "<ADM_GATEWAY>"
eth2_ip: "<INTERNAL_STATIC_IP>"
eth2_gateway: "<INTERNAL_GATEWAY>"
vpn_client_cidr: "<ADM_ALLOWED_CIDR>"
internal_cidr: "<INTERNAL_ALLOWED_CIDR>"

internal_dns_servers:
  - "<INTERNAL_RECURSIVE_DNS>"
egress_dns_servers:
  - "<INTERNET_RECURSIVE_DNS>"
platform_authoritative_dns_enabled: false
aigw_vault_ui_enabled: false

manage_networking: true
pbr_tables:
  - name: adm
    id: 101
    priority: 10101
    dev: "{{ nic_adm }}"
    gw: "{{ eth1_gateway }}"
    src: "{{ eth1_ip }}"
  - name: internal
    id: 102
    priority: 10102
    dev: "{{ nic_internal }}"
    gw: "{{ eth2_gateway }}"
    src: "{{ eth2_ip }}"

require_encrypted_state: true
require_preupgrade_backup: true
aigw_ssh_password_authentication: false
samba_lab_enabled: false
aigw_seed_test_users: false
retain_bootstrap_admin_user: false

