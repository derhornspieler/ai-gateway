---
# SAFE NAME-ONLY TEMPLATE. Do not put real plaintext values in this file.
# Generate a new value-level encrypted overlay with
# scripts/bootstrap-rocky9-production.py (or its DEPRECATED alias
# bootstrap-generic-rocky9.py). Every value below must render as !vault.
pg_super_password: "<INLINE_ANSIBLE_VAULT_VALUE_REQUIRED>"
pg_litellm_password: "<INLINE_ANSIBLE_VAULT_VALUE_REQUIRED>"
pg_keycloak_password: "<INLINE_ANSIBLE_VAULT_VALUE_REQUIRED>"
pg_rotator_password: "<INLINE_ANSIBLE_VAULT_VALUE_REQUIRED>"
kc_admin_password: "<INLINE_ANSIBLE_VAULT_VALUE_REQUIRED>"
litellm_master_key: "<INLINE_ANSIBLE_VAULT_VALUE_REQUIRED>"
litellm_salt_key: "<INLINE_ANSIBLE_VAULT_VALUE_REQUIRED>"
redis_password: "<INLINE_ANSIBLE_VAULT_VALUE_REQUIRED>"
webui_litellm_key: "<INLINE_ANSIBLE_VAULT_VALUE_REQUIRED>"
webui_secret_key: "<INLINE_ANSIBLE_VAULT_VALUE_REQUIRED>"
webui_oidc_client_secret: "<INLINE_ANSIBLE_VAULT_VALUE_REQUIRED>"
portal_oidc_client_secret: "<INLINE_ANSIBLE_VAULT_VALUE_REQUIRED>"
admin_portal_oidc_client_secret: "<INLINE_ANSIBLE_VAULT_VALUE_REQUIRED>"
oauth2_proxy_client_secret: "<INLINE_ANSIBLE_VAULT_VALUE_REQUIRED>"
vault_oidc_client_secret: "<INLINE_ANSIBLE_VAULT_VALUE_REQUIRED>"
oauth2_proxy_litellm_cookie_secret: "<INLINE_ANSIBLE_VAULT_VALUE_REQUIRED>"
oauth2_proxy_grafana_cookie_secret: "<INLINE_ANSIBLE_VAULT_VALUE_REQUIRED>"
oauth2_proxy_prometheus_cookie_secret: "<INLINE_ANSIBLE_VAULT_VALUE_REQUIRED>"
oauth2_proxy_vault_cookie_secret: "<INLINE_ANSIBLE_VAULT_VALUE_REQUIRED>"
portal_session_secret: "<INLINE_ANSIBLE_VAULT_VALUE_REQUIRED>"
admin_portal_session_secret: "<INLINE_ANSIBLE_VAULT_VALUE_REQUIRED>"
rotator_internal_token: "<INLINE_ANSIBLE_VAULT_VALUE_REQUIRED>"
portal_identity_token: "<INLINE_ANSIBLE_VAULT_VALUE_REQUIRED>"
grafana_admin_password: "<INLINE_ANSIBLE_VAULT_VALUE_REQUIRED>"
kc_bootstrap_admin_client_secret: "<INLINE_ANSIBLE_VAULT_VALUE_REQUIRED>"

# Never generate this value in advance. HashiCorp Vault returns it during the
# first operator-init ceremony. Store it afterward with the stdin-only helper.
# The supported boundary is: first converge (not complete) -> reviewed
# production init/unseal -> hidden controller read piped to the helper ->
# ordinary second converge -> full readiness -> remote init-material cleanup.
vault_unseal_key: "<OPERATOR_INIT_OUTPUT; INLINE_ANSIBLE_VAULT_VALUE_REQUIRED>"
