# Added only after first operator init; never randomly generated. In a
# disposable lab, reserve remote bootstrap stdout for the share and pipe it
# directly to scripts/store-vault-unseal-key.py using a dedicated sibling
# group_vars/gateway/vault-unseal.yml. Then rerun the ordinary playbook and
# require full readiness before deleting remote secrets/vault-init.json.
vault_unseal_key: "<OPERATOR_INIT_OUTPUT; INLINE_ANSIBLE_VAULT_VALUE_REQUIRED>"
