{
  "schema": "aigw.generic-rocky9/v1",
  "profile": "generic-rocky9",
  "canonical_profile": "rocky9-production",
  "compatibility_profile": "generic-rocky9",
  "canonical_group": "production_rocky9",
  "compatibility_group": "generic_rocky9",
  "host_vars_filename": "{inventory_alias}.yml",
  "required_nonsecret_keys": [
    "aigw_generic_inventory_alias",
    "ansible_host",
    "ansible_user",
    "aigw_domain",
    "nic_egress",
    "nic_adm",
    "nic_internal",
    "eth0_ip",
    "eth0_gateway",
    "eth1_ip",
    "eth1_gateway",
    "eth2_ip",
    "eth2_gateway",
    "vpn_client_cidr",
    "internal_cidr",
    "internal_dns_servers",
    "egress_dns_servers",
    "aigw_management_ssh_port",
    "manage_networking",
    "pbr_tables",
    "require_encrypted_state",
    "require_preupgrade_backup",
    "platform_authoritative_dns_enabled",
    "aigw_vault_ui_enabled",
    "aigw_edge_tls_mode",
    "identity_ldap_enabled"
  ],
  "required_secret_keys": [
    {"name": "pg_super_password", "min_length": 24, "alphabet": "safe"},
    {"name": "pg_litellm_password", "min_length": 24, "alphabet": "safe"},
    {"name": "pg_keycloak_password", "min_length": 24, "alphabet": "safe"},
    {"name": "pg_rotator_password", "min_length": 24, "alphabet": "safe"},
    {"name": "pg_grafana_ro_password", "min_length": 24, "alphabet": "safe"},
    {"name": "kc_admin_password", "min_length": 24, "alphabet": "safe"},
    {"name": "litellm_master_key", "min_length": 32, "alphabet": "safe"},
    {"name": "litellm_salt_key", "min_length": 32, "alphabet": "safe"},
    {"name": "litellm_ui_breakglass_password", "min_length": 32, "alphabet": "safe"},
    {"name": "redis_password", "min_length": 32, "alphabet": "safe"},
    {"name": "webui_litellm_key", "min_length": 24, "alphabet": "safe", "prefix": "sk-"},
    {"name": "webui_secret_key", "min_length": 32, "alphabet": "safe"},
    {"name": "webui_oidc_client_secret", "min_length": 32, "alphabet": "safe"},
    {"name": "portal_oidc_client_secret", "min_length": 32, "alphabet": "safe"},
    {"name": "admin_portal_oidc_client_secret", "min_length": 32, "alphabet": "safe"},
    {"name": "oauth2_proxy_client_secret", "min_length": 32, "alphabet": "safe"},
    {"name": "vault_oidc_client_secret", "min_length": 32, "alphabet": "safe"},
    {"name": "oauth2_proxy_litellm_cookie_secret", "exact_length": 32, "alphabet": "alnum"},
    {"name": "oauth2_proxy_grafana_cookie_secret", "exact_length": 32, "alphabet": "alnum"},
    {"name": "oauth2_proxy_prometheus_cookie_secret", "exact_length": 32, "alphabet": "alnum"},
    {"name": "oauth2_proxy_vault_cookie_secret", "exact_length": 32, "alphabet": "alnum"},
    {"name": "portal_session_secret", "min_length": 32, "alphabet": "safe"},
    {"name": "admin_portal_session_secret", "min_length": 32, "alphabet": "safe"},
    {"name": "rotator_internal_token", "min_length": 32, "alphabet": "safe"},
    {"name": "portal_identity_token", "min_length": 32, "alphabet": "safe"},
    {"name": "grafana_admin_password", "min_length": 24, "alphabet": "safe"},
    {"name": "kc_bootstrap_admin_client_secret", "min_length": 32, "alphabet": "safe"}
  ],
  "operator_supplied_secret_keys": [
    {
      "name": "vault_unseal_key",
      "source": "hashicorp-vault-operator-init",
      "generated_by_inventory_bootstrap": false
    }
  ],
  "lab_only_secret_keys": [
    "samba_ad_admin_password",
    "samba_ad_bind_password",
    "samba_user_lab_admin_password",
    "samba_user_lab_developer_password",
    "samba_user_lab_user_password"
  ],
  "conditional_feature_keys": {
    "identity_ldap": {
      "enabled_by": "identity_ldap_enabled",
      "required_nonsecret_keys": [
        "identity_ldap_provider_name",
        "identity_ldap_url",
        "identity_ldap_users_dn",
        "identity_ldap_bind_dn",
        "identity_ldap_ca_bundle_src",
        "identity_ldap_directory_ip",
        "identity_ldap_vendor",
        "identity_ldap_username_attribute",
        "identity_ldap_rdn_attribute",
        "identity_ldap_uuid_attribute",
        "identity_ldap_user_object_classes",
        "identity_ldap_user_filter"
      ],
      "operator_supplied_secret_keys": [
        {
          "name": "identity_ldap_bind_password",
          "source": "customer-directory-bind-account",
          "generated_by_inventory_bootstrap": false
        }
      ]
    },
    "edge_tls_customer_intermediate": {
      "enabled_by": "aigw_edge_tls_mode == 'customer-intermediate'",
      "informational": "These three keys are edge-TLS-mode-conditional file paths, validated in the playbooks like the customer-supplied trio; they are intentionally NOT in required_nonsecret_keys so lab/vault-intermediate/customer-supplied inventories stay valid. The intermediate PRIVATE KEY is a controller-local file path, never an inventory secret and never an inline-encrypted overlay value.",
      "required_nonsecret_keys": [
        "aigw_edge_tls_intermediate_cert_file",
        "aigw_edge_tls_intermediate_key_file",
        "aigw_edge_tls_intermediate_chain_file"
      ]
    }
  }
}
