#!/usr/bin/env bash
# Atomic DOCKER-USER policy for the Docker iptables firewall backend.
# Managed by Ansible; safe before or after dockerd starts.
set -euo pipefail

{% set _egress_net = docker_networks | selectattr('name', 'equalto', 'net-egress') | first %}
{% set _internal_net = docker_networks | selectattr('name', 'equalto', 'net-internal') | first %}

# iptables-restore commits the complete filter-table transaction atomically.
# `iptables -F` followed by one-rule-at-a-time appends created a real fail-open
# interval on every firewalld reload. --noflush preserves Docker/firewalld's
# other chains; only DOCKER-USER is replaced. --wait serializes with dockerd.
iptables-restore --wait 15 --noflush <<'AIGW_IPV4_RULES'
*filter
:DOCKER-USER - [0:0]
-F DOCKER-USER

# Same managed bridge is a legitimate application plane. Cross-bridge traffic
# is denied in both directions; a service is attached to every plane it needs.
{% for net in docker_networks %}
-A DOCKER-USER -i {{ net.bridge }} -o {{ net.bridge }} -j RETURN
{% endfor %}
{% if platform_authoritative_dns_enabled | bool %}
# Only the three ordinary ADM/internal edge bridges have a route to an
# upstream resolver. Isolated application bridges are service-discovery-only;
# excluding net-vendor/net-metrics also prevents multi-homed Envoy from
# reaching the internal resolver plane through one of its side networks.
{% for net in docker_networks if net.name in ['net-adm', 'net-internal', 'net-int-edge'] %}
-A DOCKER-USER -i {{ net.bridge }} -o br-platform-dns -d {{ platform_dns_ip }}/32 -p udp --dport 53 -j RETURN
-A DOCKER-USER -i {{ net.bridge }} -o br-platform-dns -d {{ platform_dns_ip }}/32 -p tcp --dport 53 -j RETURN
{% endfor %}
# Cross-bridge default-deny below intentionally precedes the generic reply
# allowance. Preserve that stale-flow protection while admitting only replies
# to the exact DNS requests allowed above; otherwise the request reaches
# CoreDNS but every answer is dropped on br-platform-dns -> application bridge.
{% for net in docker_networks if net.name in ['net-adm', 'net-internal', 'net-int-edge'] %}
-A DOCKER-USER -i br-platform-dns -o {{ net.bridge }} -s {{ platform_dns_ip }}/32 -p udp --sport 53 -m conntrack --ctstate ESTABLISHED,RELATED --ctdir REPLY -j RETURN
-A DOCKER-USER -i br-platform-dns -o {{ net.bridge }} -s {{ platform_dns_ip }}/32 -p tcp --sport 53 -m conntrack --ctstate ESTABLISHED,RELATED --ctdir REPLY -j RETURN
{% endfor %}
{% endif %}
{% for net in docker_networks %}
-A DOCKER-USER -i {{ net.bridge }} -o br+ -j DROP
-A DOCKER-USER -i br+ -o {{ net.bridge }} -j DROP
{% endfor %}
-A DOCKER-USER -i br+ -o docker0 -j DROP
-A DOCKER-USER -i docker0 -o br+ -j DROP
-A DOCKER-USER -i docker0 -o docker0 -j RETURN

# Only the REPLY direction bypasses the original-direction policy. A generic
# ESTABLISHED return at the top let a connection opened during a firewall
# reload remain authorized indefinitely after the policy was restored.
-A DOCKER-USER -m conntrack --ctstate ESTABLISHED,RELATED --ctdir REPLY -j RETURN

# Inbound DNAT to the exact published host addresses. DOCKER-USER sees the
# translated container port, so a source/port-only allow would also authorize
# routed transit traffic. Require a managed bridge output plus conntrack's
# original destination tuple and DNAT state before accepting the flow.
-A DOCKER-USER -i {{ nic_adm }} -o br+ -s {{ vpn_client_cidr }} -p tcp --dport 443 -m conntrack --ctdir ORIGINAL --ctstate DNAT --ctorigdst {{ eth1_ip }}/32 --ctorigdstport 443 -j RETURN
{% if platform_authoritative_dns_enabled | bool %}
-A DOCKER-USER -i {{ nic_adm }} -o br+ -s {{ vpn_client_cidr }} -p udp --dport 53 -m conntrack --ctdir ORIGINAL --ctstate DNAT --ctorigdst {{ eth1_ip }}/32 --ctorigdstport 53 -j RETURN
-A DOCKER-USER -i {{ nic_adm }} -o br+ -s {{ vpn_client_cidr }} -p tcp --dport 53 -m conntrack --ctdir ORIGINAL --ctstate DNAT --ctorigdst {{ eth1_ip }}/32 --ctorigdstport 53 -j RETURN
-A DOCKER-USER -i {{ nic_internal }} -o br+ -s {{ internal_cidr }} -p udp --dport 53 -m conntrack --ctdir ORIGINAL --ctstate DNAT --ctorigdst {{ eth2_ip }}/32 --ctorigdstport 53 -j RETURN
-A DOCKER-USER -i {{ nic_internal }} -o br+ -s {{ internal_cidr }} -p tcp --dport 53 -m conntrack --ctdir ORIGINAL --ctstate DNAT --ctorigdst {{ eth2_ip }}/32 --ctorigdstport 53 -j RETURN
{% endif %}
-A DOCKER-USER -i {{ nic_internal }} -o br+ -s {{ internal_cidr }} -p tcp --dport 443 -m conntrack --ctdir ORIGINAL --ctstate DNAT --ctorigdst {{ eth2_ip }}/32 --ctorigdstport 443 -j RETURN
-A DOCKER-USER -i {{ nic_egress }} -j DROP
-A DOCKER-USER -i {{ nic_adm }} -j DROP
-A DOCKER-USER -i {{ nic_internal }} -j DROP

# Routable internal/ADM edge workloads may query only the exact supplied
# corporate resolver addresses and only through an internal physical leg.
# Isolated backends never receive an upstream resolver in Compose.
{% for net in docker_networks if net.name in ['net-adm', 'net-internal', 'net-int-edge'] %}
{% for resolver in internal_dns_servers %}
-A DOCKER-USER -i {{ net.bridge }} -d {{ resolver }}/32 -o {{ nic_adm }} -p udp --dport 53 -j RETURN
-A DOCKER-USER -i {{ net.bridge }} -d {{ resolver }}/32 -o {{ nic_adm }} -p tcp --dport 53 -j RETURN
-A DOCKER-USER -i {{ net.bridge }} -d {{ resolver }}/32 -o {{ nic_internal }} -p udp --dport 53 -j RETURN
-A DOCKER-USER -i {{ net.bridge }} -d {{ resolver }}/32 -o {{ nic_internal }} -p tcp --dport 53 -j RETURN
{% endfor %}
{% endfor %}

# Original-direction Internet egress is identity-pinned. No other container
# may query an Internet resolver or open vendor HTTPS.
{% for resolver in egress_dns_servers %}
-A DOCKER-USER -i {{ _egress_net.bridge }} -s {{ envoy_egress_ip }}/32 -d {{ resolver }}/32 -o {{ nic_egress }} -p udp --dport 53 -j RETURN
-A DOCKER-USER -i {{ _egress_net.bridge }} -s {{ envoy_egress_ip }}/32 -d {{ resolver }}/32 -o {{ nic_egress }} -p tcp --dport 53 -j RETURN
{% endfor %}
-A DOCKER-USER -i {{ _egress_net.bridge }} -s {{ envoy_egress_ip }}/32 -o {{ nic_egress }} -p tcp --dport 443 -j RETURN
{% if cribl_external_export_enabled | bool %}
-A DOCKER-USER -i {{ _internal_net.bridge }} -s {{ alloy_internal_ip }}/32 -o {{ nic_internal }} -d {{ cribl_otlp_allowed_cidr }} -p tcp --dport {{ cribl_otlp_allowed_port }} -j RETURN
{% endif %}
{% if identity_ldap_enabled | bool %}
# Keycloak alone may open LDAPS to the exact external directory address.
-A DOCKER-USER -i {{ _internal_net.bridge }} -s {{ keycloak_internal_ip }}/32 -o {{ nic_internal }} -d {{ identity_ldap_directory_ip }}/32 -p tcp --dport 636 -j RETURN
{% endif %}

# Default-deny every original-direction flow from a Docker-style bridge to a
# non-bridge interface. This covers all three supplied physical NICs plus any
# later VLAN/tunnel interface; docker0 is handled explicitly as it lacks br-*.
-A DOCKER-USER -i br+ ! -o br+ -j DROP
-A DOCKER-USER -i docker0 ! -o docker0 -j DROP
-A DOCKER-USER -j RETURN
COMMIT
AIGW_IPV4_RULES

# Docker networks are explicitly IPv6-disabled. Keep a fail-closed v6 policy
# anyway so a future accidental enablement cannot silently bypass IPv4 rules.
if command -v ip6tables-restore >/dev/null 2>&1 && ip6tables -L -n >/dev/null 2>&1; then
  ip6tables-restore --wait 15 --noflush <<'AIGW_IPV6_RULES'
*filter
:DOCKER-USER - [0:0]
-F DOCKER-USER
{% for net in docker_networks %}
-A DOCKER-USER -i {{ net.bridge }} -o {{ net.bridge }} -j RETURN
{% endfor %}
{% for net in docker_networks %}
-A DOCKER-USER -i {{ net.bridge }} -o br+ -j DROP
-A DOCKER-USER -i br+ -o {{ net.bridge }} -j DROP
{% endfor %}
-A DOCKER-USER -i br+ -o docker0 -j DROP
-A DOCKER-USER -i docker0 -o br+ -j DROP
-A DOCKER-USER -i docker0 -o docker0 -j RETURN
-A DOCKER-USER -m conntrack --ctstate ESTABLISHED,RELATED --ctdir REPLY -j RETURN
-A DOCKER-USER -i {{ nic_egress }} -j DROP
-A DOCKER-USER -i {{ nic_adm }} -j DROP
-A DOCKER-USER -i {{ nic_internal }} -j DROP
-A DOCKER-USER -i br+ ! -o br+ -j DROP
-A DOCKER-USER -i docker0 ! -o docker0 -j DROP
-A DOCKER-USER -j RETURN
COMMIT
AIGW_IPV6_RULES
fi
