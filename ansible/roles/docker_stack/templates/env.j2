# Managed by Ansible — do not edit on the VM (except ROTATOR_VAULT_TOKEN,
# which scripts/vault-bootstrap.sh writes in place).
DEPLOYMENT_PROFILE={{ deployment_profile }}
PLATFORM_AUTHORITATIVE_DNS_ENABLED={{ platform_authoritative_dns_enabled | bool | lower }}
VAULT_UI_ENABLED={{ aigw_vault_ui_enabled | bool | lower }}
IDENTITY_LDAP_ENABLED={{ identity_ldap_enabled | bool | lower }}
RETAIN_BOOTSTRAP_ADMIN_USER={{ retain_bootstrap_admin_user | bool | lower }}
# Keep operator-run `scripts/aigw-compose.sh` commands on the same explicit
# files selected by Ansible. Profiles are activated only by that strict
# wrapper or by Ansible's explicit argv/module parameters; never persist a
# COMPOSE_PROFILES input that could activate an optional service implicitly.
{% set aigw_env_compose_files = ['docker-compose.yml', 'docker-compose.dns.yml']
   + (['docker-compose.platform-dns.yml']
      if (platform_authoritative_dns_enabled | bool) else [])
   + (['docker-compose.lab.yml'] if (samba_lab_enabled | bool) else [])
   + (['docker-compose.identity-ldap.yml']
      if (identity_ldap_enabled | bool) else []) %}
COMPOSE_FILE={{ aigw_env_compose_files | join(':') }}
{% if platform_authoritative_dns_enabled | bool %}
# CoreDNS selects its administrative split view only for the exact ADM/VPN
# source CIDR that the host preflight and firewall policy already validated.
LAB_DNS_ADM_CIDR={{ vpn_client_cidr }}
{% endif %}
DOMAIN={{ aigw_domain }}
ETH1_IP={{ eth1_ip }}
ETH2_IP={{ eth2_ip }}
DOCKER_DATA_ROOT={{ docker_data_root }}
TRAEFIK_INT_CHAT_IP={{ traefik_int_chat_ip }}
TRAEFIK_INT_PORTAL_IP={{ traefik_int_portal_ip }}
TRAEFIK_ADM_ADMIN_IP={{ traefik_adm_admin_ip }}
OAUTH2_PROXY_LITELLM_IP={{ oauth2_proxy_litellm_ip }}
ENVOY_EGRESS_IP={{ envoy_egress_ip }}
ALLOY_INTERNAL_IP={{ alloy_internal_ip }}
TRAEFIK_ADM_GRAFANA_IP={{ traefik_adm_grafana_ip }}
OAUTH2_PROXY_GRAFANA_IP={{ oauth2_proxy_grafana_ip }}
ALLOY_TELEMETRY_IP={{ alloy_telemetry_ip }}
ALLOY_OBSERVABILITY_IP={{ alloy_observability_ip }}
PROMETHEUS_OBSERVABILITY_IP={{ prometheus_observability_ip }}
TEMPO_INGEST_IP={{ tempo_ingest_ip }}
LAB_DNS_IP={{ lab_dns_ip }}

# Keyed content markers are non-secret Compose metadata. A marker changes only
# when that service's exact bind-source bytes/inventory change, forcing Docker
# to replace path-stable bind mounts after Ansible atomic file replacement.
AIGW_BIND_DIGEST_TRAEFIK_INT={{ aigw_bind_source_digests['traefik-int'] }}
AIGW_BIND_DIGEST_TRAEFIK_ADM={{ aigw_bind_source_digests['traefik-adm'] }}
AIGW_BIND_DIGEST_LITELLM={{ aigw_bind_source_digests['litellm'] }}
AIGW_BIND_DIGEST_OPEN_WEBUI={{ aigw_bind_source_digests['open-webui'] }}
AIGW_BIND_DIGEST_KEYCLOAK={{ aigw_bind_source_digests['keycloak'] }}
AIGW_BIND_DIGEST_VAULT={{ aigw_bind_source_digests['vault'] }}
AIGW_BIND_DIGEST_POSTGRES={{ aigw_bind_source_digests['postgres'] }}
AIGW_BIND_DIGEST_REDIS={{ aigw_bind_source_digests['redis'] }}
AIGW_BIND_DIGEST_ALLOY={{ aigw_bind_source_digests['alloy'] }}
AIGW_BIND_DIGEST_PROMETHEUS={{ aigw_bind_source_digests['prometheus'] }}
AIGW_BIND_DIGEST_LOKI={{ aigw_bind_source_digests['loki'] }}
AIGW_BIND_DIGEST_TEMPO={{ aigw_bind_source_digests['tempo'] }}
AIGW_BIND_DIGEST_GRAFANA={{ aigw_bind_source_digests['grafana'] }}
AIGW_BIND_DIGEST_CRIBL_MOCK={{ aigw_bind_source_digests['cribl-mock'] }}
{% if platform_authoritative_dns_enabled | bool %}
AIGW_BIND_DIGEST_LAB_DNS={{ aigw_bind_source_digests['lab-dns'] }}
{% endif %}
{% if samba_lab_enabled | bool %}
AIGW_BIND_DIGEST_SAMBA_AD={{ aigw_bind_source_digests['samba-ad'] }}
AIGW_BIND_DIGEST_KEY_ROTATOR_LAB={{ aigw_bind_source_digests['key-rotator'] }}
{% endif %}
{% if identity_ldap_enabled | bool %}
{# The bind credential itself is NEVER rendered here: key-rotator reads it from
   the root-owned file bind-mounted at /run/secrets/identity_ldap_bind_password. #}
KEYCLOAK_INTERNAL_IP={{ keycloak_internal_ip }}
IDENTITY_LDAP_HOST={{ identity_ldap_url | urlsplit('hostname') }}
IDENTITY_LDAP_DIRECTORY_IP={{ identity_ldap_directory_ip }}
IDENTITY_LDAP_PROVIDER_NAME={{ identity_ldap_provider_name }}
IDENTITY_LDAP_URL={{ identity_ldap_url }}
IDENTITY_LDAP_USERS_DN={{ identity_ldap_users_dn }}
IDENTITY_LDAP_BIND_DN={{ identity_ldap_bind_dn }}
IDENTITY_LDAP_VENDOR={{ identity_ldap_vendor }}
IDENTITY_LDAP_USERNAME_ATTRIBUTE={{ identity_ldap_username_attribute }}
IDENTITY_LDAP_RDN_ATTRIBUTE={{ identity_ldap_rdn_attribute }}
IDENTITY_LDAP_UUID_ATTRIBUTE={{ identity_ldap_uuid_attribute }}
IDENTITY_LDAP_USER_OBJECT_CLASSES={{ identity_ldap_user_object_classes }}
IDENTITY_LDAP_USER_FILTER={{ identity_ldap_user_filter }}
AIGW_BIND_DIGEST_KEY_ROTATOR_LDAP={{ aigw_bind_source_digests['key-rotator'] }}
{% endif %}

{# Every secret below is `| mandatory(...)`: an unset var aborts the play with
   a clear message instead of shipping a git-known dev default. Define them in
   an ansible-vault overlay (see group_vars/all.yml for the full list + charset
   constraints). #}
PG_SUPER_PASSWORD={{ pg_super_password | mandatory("pg_super_password is unset — define it in an ansible-vault overlay (see group_vars/all.yml)") }}
PG_LITELLM_PASSWORD={{ pg_litellm_password | mandatory("pg_litellm_password is unset — define it in an ansible-vault overlay (see group_vars/all.yml)") }}
PG_KEYCLOAK_PASSWORD={{ pg_keycloak_password | mandatory("pg_keycloak_password is unset — define it in an ansible-vault overlay (see group_vars/all.yml)") }}
PG_ROTATOR_PASSWORD={{ pg_rotator_password | mandatory("pg_rotator_password is unset — define it in an ansible-vault overlay (see group_vars/all.yml)") }}

KC_ADMIN_PASSWORD={{ kc_admin_password | mandatory("kc_admin_password is unset — define it in an ansible-vault overlay (see group_vars/all.yml)") }}
KC_BOOTSTRAP_ADMIN_CLIENT_SECRET={{ kc_bootstrap_admin_client_secret | mandatory("kc_bootstrap_admin_client_secret is unset — define it in an ansible-vault overlay") }}

LITELLM_MASTER_KEY={{ litellm_master_key | mandatory("litellm_master_key is unset — define it in an ansible-vault overlay (see group_vars/all.yml)") }}
LITELLM_SALT_KEY={{ litellm_salt_key | mandatory("litellm_salt_key is unset — define it in an ansible-vault overlay (see group_vars/all.yml)") }}
REDIS_PASSWORD={{ redis_password | mandatory("redis_password is unset — define it in an ansible-vault overlay (see group_vars/all.yml)") }}
{# NOT the master key: Ansible reconciles this candidate as the exact scoped Open WebUI key. #}
WEBUI_LITELLM_KEY={{ webui_litellm_key | mandatory("webui_litellm_key is unset — define a high-entropy scoped-key candidate (NOT the master key) in the vault overlay") }}
{# Stable application/session signing secret: never regenerate on converge or recreate. #}
WEBUI_SECRET_KEY={{ webui_secret_key | mandatory("webui_secret_key is unset — define a STABLE 32+ character secret in an ansible-vault overlay (do not regenerate per run)") }}

WEBUI_OIDC_CLIENT_SECRET={{ webui_oidc_client_secret | mandatory("webui_oidc_client_secret is unset — define it (alphanumeric only) in an ansible-vault overlay") }}
PORTAL_OIDC_CLIENT_SECRET={{ portal_oidc_client_secret | mandatory("portal_oidc_client_secret is unset — define it (alphanumeric only) in an ansible-vault overlay") }}
ADMIN_PORTAL_OIDC_CLIENT_SECRET={{ admin_portal_oidc_client_secret | mandatory("admin_portal_oidc_client_secret is unset — define it (alphanumeric only) in an ansible-vault overlay") }}
OAUTH2_PROXY_CLIENT_SECRET={{ oauth2_proxy_client_secret | mandatory("oauth2_proxy_client_secret is unset — define it (alphanumeric only) in an ansible-vault overlay") }}
OAUTH2_PROXY_LITELLM_COOKIE_SECRET={{ oauth2_proxy_litellm_cookie_secret | mandatory("oauth2_proxy_litellm_cookie_secret is unset — define a STABLE per-gate 32-char alphanumeric secret") }}
OAUTH2_PROXY_GRAFANA_COOKIE_SECRET={{ oauth2_proxy_grafana_cookie_secret | mandatory("oauth2_proxy_grafana_cookie_secret is unset — define a STABLE per-gate 32-char alphanumeric secret") }}
OAUTH2_PROXY_PROMETHEUS_COOKIE_SECRET={{ oauth2_proxy_prometheus_cookie_secret | mandatory("oauth2_proxy_prometheus_cookie_secret is unset — define a STABLE per-gate 32-char alphanumeric secret") }}
OAUTH2_PROXY_VAULT_COOKIE_SECRET={{ oauth2_proxy_vault_cookie_secret | mandatory("oauth2_proxy_vault_cookie_secret is unset — define a STABLE per-gate 32-char alphanumeric secret") }}
PORTAL_SESSION_SECRET={{ portal_session_secret | mandatory("portal_session_secret is unset — define it in an ansible-vault overlay") }}
ADMIN_PORTAL_SESSION_SECRET={{ admin_portal_session_secret | mandatory("admin_portal_session_secret is unset — define a distinct stable secret in an ansible-vault overlay") }}

ROTATOR_INTERNAL_TOKEN={{ rotator_internal_token | mandatory("rotator_internal_token is unset — define it in an ansible-vault overlay") }}
PORTAL_IDENTITY_TOKEN={{ portal_identity_token | mandatory("portal_identity_token is unset — define a distinct portal-only identity-read token") }}
ROTATOR_VAULT_TOKEN={{ rotator_vault_token }}

# key-rotator private_key_jwt: Vault path holding the broker client's signing key.
KC_CLIENT_ASSERTION_KEY_VAULT_PATH={{ kc_client_assertion_key_vault_path }}
IDENTITY_CONTROLLER_KEY_VAULT_PATH={{ identity_controller_key_vault_path }}
IDENTITY_STATE_VAULT_PATH={{ identity_state_vault_path }}

GRAFANA_ADMIN_PASSWORD={{ grafana_admin_password | mandatory("grafana_admin_password is unset — define it in an ansible-vault overlay") }}
CRIBL_OTLP_ENDPOINT={{ cribl_otlp_endpoint }}
CRIBL_OTLP_INSECURE={{ cribl_otlp_insecure | bool | lower }}
CRIBL_OTLP_CA_FILE={{ cribl_otlp_ca_file }}
CRIBL_OTLP_SERVER_NAME={{ cribl_otlp_server_name }}
